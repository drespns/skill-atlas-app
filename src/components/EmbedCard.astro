---
import type { ProjectEmbed } from "../data";

const { embed } = Astro.props as { embed: ProjectEmbed };

function getIframeSrc(url: string) {
  // Tableau Public suele necesitar `:showVizHome=no` para renderizar correctamente embebido.
  let next = url;

  // Parametros típicos de enlaces “share” que pueden interferir con el embed.
  next = next.replaceAll("&:redirect=auth", "");
  next = next.replaceAll("&:origin=viz_share_link", "");

  if (!next.includes(":showVizHome=no")) {
    next += "&:showVizHome=no";
  }

  if (!next.includes(":embed=yes")) {
    next += "&:embed=yes";
  }

  return next;
}
---

<article class="border border-gray-200/80 dark:border-gray-800 rounded-xl p-4 bg-white dark:bg-gray-950 flex flex-col gap-3 shadow-sm">
  <h3 class="m-0 text-sm font-semibold">{embed.title}</h3>

  {embed.kind === "iframe" ? (
    <iframe
      class="w-full aspect-video rounded-lg border border-gray-200/80 dark:border-gray-800"
      src={getIframeSrc(embed.url)}
      title={embed.title}
      loading="lazy"
      referrerpolicy="strict-origin-when-cross-origin"
      allowfullscreen
      allow="fullscreen; clipboard-read; clipboard-write"
    />
  ) : (
    <a
      class="inline-flex items-center justify-center rounded-lg border border-gray-200/80 dark:border-gray-800 px-3 py-2 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900 no-underline"
      href={embed.url}
      target="_blank"
      rel="noreferrer"
    >
      Abrir enlace
    </a>
  )}
</article>

