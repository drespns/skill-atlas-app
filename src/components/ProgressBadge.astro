---
import type { ProgressState } from "../data";

const { progress } = Astro.props as { progress: ProgressState };

const styles =
  progress === "mastered"
    ? "bg-purple-100 text-purple-800 border-purple-200"
    : progress === "practicado"
      ? "bg-blue-100 text-blue-800 border-blue-200"
      : "bg-green-100 text-green-800 border-green-200";

const label =
  progress === "mastered"
    ? "Dominado"
    : progress === "practicado"
      ? "Practicado"
      : "Aprendido";
---

<span
  class={`inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold ${styles}`}
>
  {label}
</span>

