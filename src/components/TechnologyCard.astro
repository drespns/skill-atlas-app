---
const { technology } = Astro.props;
---

<article
  class="border border-gray-200 rounded-xl p-4 flex flex-col gap-3"
>
  <div class="flex items-baseline justify-between gap-3">
    <h3 class="m-0 text-base font-semibold">{technology.name}</h3>
    <span
      class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-900 whitespace-nowrap"
      aria-label="Cantidad de conceptos"
    >
      {technology.conceptsCount} conceptos
    </span>
  </div>

  <a
    href={`/technologies/${technology.id}`}
    class="inline-flex items-center justify-center rounded-lg bg-gray-900 px-3 py-2 text-sm font-semibold text-white hover:bg-gray-800 no-underline"
  >
    Ver
  </a>
</article>

