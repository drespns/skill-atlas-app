---
import { getTechnologyIconSrc } from "../config/icons";
import { dataSource } from "../data";

const { technology } = Astro.props;
const iconSrc = getTechnologyIconSrc(technology);

const detailHref =
  dataSource === "supabase"
    ? `/technologies/view?tech=${encodeURIComponent(technology.id)}`
    : `/technologies/${technology.id}`;
---

<article
  class="border border-gray-200/80 dark:border-gray-800 rounded-xl p-4 bg-white dark:bg-gray-950 flex flex-col gap-3 shadow-sm"
>
  <div class="flex items-baseline justify-between gap-3">
    <div class="flex items-center gap-2 min-w-0">
      {iconSrc ? (
        <img src={iconSrc} alt="" class="h-5 w-5 shrink-0" loading="lazy" />
      ) : null}
      <h3 class="m-0 text-base font-semibold truncate">{technology.name}</h3>
    </div>
    <span
      class="text-xs px-2 py-1 rounded-full bg-gray-100 dark:bg-gray-900 text-gray-900 dark:text-gray-100 whitespace-nowrap"
      aria-label="Cantidad de conceptos"
    >
      {technology.conceptsCount} <span data-i18n="technologies.concepts">conceptos</span>
    </span>
  </div>

  <a
    href={detailHref}
    class="inline-flex items-center justify-center rounded-lg bg-gray-900 dark:bg-gray-100 px-3 py-2 text-sm font-semibold text-white dark:text-gray-900 hover:bg-gray-800 dark:hover:bg-gray-200 no-underline"
  >
    <span data-i18n="common.view">Ver</span>
  </a>
</article>

