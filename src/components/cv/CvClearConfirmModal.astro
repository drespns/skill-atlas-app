---
/** Confirmación in-app antes de vaciar el CV (`cv-page.ts`). */
---

<div
  data-cv-clear-modal
  class="fixed inset-0 z-[1002] hidden items-center justify-center p-4 bg-black/40 backdrop-blur-sm print:hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="cv-clear-modal-title"
>
  <div
    data-cv-clear-modal-panel
    class="w-full max-w-md overflow-hidden flex flex-col rounded-2xl border border-gray-200/90 dark:border-gray-800 bg-white dark:bg-gray-950 shadow-xl"
  >
    <div class="px-4 py-3 border-b border-gray-200/80 dark:border-gray-800 shrink-0">
      <h2 id="cv-clear-modal-title" class="m-0 text-base font-bold text-gray-900 dark:text-gray-100" data-i18n="cv.clearModalTitle">
        Vaciar contenido del CV
      </h2>
      <p class="m-0 mt-2 text-sm text-gray-600 dark:text-gray-400" data-i18n="cv.clearModalBody">
        Se borrarán experiencia, educación, certificaciones, idiomas y los campos de texto del CV. No se modifica tu nombre en Ajustes ni la selección de proyectos.
      </p>
    </div>
    <div class="px-4 py-3 flex flex-wrap justify-end gap-2">
      <button
        type="button"
        data-cv-clear-modal-cancel
        class="rounded-lg border border-gray-200 dark:border-gray-700 px-3 py-2 text-sm font-semibold text-gray-800 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-900"
        data-i18n="cv.clearModalCancel"
      >
        Cancelar
      </button>
      <button
        type="button"
        data-cv-clear-modal-confirm
        class="rounded-lg bg-rose-600 text-white px-3 py-2 text-sm font-semibold hover:bg-rose-500"
        data-i18n="cv.clearModalConfirm"
      >
        Vaciar
      </button>
    </div>
  </div>
</div>
