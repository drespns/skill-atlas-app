---
---

<dialog
  data-cv-doc-name-dialog
  class="fixed left-1/2 top-1/2 z-[1200] w-[min(92vw,24rem)] -translate-x-1/2 -translate-y-1/2 rounded-2xl border border-gray-200/90 bg-white p-4 shadow-2xl backdrop:bg-black/50 dark:border-gray-800 dark:bg-gray-950"
>
  <input type="hidden" data-cv-doc-name-mode value="new" />
  <h3 class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100" data-i18n="cv.docNameDialogTitle">
    Nombre del CV
  </h3>
  <p class="m-0 mt-1 text-xs text-gray-500 dark:text-gray-400" data-i18n="cv.docNameDialogHint">
    Elige un nombre para identificarlo en el selector.
  </p>
  <input
    type="text"
    data-cv-doc-name-input
    maxlength="80"
    class="mt-3 w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm text-gray-900 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100"
  />
  <div class="mt-4 flex justify-end gap-2">
    <button
      type="button"
      data-cv-doc-name-cancel
      class="rounded-lg border border-gray-200 px-3 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-50 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-900"
      data-i18n="cv.docDialogCancel"
    >
      Cancelar
    </button>
    <button
      type="button"
      data-cv-doc-name-save
      class="rounded-lg bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-indigo-500"
      data-i18n="cv.docNameDialogSave"
    >
      Crear
    </button>
  </div>
</dialog>

<dialog
  data-cv-doc-manage-dialog
  class="fixed left-1/2 top-1/2 z-[1200] w-[min(92vw,26rem)] -translate-x-1/2 -translate-y-1/2 rounded-2xl border border-gray-200/90 bg-white p-4 shadow-2xl backdrop:bg-black/50 dark:border-gray-800 dark:bg-gray-950"
>
  <h3 class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100" data-i18n="cv.docManageTitle">
    Gestionar CV
  </h3>
  <label class="mt-3 block space-y-1">
    <span class="text-[10px] font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400" data-i18n="cv.docManageNameLabel"
      >Nombre</span
    >
    <input
      type="text"
      data-cv-doc-manage-name
      maxlength="80"
      class="w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm text-gray-900 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100"
    />
  </label>
  <label class="mt-2 block space-y-1">
    <span class="text-[10px] font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400" data-i18n="cv.docManageTagsLabel"
      >Etiquetas (separadas por coma)</span
    >
    <input
      type="text"
      data-cv-doc-manage-tags
      class="w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm text-gray-900 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100"
      placeholder="p. ej. backend, remoto"
    />
  </label>
  <label class="mt-3 flex cursor-pointer items-center gap-2 text-xs text-gray-700 dark:text-gray-200">
    <input type="checkbox" data-cv-doc-manage-main class="accent-indigo-600" />
    <span data-i18n="cv.docManageMainLabel">CV principal (público por defecto y al abrir /cv)</span>
  </label>
  <div class="mt-4 flex flex-wrap items-center justify-between gap-2">
    <button
      type="button"
      data-cv-doc-manage-delete
      class="rounded-lg border border-rose-200/90 px-3 py-1.5 text-xs font-semibold text-rose-800 hover:bg-rose-50 dark:border-rose-900/50 dark:text-rose-200 dark:hover:bg-rose-950/40"
      data-i18n="cv.docManageDelete"
    >
      Eliminar este CV
    </button>
    <div class="flex gap-2">
      <button
        type="button"
        data-cv-doc-manage-cancel
        class="rounded-lg border border-gray-200 px-3 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-50 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-900"
        data-i18n="cv.docDialogCancel"
      >
        Cancelar
      </button>
      <button
        type="button"
        data-cv-doc-manage-save
        class="rounded-lg bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-indigo-500"
        data-i18n="cv.docDialogSave"
      >
        Guardar
      </button>
    </div>
  </div>
</dialog>
