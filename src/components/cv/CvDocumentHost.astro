---
/** Documento renderizado del CV (impresión / preview). */
---

<div data-cv-doc-host>
  <article
    data-cv-document
    class="hidden rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 p-8 shadow-sm print:border-0 print:shadow-none print:p-0"
  >
    <div class="border-b border-gray-200/80 dark:border-gray-800 pb-6 print:border-gray-300">
      <div class="flex items-start gap-5">
        <img
          data-cv-doc-photo
          alt=""
          class="hidden h-16 w-16 rounded-2xl border border-gray-200 dark:border-gray-800 object-cover"
          loading="lazy"
          referrerpolicy="no-referrer"
        />
        <div class="min-w-0 flex-1">
          <h2 data-cv-doc-name class="m-0 text-3xl font-semibold tracking-tight text-gray-900 dark:text-gray-100"></h2>
          <p data-cv-doc-headline class="mt-2 mb-0 text-base font-semibold text-gray-700 dark:text-gray-300"></p>
          <div data-cv-doc-contact class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-gray-600 dark:text-gray-300"></div>
          <p data-cv-doc-bio class="mt-4 mb-0 max-w-3xl text-base leading-relaxed text-gray-600 dark:text-gray-300"></p>
          <div data-cv-doc-helpstack class="mt-4 hidden flex-wrap gap-2"></div>
        </div>
      </div>
    </div>
    <section class="pt-8 hidden" data-cv-doc-experience-section>
      <h3 class="m-0 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400" data-i18n="cv.docExperienceHeading">
        Experiencia
      </h3>
      <div data-cv-doc-experience class="mt-4 space-y-7"></div>
    </section>
    <section class="pt-8 hidden" data-cv-doc-education-section>
      <h3 class="m-0 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400" data-i18n="cv.docEducationHeading">
        Educación
      </h3>
      <div data-cv-doc-education class="mt-4 space-y-6"></div>
    </section>
    <section class="pt-6" data-cv-doc-projects-section>
      <h3 class="m-0 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400" data-i18n="cv.docProjectsHeading">
        Proyectos
      </h3>
      <div data-cv-doc-projects class="mt-4 space-y-8"></div>
    </section>
    <section class="pt-8" data-cv-doc-highlights-section>
      <h3
        class="m-0 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400"
        data-i18n="cv.docHighlightsHeading"
      >
        Experiencia
      </h3>
      <ul data-cv-doc-highlights class="mt-4 space-y-2 pl-5 text-sm text-gray-700 dark:text-gray-300"></ul>
    </section>
  </article>
</div>
