---
/** Formulario de edición del CV; hidratado por `cv-page.ts`. */
const h2 = "cv-section-heading m-0 text-lg md:text-xl font-bold tracking-tight text-gray-900 dark:text-gray-100 border-b border-gray-200/90 dark:border-gray-800 pb-2";
---

<div data-cv-editor class="hidden space-y-6 rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/50 p-5 shadow-sm print:hidden">
  <div class="rounded-xl border border-indigo-200/70 dark:border-indigo-900/40 bg-indigo-50/50 dark:bg-indigo-950/20 p-4 text-sm text-indigo-900 dark:text-indigo-100">
    <span data-i18n="cv.publicShareMovedNote">El enlace público del CV se gestiona en Ajustes → “Portfolio público”.</span>
    <a href="/settings#prefs" class="ml-1 font-semibold underline underline-offset-2 hover:opacity-90" data-i18n="cv.goToSettings">
      Ir a Ajustes
    </a>
  </div>

  <div class="space-y-3">
    <h2 class={h2}>
      <span data-i18n="cv.profileSectionTitle">Datos del CV</span>
    </h2>
    <p class="m-0 text-xs text-gray-500 dark:text-gray-400" data-i18n="cv.settingsSyncHint">
      Nombre, bio, avatar y stack se sincronizan con Ajustes. Si están vacíos, puedes completarlos aquí.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <label class="space-y-1">
        <span class="text-xs font-semibold text-gray-700 dark:text-gray-300" data-i18n="cv.fullNameLabel">Nombre</span>
        <input
          type="text"
          data-cv-full-name
          placeholder="Tu nombre"
          class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm text-gray-900 dark:text-gray-100"
        />
      </label>
      <label class="space-y-1">
        <span class="text-xs font-semibold text-gray-700 dark:text-gray-300" data-i18n="cv.photoLabel">Foto</span>
        <div class="flex items-center gap-3">
          <input
            type="file"
            accept="image/*"
            data-cv-avatar-file
            class="block w-full text-sm text-gray-700 dark:text-gray-300 file:mr-3 file:rounded-lg file:border file:border-gray-200 file:bg-white/70 file:px-3 file:py-2 file:text-sm file:font-semibold hover:file:bg-gray-50 dark:file:border-gray-800 dark:file:bg-gray-950 dark:hover:file:bg-gray-900"
          />
          <button
            type="button"
            data-cv-photo-use-linkedin
            class="hidden text-xs font-semibold text-indigo-700 dark:text-indigo-300 hover:underline"
          >
            <span data-i18n="cv.useLinkedinPhoto">Usar LinkedIn</span>
          </button>
          <button
            type="button"
            data-cv-photo-use-uploaded
            class="hidden text-xs font-semibold text-gray-600 dark:text-gray-400 hover:underline"
          >
            <span data-i18n="cv.useUploadedPhoto">Usar subida</span>
          </button>
          <label class="flex items-start gap-2 cursor-pointer shrink-0">
            <input type="checkbox" data-cv-show-photo class="rounded border-gray-300 dark:border-gray-600 mt-0.5" />
            <span class="text-sm text-gray-800 dark:text-gray-200" data-i18n="cv.showPhotoLabel">Mostrar</span>
          </label>
        </div>
      </label>
      <label class="space-y-1 md:col-span-2">
        <span class="text-xs font-semibold text-gray-700 dark:text-gray-300" data-i18n="cv.publicBioLabel">Bio (Ajustes)</span>
        <textarea
          rows={3}
          data-cv-public-bio
          placeholder="Bio breve (se comparte con portfolio)."
          class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm text-gray-900 dark:text-gray-100"
        ></textarea>
      </label>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <label class="space-y-1">
        <span class="text-xs font-semibold text-gray-700 dark:text-gray-300" data-i18n="cv.headlineLabel">Titular</span>
        <input
          type="text"
          data-cv-headline
          placeholder="Data Analyst · Analytics Engineer"
          class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm text-gray-900 dark:text-gray-100"
        />
      </label>
      <label class="space-y-1">
        <span class="text-xs font-semibold text-gray-700 dark:text-gray-300" data-i18n="cv.locationLabel">Ubicación</span>
        <input
          type="text"
          data-cv-location
          placeholder="Madrid, ES"
          class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm text-gray-900 dark:text-gray-100"
        />
      </label>
      <label class="space-y-1 md:col-span-2">
        <span class="text-xs font-semibold text-gray-700 dark:text-gray-300" data-i18n="cv.emailLabel">Email</span>
        <input
          type="email"
          data-cv-email
          placeholder="tu@email.com"
          class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm text-gray-900 dark:text-gray-100"
        />
      </label>
      <label class="space-y-1">
        <span class="text-xs font-semibold text-gray-700 dark:text-gray-300" data-i18n="cv.phoneMobileLabel">Móvil</span>
        <input
          type="tel"
          data-cv-phone-mobile
          placeholder="+34 …"
          class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm text-gray-900 dark:text-gray-100"
        />
      </label>
      <label class="space-y-1">
        <span class="text-xs font-semibold text-gray-700 dark:text-gray-300" data-i18n="cv.phoneLandlineLabel">Teléfono fijo / otro</span>
        <input
          type="tel"
          data-cv-phone-landline
          placeholder=""
          class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm text-gray-900 dark:text-gray-100"
        />
      </label>
    </div>
    <div class="space-y-3">
      <p class="m-0 text-xs font-semibold text-gray-700 dark:text-gray-300" data-i18n="cv.linksLabel">Enlaces</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <label class="space-y-1">
          <span class="text-[11px] text-gray-600 dark:text-gray-400" data-i18n="cv.linkLabel1">LinkedIn</span>
          <input
            type="url"
            data-cv-link-url="0"
            placeholder="https://linkedin.com/in/..."
            class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm text-gray-900 dark:text-gray-100"
          />
        </label>
        <label class="space-y-1">
          <span class="text-[11px] text-gray-600 dark:text-gray-400" data-i18n="cv.linkLabel2">GitHub</span>
          <input
            type="url"
            data-cv-link-url="1"
            placeholder="https://github.com/..."
            class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm text-gray-900 dark:text-gray-100"
          />
        </label>
        <label class="space-y-1">
          <span class="text-[11px] text-gray-600 dark:text-gray-400" data-i18n="cv.linkLabel3">Portfolio</span>
          <input
            type="url"
            data-cv-link-url="2"
            placeholder="https://…"
            class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm text-gray-900 dark:text-gray-100"
          />
        </label>
        <label class="space-y-1">
          <span class="text-[11px] text-gray-600 dark:text-gray-400" data-i18n="cv.linkLabel4">X / Twitter</span>
          <input
            type="url"
            data-cv-link-url="3"
            placeholder="https://x.com/…"
            class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm text-gray-900 dark:text-gray-100"
          />
        </label>
        <label class="space-y-1">
          <span class="text-[11px] text-gray-600 dark:text-gray-400" data-i18n="cv.linkLabel5">Web u otro</span>
          <input
            type="url"
            data-cv-link-url="4"
            placeholder="https://…"
            class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm text-gray-900 dark:text-gray-100"
          />
        </label>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <label class="space-y-1">
          <span class="text-[11px] font-medium text-gray-600 dark:text-gray-400" data-i18n="cv.socialDisplayLabel">Mostrar enlaces como</span>
          <select
            data-cv-social-display
            class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm text-gray-900 dark:text-gray-100"
          >
            <option value="both" data-i18n="cv.socialDisplayBoth">Icono + texto</option>
            <option value="url" data-i18n="cv.socialDisplayUrl">Solo texto (URL visible)</option>
            <option value="icon" data-i18n="cv.socialDisplayIcon">Solo icono (clic / PDF)</option>
          </select>
        </label>
        <label class="space-y-1">
          <span class="text-[11px] font-medium text-gray-600 dark:text-gray-400" data-i18n="cv.templateLabel">Plantilla</span>
          <select
            data-cv-template
            class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm text-gray-900 dark:text-gray-100"
          >
            <option value="classic" data-i18n="cv.templateClassic">Clásica</option>
            <option value="minimal" data-i18n="cv.templateMinimal">Minimal (beta)</option>
            <option value="modern" data-i18n="cv.templateModern">Moderna</option>
            <option value="compact" data-i18n="cv.templateCompact">Compacta</option>
            <option value="mono" data-i18n="cv.templateMono">Mono</option>
            <option value="sidebar" data-i18n="cv.templateSidebar">Sidebar</option>
            <option value="serif" data-i18n="cv.templateSerif">Serif</option>
            <option value="atlas" data-i18n="cv.templateAtlas">Atlas</option>
            <option value="contrast" data-i18n="cv.templateContrast">Contraste</option>
            <option value="focus" data-i18n="cv.templateFocus">Enfoque</option>
          </select>
        </label>
      </div>
      <p class="m-0 text-xs text-gray-500 dark:text-gray-400" data-i18n="cv.profileHint">
        Se guarda en tus preferencias (no es público).
      </p>
    </div>
    <label class="space-y-1">
      <span class="text-xs font-semibold text-gray-700 dark:text-gray-300" data-i18n="cv.summaryLabel">Resumen</span>
      <textarea
        rows={4}
        data-cv-summary
        placeholder="Resumen breve: foco, impacto, tecnologías y tipo de rol que buscas…"
        class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm text-gray-900 dark:text-gray-100"
      ></textarea>
    </label>
    <label class="flex items-start gap-2 cursor-pointer">
      <input type="checkbox" data-cv-show-helpstack class="rounded border-gray-300 dark:border-gray-600 mt-0.5" />
      <span class="text-sm text-gray-800 dark:text-gray-200" data-i18n="cv.showHelpStackLabel">Mostrar stack de ayuda</span>
    </label>
    <label class="space-y-1">
      <span class="text-xs font-semibold text-gray-700 dark:text-gray-300" data-i18n="cv.highlightsLabel">Experiencia / logros</span>
      <textarea
        rows={5}
        data-cv-highlights
        placeholder="- Logro 1 (métrica)\n- Logro 2 (impacto)\n- Logro 3 (stack)"
        class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm text-gray-900 dark:text-gray-100 font-mono/90"
      ></textarea>
      <p class="m-0 text-xs text-gray-500 dark:text-gray-400" data-i18n="cv.highlightsHint">
        Una línea por punto. Se imprimirá como bullets.
      </p>
    </label>
  </div>

  <details class="group rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/40 dark:bg-gray-950/30 p-4 open:shadow-sm">
    <summary class="cursor-pointer list-none flex items-center justify-between gap-3">
      <h2 class="m-0 text-base font-bold text-gray-900 dark:text-gray-100">
        <span data-i18n="cv.projectsSectionTitle">Proyectos en el CV</span>
      </h2>
      <span class="text-xs text-gray-500 dark:text-gray-400 group-open:hidden" data-i18n="cv.foldHintExpand">Pulsa para editar</span>
    </summary>
    <div class="mt-4 space-y-3">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400 max-w-xl" data-i18n="cv.projectsSectionHintCompact">
          Opcional: el portfolio ya muestra tu trabajo. Aquí elige pocos proyectos para el PDF; uno puede ir destacado, el resto en lista compacta.
        </p>
        <div class="flex flex-wrap items-center gap-3 text-xs font-semibold">
          <button
            type="button"
            data-cv-featured-none
            class="text-amber-700 dark:text-amber-300 hover:underline"
            data-i18n="cv.featuredClearBtn"
          >
            Sin destacado
          </button>
          <button
            type="button"
            data-cv-select-featured-only
            class="text-amber-800 dark:text-amber-200 hover:underline font-bold"
            data-i18n="cv.selectFeaturedOnly"
          >
            Solo el destacado
          </button>
          <button type="button" data-cv-select-all class="text-indigo-700 dark:text-indigo-300 hover:underline">
            <span data-i18n="cv.selectAll">Marcar todos</span>
          </button>
          <button type="button" data-cv-select-none class="text-gray-600 dark:text-gray-400 hover:underline">
            <span data-i18n="cv.selectNone">Quitar todos</span>
          </button>
        </div>
      </div>
      <ul data-cv-project-list class="m-0 list-none space-y-1.5 p-0"></ul>
    </div>
  </details>

  <details class="group rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/40 dark:bg-gray-950/30 p-4 open:shadow-sm">
    <summary class="cursor-pointer list-none flex items-center justify-between gap-3">
      <h2 class="m-0 text-base font-bold text-gray-900 dark:text-gray-100" data-i18n="cv.experienceTitle">Experiencia</h2>
      <span class="text-xs text-gray-500 dark:text-gray-400 group-open:hidden" data-i18n="cv.foldHintExpand">Pulsa para editar</span>
    </summary>
    <div class="mt-4 space-y-3">
      <div class="flex justify-end">
        <button type="button" data-cv-exp-add class="text-xs font-semibold text-indigo-700 dark:text-indigo-300 hover:underline shrink-0">
          <span data-i18n="cv.addExperience">Añadir</span>
        </button>
      </div>
      <div data-cv-exp-list class="space-y-3"></div>
    </div>
  </details>

  <details class="group rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/40 dark:bg-gray-950/30 p-4 open:shadow-sm">
    <summary class="cursor-pointer list-none flex items-center justify-between gap-3">
      <h2 class="m-0 text-base font-bold text-gray-900 dark:text-gray-100" data-i18n="cv.educationTitle">Educación</h2>
      <span class="text-xs text-gray-500 dark:text-gray-400 group-open:hidden" data-i18n="cv.foldHintExpand">Pulsa para editar</span>
    </summary>
    <div class="mt-4 space-y-3">
      <div class="flex justify-end">
        <button type="button" data-cv-edu-add class="text-xs font-semibold text-indigo-700 dark:text-indigo-300 hover:underline shrink-0">
          <span data-i18n="cv.addEducation">Añadir</span>
        </button>
      </div>
      <div data-cv-edu-list class="space-y-3"></div>
    </div>
  </details>

  <details class="group rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/40 dark:bg-gray-950/30 p-4 open:shadow-sm">
    <summary class="cursor-pointer list-none flex items-center justify-between gap-3">
      <h2 class="m-0 text-base font-bold text-gray-900 dark:text-gray-100">
        <span data-i18n="cv.certificationsTitle">Certificaciones</span>
      </h2>
      <span class="text-xs text-gray-500 dark:text-gray-400 group-open:hidden" data-i18n="cv.foldHintExpand">Pulsa para editar</span>
    </summary>
    <div class="mt-4 space-y-3">
      <div class="flex justify-end">
        <button type="button" data-cv-cert-add class="text-xs font-semibold text-indigo-700 dark:text-indigo-300 hover:underline">
          <span data-i18n="cv.addCertification">Añadir</span>
        </button>
      </div>
      <div data-cv-cert-list class="space-y-3"></div>
    </div>
  </details>

  <details class="group rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/40 dark:bg-gray-950/30 p-4 open:shadow-sm">
    <summary class="cursor-pointer list-none flex items-center justify-between gap-3">
      <h2 class="m-0 text-base font-bold text-gray-900 dark:text-gray-100">
        <span data-i18n="cv.languagesTitle">Idiomas</span>
      </h2>
      <span class="text-xs text-gray-500 dark:text-gray-400 group-open:hidden" data-i18n="cv.foldHintExpand">Pulsa para editar</span>
    </summary>
    <div class="mt-4 space-y-3">
      <div class="flex justify-end">
        <button type="button" data-cv-lang-add class="text-xs font-semibold text-indigo-700 dark:text-indigo-300 hover:underline">
          <span data-i18n="cv.addLanguage">Añadir</span>
        </button>
      </div>
      <div data-cv-lang-list class="space-y-3"></div>
    </div>
  </details>

  <div data-cv-editor-sentinel class="pointer-events-none h-px w-full shrink-0" aria-hidden="true"></div>
</div>
