---
export interface Props {
  title: string;
}
const { title } = Astro.props;
---

<header class="flex flex-col gap-4 print:hidden">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between lg:gap-6">
    <div class="min-w-0 flex-1 space-y-2">
      <p class="app-kicker m-0 flex flex-wrap items-center gap-x-1.5 gap-y-0.5">
        <span data-i18n="cv.kickerDoc">Documento</span>
        <span data-cv-kicker-badge class="font-semibold text-rose-600 dark:text-rose-400">privado</span>
        <span
          data-cv-kicker-pulse
          class="hidden h-2 w-2 shrink-0 rounded-full bg-emerald-500 shadow-[0_0_10px_rgba(52,211,153,0.85)] motion-safe:animate-pulse"
          aria-hidden="true"
        ></span>
      </p>
      <h1 class="m-0 text-2xl font-semibold tracking-tight">
        <span data-i18n="cv.pageTitle">{title}</span>
      </h1>
      <div class="flex flex-wrap items-end gap-2">
        <label class="flex min-w-[min(100%,14rem)] flex-1 flex-col gap-0.5 sm:min-w-[12rem]">
          <span
            class="text-[10px] font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400"
            data-i18n="cv.docSelectLabel"
          >
            CV activo
          </span>
          <select
            data-cv-doc-select
            class="w-full rounded-lg border border-gray-200 bg-white px-2 py-2 text-sm font-medium text-gray-900 shadow-sm dark:border-gray-700 dark:bg-gray-950 dark:text-gray-100"
          ></select>
        </label>
        <div class="flex flex-wrap items-center gap-1.5 pb-0.5">
          <button
            type="button"
            data-cv-doc-new
            class="inline-flex items-center justify-center rounded-lg border border-gray-200 bg-white px-2.5 py-2 text-xs font-semibold text-gray-800 hover:bg-gray-50 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100 dark:hover:bg-gray-800"
            data-i18n="cv.docNewBtn"
          >
            Nuevo
          </button>
          <button
            type="button"
            data-cv-doc-dup
            class="inline-flex items-center justify-center rounded-lg border border-gray-200 bg-white px-2.5 py-2 text-xs font-semibold text-gray-800 hover:bg-gray-50 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100 dark:hover:bg-gray-800"
            data-i18n="cv.docDupBtn"
          >
            Duplicar
          </button>
          <button
            type="button"
            data-cv-doc-manage
            class="inline-flex items-center justify-center rounded-lg border border-indigo-200/80 bg-indigo-50/90 px-2.5 py-2 text-xs font-semibold text-indigo-900 hover:bg-indigo-100/90 dark:border-indigo-800/60 dark:bg-indigo-950/40 dark:text-indigo-100 dark:hover:bg-indigo-950/70"
            data-i18n="cv.docManageBtn"
          >
            Gestionar
          </button>
        </div>
      </div>
      <button
        type="button"
        data-cv-import-open
        class="inline-flex w-fit items-center justify-center rounded-lg bg-indigo-600 px-3 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 dark:bg-indigo-500 dark:hover:bg-indigo-400"
      >
        <span data-i18n="cv.importOpenModalBtn">Importar desde texto o PDF…</span>
      </button>
      <p class="m-0 max-w-2xl text-sm text-gray-600 dark:text-gray-400" data-i18n="cv.intro">
        Vista previa local de tu CV. Nadie puede ver esta página sin tu sesión.
      </p>
    </div>

    <div class="flex shrink-0 flex-col items-stretch gap-2 sm:items-end lg:min-w-[12rem]">
      <div class="flex flex-wrap gap-2 sm:justify-end">
        <button
          type="button"
          data-cv-preview-open
          class="inline-flex items-center justify-center rounded-lg bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-800 dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-gray-200"
        >
          <span data-i18n="cv.preview">Preview</span>
        </button>
        <button
          type="button"
          data-cv-print
          class="inline-flex items-center justify-center rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-semibold hover:bg-gray-50 dark:border-gray-800 dark:bg-gray-950 dark:hover:bg-gray-900"
        >
          <span data-i18n="cv.printOrPdf">Imprimir / PDF</span>
        </button>
      </div>
      <p class="m-0 max-w-xs text-xs text-gray-500 sm:text-right dark:text-gray-400" data-i18n="cv.printHint">
        Usa “Guardar como PDF” en el diálogo de impresión del navegador.
      </p>
    </div>
  </div>

  <div
    class="flex flex-wrap items-center gap-1.5 border-t border-gray-200/90 pt-3 dark:border-gray-800"
    aria-label="Respaldo y datos"
  >
    <input type="file" accept="application/json,.json" class="sr-only" data-cv-backup-restore-input tabindex="-1" />
    <button
      type="button"
      data-cv-header-json-export
      class="inline-flex items-center justify-center rounded-md border border-emerald-200/90 bg-emerald-50/90 px-2 py-1 text-xs font-medium text-emerald-900 hover:bg-emerald-100 dark:border-emerald-800/80 dark:bg-emerald-950/40 dark:text-emerald-100 dark:hover:bg-emerald-950/70"
    >
      <span data-i18n="cv.exportJsonBtn">Descargar JSON</span>
    </button>
    <button
      type="button"
      data-cv-backup-restore-trigger
      class="inline-flex items-center justify-center rounded-md border border-amber-200/90 bg-amber-50/90 px-2 py-1 text-xs font-medium text-amber-950 hover:bg-amber-100/90 dark:border-amber-800/70 dark:bg-amber-950/40 dark:text-amber-100 dark:hover:bg-amber-950/70"
    >
      <span data-i18n="cv.backupRestoreBtn">Restaurar desde archivo</span>
    </button>
    <button
      type="button"
      data-cv-clear-content
      class="inline-flex items-center justify-center rounded-md border border-rose-200/90 bg-rose-50/90 px-2 py-1 text-xs font-medium text-rose-900 hover:bg-rose-100/90 dark:border-rose-900/50 dark:bg-rose-950/35 dark:text-rose-100 dark:hover:bg-rose-950/55"
    >
      <span data-i18n="cv.clearContentBtn">Vaciar contenido del CV</span>
    </button>
  </div>
</header>
