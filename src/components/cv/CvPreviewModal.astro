---
/** Modal de vista previa del CV. */
---

<div
  data-cv-preview-modal
  class="fixed inset-0 z-1000 hidden items-center justify-center p-4 bg-black/40 backdrop-blur-sm print:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="CV preview"
  data-i18n="cv.previewDialogLabel"
  data-i18n-attr="aria-label"
>
  <div class="w-full max-w-6xl max-h-[90vh] overflow-hidden rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 shadow-xl flex flex-col">
    <div class="px-4 py-3 border-b border-gray-200/80 dark:border-gray-800 flex flex-wrap items-center justify-between gap-3 shrink-0">
      <div class="flex flex-wrap items-center gap-3 min-w-0">
        <p class="m-0 text-sm font-semibold shrink-0" data-i18n="cv.previewTitle">Preview</p>
        <label class="flex items-center gap-2 text-xs text-gray-600 dark:text-gray-400 min-w-0">
          <span class="shrink-0 font-medium" data-i18n="cv.previewTemplateLabel">Plantilla</span>
          <div data-select-popover data-placeholder="Clásica">
            <select data-cv-preview-template class="sr-only" data-select-native>
            <option value="classic" data-i18n="cv.templateClassic">Clásica</option>
            <option value="minimal" data-i18n="cv.templateMinimal">Minimal (beta)</option>
            <option value="modern" data-i18n="cv.templateModern">Moderna</option>
            <option value="compact" data-i18n="cv.templateCompact">Compacta</option>
            <option value="mono" data-i18n="cv.templateMono">Mono</option>
            <option value="sidebar" data-i18n="cv.templateSidebar">Sidebar</option>
            <option value="serif" data-i18n="cv.templateSerif">Serif</option>
            </select>
            <div class="relative">
              <button
                type="button"
                class="max-w-48 inline-flex items-center justify-between gap-2 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 px-2.5 py-1.5 text-xs font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900"
                data-select-trigger
                aria-haspopup="listbox"
                aria-expanded="false"
              >
                <span class="min-w-0 truncate" data-select-trigger-label>Clásica</span>
                <span class="shrink-0 opacity-70" aria-hidden="true">▾</span>
              </button>
              <div
                class="hidden absolute left-0 right-0 top-full z-30 mt-1 overflow-hidden rounded-xl border border-gray-200/80 dark:border-gray-800 bg-white/95 dark:bg-gray-950/95 shadow-lg"
                data-select-panel
              >
                <ul
                  class="max-h-72 overflow-auto m-0 p-0 divide-y divide-gray-200/70 dark:divide-gray-800"
                  data-select-list
                  role="listbox"
                ></ul>
              </div>
            </div>
          </div>
        </label>
      </div>
      <div class="flex flex-wrap items-center justify-end gap-2 shrink-0">
        <button
          type="button"
          data-cv-preview-ats
          class="inline-flex items-center justify-center rounded-lg border border-amber-200/90 dark:border-amber-800/80 bg-amber-50/80 dark:bg-amber-950/40 px-2.5 py-1.5 text-xs font-semibold text-amber-950 dark:text-amber-100 hover:bg-amber-100/90 dark:hover:bg-amber-950/70"
        >
          <span data-i18n="cv.previewAtsBtn">Chequeo ATS</span>
        </button>
        <button
          type="button"
          data-cv-preview-close
          class="inline-flex items-center justify-center rounded-lg border border-gray-200 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 px-2.5 py-1.5 text-sm font-semibold hover:bg-gray-50 dark:hover:bg-gray-900"
        >
          <span data-i18n="common.close">Cerrar</span>
        </button>
      </div>
    </div>
    <div
      data-cv-preview-ats-panel
      class="hidden border-b border-gray-200/80 dark:border-gray-800 bg-amber-50/40 dark:bg-amber-950/20 px-4 py-3 print:hidden"
    >
      <p class="m-0 text-[11px] leading-snug text-gray-700 dark:text-gray-300" data-i18n="cv.ats.disclaimer"></p>
      <div class="mt-3 grid gap-3 md:grid-cols-3">
        <div class="min-w-0">
          <p
            class="m-0 text-[10px] font-bold uppercase tracking-wide text-emerald-700 dark:text-emerald-400"
            data-i18n="cv.ats.columnOk"
          >
            Bien
          </p>
          <ul data-cv-ats-ok class="m-0 mt-1.5 list-none space-y-1 p-0 text-xs text-gray-800 dark:text-gray-200"></ul>
        </div>
        <div class="min-w-0">
          <p
            class="m-0 text-[10px] font-bold uppercase tracking-wide text-amber-800 dark:text-amber-400"
            data-i18n="cv.ats.columnWarn"
          >
            Revisar
          </p>
          <ul data-cv-ats-warn class="m-0 mt-1.5 list-none space-y-1 p-0 text-xs text-gray-800 dark:text-gray-200"></ul>
        </div>
        <div class="min-w-0">
          <p
            class="m-0 text-[10px] font-bold uppercase tracking-wide text-sky-800 dark:text-sky-400"
            data-i18n="cv.ats.columnInfo"
          >
            Notas
          </p>
          <ul data-cv-ats-info class="m-0 mt-1.5 list-none space-y-1 p-0 text-xs text-gray-800 dark:text-gray-200"></ul>
        </div>
      </div>
      <button
        type="button"
        data-cv-preview-ats-hide
        class="mt-3 text-xs font-semibold text-amber-900/90 underline decoration-amber-700/50 hover:decoration-amber-700 dark:text-amber-200"
      >
        <span data-i18n="cv.previewAtsHide">Ocultar</span>
      </button>
    </div>
    <div class="flex min-h-0 flex-1 flex-col md:flex-row">
      <div
        data-cv-preview-body
        class="min-h-0 min-w-0 flex-1 overflow-auto overflow-x-hidden p-4 max-h-[calc(90vh-3.25rem)] md:max-h-[calc(90vh-3.25rem)]"
      ></div>
      <aside
        data-cv-preview-section-rail
        class="shrink-0 border-t border-gray-200/80 dark:border-gray-800 md:border-t-0 md:border-l md:w-52 print:hidden"
      >
        <div class="sticky top-0 p-3 md:max-h-[calc(90vh-3.25rem)] md:overflow-y-auto">
          <p class="m-0 mb-2 text-[11px] font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400" data-i18n="cv.previewSectionOrderTitle">
            Orden de secciones
          </p>
          <ul data-cv-preview-section-list class="m-0 list-none space-y-1.5 p-0"></ul>
        </div>
      </aside>
    </div>
  </div>
</div>
