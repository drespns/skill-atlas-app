---
/** Modal de vista previa del CV. */
---

<div
  data-cv-preview-modal
  class="fixed inset-0 z-1000 hidden items-center justify-center p-4 bg-black/40 backdrop-blur-sm print:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="CV preview"
  data-i18n="cv.previewDialogLabel"
  data-i18n-attr="aria-label"
>
  <div class="w-full max-w-6xl max-h-[90vh] overflow-hidden rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 shadow-xl flex flex-col">
    <div class="px-4 py-3 border-b border-gray-200/80 dark:border-gray-800 flex flex-wrap items-center justify-between gap-3 shrink-0">
      <div class="flex flex-wrap items-center gap-3 min-w-0">
        <p class="m-0 text-sm font-semibold shrink-0" data-i18n="cv.previewTitle">Preview</p>
        <label class="flex items-center gap-2 text-xs text-gray-600 dark:text-gray-400 min-w-0">
          <span class="shrink-0 font-medium" data-i18n="cv.previewTemplateLabel">Plantilla</span>
          <select
            data-cv-preview-template
            class="max-w-48 rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-2 py-1.5 text-xs font-semibold text-gray-900 dark:text-gray-100"
          >
            <option value="classic" data-i18n="cv.templateClassic">Clásica</option>
            <option value="minimal" data-i18n="cv.templateMinimal">Minimal (beta)</option>
            <option value="modern" data-i18n="cv.templateModern">Moderna</option>
            <option value="compact" data-i18n="cv.templateCompact">Compacta</option>
            <option value="mono" data-i18n="cv.templateMono">Mono</option>
            <option value="sidebar" data-i18n="cv.templateSidebar">Sidebar</option>
            <option value="serif" data-i18n="cv.templateSerif">Serif</option>
          </select>
        </label>
      </div>
      <button
        type="button"
        data-cv-preview-close
        class="inline-flex items-center justify-center rounded-lg border border-gray-200 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 px-2.5 py-1.5 text-sm font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 shrink-0"
      >
        <span data-i18n="common.close">Cerrar</span>
      </button>
    </div>
    <div class="flex min-h-0 flex-1 flex-col md:flex-row">
      <div
        data-cv-preview-body
        class="min-h-0 min-w-0 flex-1 overflow-auto overflow-x-hidden p-4 max-h-[calc(90vh-3.25rem)] md:max-h-[calc(90vh-3.25rem)]"
      ></div>
      <aside
        data-cv-preview-section-rail
        class="shrink-0 border-t border-gray-200/80 dark:border-gray-800 md:border-t-0 md:border-l md:w-52 print:hidden"
      >
        <div class="sticky top-0 p-3 md:max-h-[calc(90vh-3.25rem)] md:overflow-y-auto">
          <p class="m-0 mb-2 text-[11px] font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400" data-i18n="cv.previewSectionOrderTitle">
            Orden de secciones
          </p>
          <ul data-cv-preview-section-list class="m-0 list-none space-y-1.5 p-0"></ul>
        </div>
      </aside>
    </div>
  </div>
</div>
