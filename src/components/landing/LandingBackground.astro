---
/** Blobs, puntos y viñeta del hero (full-bleed). */
---
    <div class="pointer-events-none absolute inset-0 isolate min-h-full">
      <div class="absolute inset-0 -z-20 overflow-hidden">
        <div
          class="landing-hero-blob landing-hero-blob--1 absolute -top-40 left-1/2 h-[28rem] w-[min(140vw,90rem)] max-w-none -translate-x-1/2 rounded-[100%] bg-linear-to-r from-indigo-300/38 via-sky-200/28 to-rose-300/32 dark:from-indigo-500/18 dark:via-sky-500/12 dark:to-rose-500/14 blur-3xl"
        />
        <div
          class="landing-hero-blob landing-hero-blob--2 absolute -top-20 -right-[min(18vw,12rem)] h-80 w-[min(90vw,52rem)] rounded-[100%] bg-linear-to-bl from-violet-200/25 via-transparent to-transparent dark:from-violet-500/12 blur-3xl"
        />
        <div
          class="landing-hero-blob landing-hero-blob--3 absolute -bottom-48 -left-[min(12vw,8rem)] h-[26rem] w-[min(95vw,56rem)] rounded-[100%] bg-linear-to-br from-emerald-200/28 via-transparent to-amber-200/22 dark:from-emerald-500/12 dark:to-amber-500/10 blur-3xl"
        />
      </div>
      <div class="landing-dots absolute inset-0 z-0" aria-hidden="true"></div>
      <div
        class="landing-edge-vignette pointer-events-none absolute inset-0 z-[1]"
        aria-hidden="true"
      ></div>
    </div>