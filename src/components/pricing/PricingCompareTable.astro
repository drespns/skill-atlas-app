---
/** Tabla comparativa de planes. */
---

<section class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 overflow-hidden shadow-sm">
  <div class="px-5 py-4 border-b border-gray-100 dark:border-gray-800/80">
    <h2 class="m-0 text-base font-semibold text-gray-900 dark:text-gray-50">
      <span data-i18n="pricing.compareTitle">Comparativa rápida</span>
    </h2>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full min-w-lg text-sm border-collapse">
      <thead>
        <tr class="text-left text-gray-500 dark:text-gray-400 border-b border-gray-100 dark:border-gray-800/80">
          <th class="py-3 px-5 font-medium" data-i18n="pricing.compareFeature">Funcionalidad</th>
          <th class="py-3 px-4 font-medium text-center">Starter</th>
          <th class="py-3 px-4 font-medium text-center text-indigo-700 dark:text-indigo-300">
            <span data-i18n="pricing.comparePro">Pro</span>
          </th>
          <th class="py-3 px-4 font-medium text-center">Team</th>
        </tr>
      </thead>
      <tbody class="text-gray-800 dark:text-gray-200">
        <tr class="border-b border-gray-100 dark:border-gray-800/60">
          <td class="py-3 px-5 text-gray-600 dark:text-gray-400" data-i18n="pricing.compareRowPortfolio">
            Portfolio y perfil público
          </td>
          <td class="py-3 px-4 text-center text-lg">
            <span aria-hidden="true">✅</span>
            <span class="sr-only" data-i18n="pricing.compareYes">Incluido</span>
          </td>
          <td class="py-3 px-4 text-center text-lg text-indigo-700 dark:text-indigo-300">
            <span aria-hidden="true">✅</span>
            <span class="sr-only" data-i18n="pricing.compareYes">Incluido</span>
          </td>
          <td class="py-3 px-4 text-center text-lg">
            <span aria-hidden="true">✅</span>
            <span class="sr-only" data-i18n="pricing.compareYes">Incluido</span>
          </td>
        </tr>
        <tr class="border-b border-gray-100 dark:border-gray-800/60">
          <td class="py-3 px-5 text-gray-600 dark:text-gray-400" data-i18n="pricing.compareRowProjects">
            Proyectos con evidencias
          </td>
          <td class="py-3 px-4 text-center text-lg">
            <span aria-hidden="true">✅</span>
            <span class="sr-only" data-i18n="pricing.compareYes">Incluido</span>
          </td>
          <td class="py-3 px-4 text-center text-lg text-indigo-700 dark:text-indigo-300">
            <span aria-hidden="true">✅</span>
            <span class="sr-only" data-i18n="pricing.compareYes">Incluido</span>
          </td>
          <td class="py-3 px-4 text-center text-lg">
            <span aria-hidden="true">✅</span>
            <span class="sr-only" data-i18n="pricing.compareYes">Incluido</span>
          </td>
        </tr>
        <tr class="border-b border-gray-100 dark:border-gray-800/60">
          <td class="py-3 px-5 text-gray-600 dark:text-gray-400" data-i18n="pricing.compareRowConcepts">
            Conceptos por tecnología
          </td>
          <td class="py-3 px-4 text-center text-lg">
            <span aria-hidden="true">✅</span>
            <span class="sr-only" data-i18n="pricing.compareYes">Incluido</span>
          </td>
          <td class="py-3 px-4 text-center text-lg text-indigo-700 dark:text-indigo-300">
            <span aria-hidden="true">✅</span>
            <span class="sr-only" data-i18n="pricing.compareYes">Incluido</span>
          </td>
          <td class="py-3 px-4 text-center text-lg">
            <span aria-hidden="true">✅</span>
            <span class="sr-only" data-i18n="pricing.compareYes">Incluido</span>
          </td>
        </tr>
        <tr class="border-b border-gray-100 dark:border-gray-800/60">
          <td class="py-3 px-5 text-gray-600 dark:text-gray-400" data-i18n="pricing.compareRowCv">
            CV & exportación
          </td>
          <td class="py-3 px-4 text-center text-lg">
            <span aria-hidden="true">❌</span>
            <span class="sr-only" data-i18n="pricing.compareNo">No incluido</span>
          </td>
          <td class="py-3 px-4 text-center text-lg text-indigo-700 dark:text-indigo-300">
            <span aria-hidden="true">✅</span>
            <span class="sr-only" data-i18n="pricing.compareYes">Incluido</span>
          </td>
          <td class="py-3 px-4 text-center text-lg">
            <span aria-hidden="true">✅</span>
            <span class="sr-only" data-i18n="pricing.compareYes">Incluido</span>
          </td>
        </tr>
        <tr>
          <td class="py-3 px-5 text-gray-600 dark:text-gray-400" data-i18n="pricing.compareRowShareToken">
            Enlace público de portfolio (token)
          </td>
          <td class="py-3 px-4 text-center text-lg">
            <span aria-hidden="true">❌</span>
            <span class="sr-only" data-i18n="pricing.compareNo">No incluido</span>
          </td>
          <td class="py-3 px-4 text-center text-lg text-indigo-700 dark:text-indigo-300">
            <span aria-hidden="true">✅</span>
            <span class="sr-only" data-i18n="pricing.compareYes">Incluido</span>
          </td>
          <td class="py-3 px-4 text-center text-lg">
            <span aria-hidden="true">✅</span>
            <span class="sr-only" data-i18n="pricing.compareYes">Incluido</span>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</section>
