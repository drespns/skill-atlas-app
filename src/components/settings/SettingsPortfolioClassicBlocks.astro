---
/**
 * Bloques de portfolio/CV/QA en /settings (misma semántica data-* que los scripts de perfil).
 */
---

<section
  id="portfolio-links"
  data-settings-section="portfolio_links"
  data-settings-panel
  hidden
  class="settings-classic-panel hidden max-w-3xl pb-10"
>
  <div class="space-y-4 max-w-3xl">
    <div class="space-y-1 border-b border-gray-200/90 dark:border-[#30363d] pb-5">
      <h1 class="m-0 text-3xl font-normal tracking-tight text-gray-900 dark:text-gray-100">
        <span data-i18n="settings.portfolio.linksCardTitle">Enlaces públicos</span>
      </h1>
      <p class="m-0 text-sm text-gray-600 dark:text-gray-400">
        <span data-i18n="settings.portfolio.publicUrlHint">
          Publica tu portfolio en una dirección fácil de compartir. Requiere Supabase con la migración saas-011.
        </span>
      </p>
    </div>
    <label class="flex items-start gap-2 cursor-pointer">
      <input
        type="checkbox"
        data-profile-share-enabled
        class="rounded border-gray-300 dark:border-gray-600 shrink-0 mt-0.5"
      />
      <span class="text-sm text-gray-900 dark:text-gray-100" data-i18n="settings.portfolio.shareEnabledLabel">
        Hacer visible mi portfolio públicamente
      </span>
    </label>
    <p class="m-0 text-xs text-gray-500 dark:text-gray-400 leading-relaxed" data-i18n="settings.portfolio.applyPublicLinksHint">
      La casilla y el identificador no se guardan solos: pulsa Aplicar para publicar o dejar de publicar.
    </p>
    <div class="space-y-2" data-profile-slug-fields>
      <span class="text-sm font-semibold" data-i18n="settings.portfolio.publicSlugLabel">Identificador en la URL</span>
      <div class="flex flex-col sm:flex-row sm:items-center gap-2 min-w-0">
        <span class="text-sm text-gray-500 dark:text-gray-400 shrink-0 font-mono" data-profile-url-prefix>/portfolio/</span>
        <input
          type="text"
          data-profile-public-slug
          inputmode="text"
          autocomplete="off"
          spellcheck="false"
          maxlength="32"
          placeholder="tu-nombre"
          class="flex-1 min-w-0 rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#0d1117] px-3 py-2 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500/40 settings-classic-input"
        />
      </div>
      <p class="m-0 text-xs text-gray-500 dark:text-gray-400 break-all" data-profile-public-url-preview></p>
      <div class="flex flex-wrap items-center gap-2">
        <button
          type="button"
          data-profile-copy-public-url
          class="inline-flex items-center justify-center rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#21262d] px-3 py-2 text-sm font-medium hover:bg-gray-50 dark:hover:bg-[#30363d] transition-colors"
          title="Copiar"
        >
          <span class="sr-only" data-i18n="settings.portfolio.copyPublicUrl">Copiar enlace</span>
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
        </button>
        <button
          type="button"
          data-profile-apply-public-links
          class="inline-flex items-center justify-center rounded-md border border-transparent bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500 dark:bg-indigo-500 dark:hover:bg-indigo-400 transition-colors"
        >
          <span data-i18n="settings.portfolio.applyPublicLinks">Aplicar visibilidad y slug</span>
        </button>
      </div>
    </div>
    <div data-portfolio-token-share class="space-y-3 pt-4 border-t border-gray-200/80 dark:border-[#30363d] hidden">
      <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">
        <span data-i18n="settings.portfolio.tokenKicker">Enlace por token</span>
      </h3>
      <p class="m-0 text-sm text-gray-600 dark:text-gray-400">
        <span data-i18n="settings.portfolio.tokenHint">
          Enlace revocable (más privado que el slug). Requiere tener marcada la visibilidad pública.
        </span>
      </p>
      <div class="flex flex-col sm:flex-row gap-2 sm:items-center">
        <input
          type="text"
          readonly
          data-portfolio-token-url
          class="w-full rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#0d1117] px-3 py-2 text-sm settings-classic-input"
        />
        <div class="flex gap-2">
          <button
            type="button"
            data-portfolio-token-copy
            class="inline-flex items-center justify-center rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#21262d] px-3 py-2 text-sm font-medium hover:bg-gray-50 dark:hover:bg-[#30363d]"
            title="Copiar"
          >
            <span class="sr-only" data-i18n="settings.portfolio.copyPublicUrl">Copiar enlace</span>
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="9" y="9" width="13" height="13" rx="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
          </button>
          <button
            type="button"
            data-portfolio-token-rotate
            class="inline-flex items-center justify-center rounded-md px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-400 hover:underline"
          >
            <span data-i18n="settings.portfolio.tokenRotate">Regenerar</span>
          </button>
        </div>
      </div>
      <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="settings.portfolio.tokenWarn">
        Al regenerar, el enlace anterior deja de funcionar.
      </p>
    </div>
  </div>
</section>

<section
  id="portfolio-display"
  data-settings-section="portfolio_display"
  data-settings-panel
  hidden
  class="settings-classic-panel hidden max-w-3xl pb-10"
>
  <div class="space-y-4 max-w-3xl">
    <div class="space-y-1 border-b border-gray-200/90 dark:border-[#30363d] pb-5">
      <h1 class="m-0 text-3xl font-normal tracking-tight text-gray-900 dark:text-gray-100">
        <span data-i18n="settings.portfolio.publicDisplayKicker">Vista pública del portfolio</span>
      </h1>
      <p class="m-0 text-sm text-gray-600 dark:text-gray-400">
        <span data-i18n="settings.portfolio.publicDisplayHint">
          Define la vista por defecto, cuántas evidencias ver por proyecto y un botón opcional bajo tu bio.
        </span>
      </p>
      <p class="m-0 text-xs text-gray-500 dark:text-gray-400" data-i18n="settings.portfolio.publicDisplayMigrationShort">
        Layout, evidencias y CTA del hero: migración saas-013 en Supabase.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="space-y-1">
        <label class="text-sm font-semibold" data-i18n="portfolio.public.viewLabel">Vista por defecto</label>
        <select
          data-profile-public-layout
          class="w-full min-h-10 rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#0d1117] px-3 py-2 text-sm settings-classic-input"
        >
          <option value="grid" data-i18n="portfolio.public.viewGrid">Cuadrícula</option>
          <option value="list" data-i18n="portfolio.public.viewList">Lista</option>
        </select>
      </div>
      <div class="space-y-1">
        <label class="text-sm font-semibold" data-i18n="portfolio.public.embedCapLabel">Evidencias por proyecto</label>
        <select
          data-profile-public-embeds-limit
          class="w-full min-h-10 rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#0d1117] px-3 py-2 text-sm settings-classic-input"
        >
          <option value="1">1</option>
          <option value="2">2</option>
          <option value="3">3</option>
          <option value="4">4</option>
          <option value="5">5</option>
        </select>
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="space-y-1">
        <label class="text-sm font-semibold" data-i18n="settings.portfolio.heroCtaLabel">Texto del botón (opcional)</label>
        <input
          type="text"
          data-profile-hero-cta-label
          maxlength="80"
          autocomplete="off"
          class="w-full min-h-10 rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#0d1117] px-3 py-2 text-sm settings-classic-input"
        />
      </div>
      <div class="space-y-1">
        <label class="text-sm font-semibold" data-i18n="settings.portfolio.heroCtaUrl">URL del botón (https)</label>
        <input
          type="url"
          data-profile-hero-cta-url
          inputmode="url"
          autocomplete="off"
          placeholder="https://…"
          class="w-full min-h-10 rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#0d1117] px-3 py-2 text-sm settings-classic-input"
        />
      </div>
    </div>
  </div>
</section>

<section
  id="portfolio-presentation"
  data-settings-section="portfolio_presentation"
  data-settings-panel
  hidden
  class="settings-classic-panel hidden max-w-3xl pb-10"
>
  <div class="space-y-4 max-w-3xl">
    <div class="space-y-1 border-b border-gray-200/90 dark:border-[#30363d] pb-5">
      <h1 class="m-0 text-3xl font-normal tracking-tight text-gray-900 dark:text-gray-100">
        <span data-i18n="settings.portfolio.presentationKicker">Presentación (look del portfolio público)</span>
      </h1>
      <p class="m-0 text-sm text-gray-600 dark:text-gray-400">
        <span data-i18n="settings.portfolio.presentationHint">
          Afecta a quien visita tu portfolio y a la vista previa en /portfolio. Los ajustes generales de la app están en otras secciones de Ajustes.
        </span>
      </p>
      <p class="m-0 text-xs text-gray-500 dark:text-gray-400" data-i18n="settings.portfolio.presentationMigration">
        Tema, acento y destacados: migración saas-014 en Supabase.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="space-y-1">
        <label class="text-sm font-semibold" data-i18n="settings.portfolio.themeLabel">Tema visual</label>
        <select
          data-profile-public-theme
          class="w-full min-h-10 rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#0d1117] px-3 py-2 text-sm settings-classic-input"
        >
          <option value="classic" data-i18n="settings.portfolio.themeClassic">Clásico</option>
          <option value="minimal" data-i18n="settings.portfolio.themeMinimal">Minimal</option>
          <option value="contrast" data-i18n="settings.portfolio.themeContrast">Alto contraste</option>
          <option value="reader" data-i18n="settings.portfolio.themeReader">Lectura</option>
        </select>
      </div>
      <div class="space-y-1">
        <label class="text-sm font-semibold" data-i18n="settings.portfolio.densityLabel">Densidad de tarjetas</label>
        <select
          data-profile-public-density
          class="w-full min-h-10 rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#0d1117] px-3 py-2 text-sm settings-classic-input"
        >
          <option value="comfortable" data-i18n="settings.portfolio.densityComfortable">Cómoda</option>
          <option value="compact" data-i18n="settings.portfolio.densityCompact">Compacta</option>
        </select>
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 items-end">
      <div class="space-y-1">
        <label class="text-sm font-semibold" data-i18n="settings.portfolio.accentLabel">Color de acento (opcional)</label>
        <div class="flex flex-wrap items-center gap-2">
          <input
            type="color"
            data-profile-accent-color
            class="h-10 w-14 cursor-pointer rounded border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#0d1117] p-0.5"
            aria-label="Color"
          />
          <input
            type="text"
            data-profile-accent-hex
            inputmode="text"
            maxlength="7"
            placeholder="RRGGBB"
            autocomplete="off"
            class="min-w-[6.5rem] flex-1 min-h-10 rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#0d1117] px-3 py-2 text-sm font-mono settings-classic-input"
          />
          <button
            type="button"
            data-profile-accent-clear
            class="shrink-0 rounded-md border border-gray-200 dark:border-[#30363d] px-2 py-2 text-xs font-semibold text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-[#30363d]"
          >
            <span data-i18n="settings.portfolio.accentClear">Quitar</span>
          </button>
        </div>
      </div>
      <div class="space-y-1">
        <label class="text-sm font-semibold" data-i18n="settings.portfolio.headerStyleLabel">Estilo del botón principal</label>
        <select
          data-profile-header-style
          class="w-full min-h-10 rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#0d1117] px-3 py-2 text-sm settings-classic-input"
        >
          <option value="default" data-i18n="settings.portfolio.headerStyleDefault">Normal</option>
          <option value="cta_prominent" data-i18n="settings.portfolio.headerStyleProminent">Destacado</option>
        </select>
      </div>
    </div>
    <div class="space-y-1">
      <label class="text-sm font-semibold" data-i18n="settings.portfolio.featuredLabel">Proyectos destacados (orden)</label>
      <textarea
        data-profile-featured-slugs
        rows={4}
        spellcheck="false"
        class="w-full rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#0d1117] px-3 py-2 text-sm font-mono settings-classic-input"
        placeholder="slug-proyecto-uno&#10;otro-slug"
      ></textarea>
      <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400" data-profile-featured-slugs-hint></p>
    </div>
  </div>
</section>

<section
  id="cv-public"
  data-settings-section="cv_public"
  data-settings-panel
  hidden
  class="settings-classic-panel hidden max-w-3xl pb-10"
>
  <div class="space-y-4 max-w-3xl">
    <h1 class="m-0 text-3xl font-normal tracking-tight text-gray-900 dark:text-gray-100 border-b border-gray-200/90 dark:border-[#30363d] pb-5">
      <span data-i18n="cv.publicShareTitle">CV público</span>
    </h1>
    <p class="m-0 text-sm text-gray-600 dark:text-gray-400">
      <span data-i18n="cv.publicShareSettingsHint">
        Este enlace se gestiona desde Ajustes y es revocable (puedes regenerarlo).
      </span>
    </p>
    <div data-cv-share class="space-y-3 hidden">
      <label class="flex items-start gap-2 cursor-pointer">
        <input type="checkbox" data-cv-share-enabled class="rounded border-gray-300 dark:border-gray-600 shrink-0 mt-0.5" />
        <span class="text-sm text-gray-900 dark:text-gray-100" data-i18n="cv.publicShareEnable">Activar</span>
      </label>
      <div class="flex flex-col sm:flex-row gap-2 sm:items-center">
        <input
          type="text"
          readonly
          data-cv-share-url
          class="w-full rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#0d1117] px-3 py-2 text-sm settings-classic-input"
        />
        <div class="flex gap-2">
          <button
            type="button"
            data-cv-share-copy
            class="inline-flex items-center justify-center rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#21262d] px-3 py-2 text-sm font-medium"
            title="Copiar"
          >
            <span class="sr-only" data-i18n="settings.portfolio.copyPublicUrl">Copiar enlace</span>
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="9" y="9" width="13" height="13" rx="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
          </button>
          <button
            type="button"
            data-cv-share-rotate
            class="inline-flex items-center justify-center rounded-md px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-400 hover:underline"
          >
            <span data-i18n="cv.publicShareRotate">Regenerar</span>
          </button>
        </div>
      </div>
      <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="cv.publicShareWarn">
        Al regenerar, el enlace anterior deja de funcionar.
      </p>
    </div>
  </div>
</section>

<section
  id="qa"
  data-settings-section="qa"
  data-settings-panel
  hidden
  class="settings-classic-panel hidden max-w-3xl pb-16"
>
  <div class="space-y-4 max-w-3xl">
    <h1 class="m-0 text-3xl font-normal tracking-tight text-gray-900 dark:text-gray-100 border-b border-gray-200/90 dark:border-[#30363d] pb-5">
      <span data-i18n="settings.qa.kicker">Onboarding / QA</span>
    </h1>
    <p class="m-0 text-sm text-gray-600 dark:text-gray-400">
      <span data-i18n="settings.qa.hint">Herramientas para probar, sembrar datos y reportar errores.</span>
    </p>
    <label class="flex items-start gap-2 cursor-pointer">
      <input type="checkbox" data-qa-tester-mode class="rounded border-gray-300 dark:border-gray-600 shrink-0 mt-0.5" />
      <span class="text-sm text-gray-900 dark:text-gray-100" data-i18n="settings.qa.enable">Activar modo tester</span>
    </label>
    <div data-qa-panel class="hidden space-y-3 rounded-lg border border-gray-200/80 dark:border-[#30363d] bg-white/60 dark:bg-[#161b22] p-4">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <p class="m-0 text-xs font-semibold text-gray-700 dark:text-gray-300" data-i18n="settings.qa.checklistTitle">
          Checklist rápida
        </p>
        <button
          type="button"
          data-qa-copy-checklist
          class="inline-flex items-center justify-center rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#21262d] px-2.5 py-1.5 text-xs font-semibold"
        >
          <span data-i18n="settings.qa.copyChecklist">Copiar checklist</span>
        </button>
      </div>
      <div data-qa-checklist class="space-y-2"></div>
      <div class="flex flex-wrap gap-2 pt-2 border-t border-gray-200 dark:border-[#30363d]">
        <button
          type="button"
          data-qa-seed
          class="inline-flex items-center justify-center rounded-md bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 px-3 py-2 text-sm font-semibold hover:opacity-90"
        >
          <span data-i18n="settings.qa.seedBtn">Crear datos de prueba</span>
        </button>
        <button
          type="button"
          data-qa-copy-debug
          class="inline-flex items-center justify-center rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#21262d] px-3 py-2 text-sm font-semibold"
        >
          <span data-i18n="settings.qa.copyDebug">Copiar debug info</span>
        </button>
        <p class="m-0 text-xs text-gray-500 dark:text-gray-400 min-h-4" data-qa-feedback></p>
      </div>
    </div>
  </div>
</section>
