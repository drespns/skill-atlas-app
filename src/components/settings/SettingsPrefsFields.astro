---
/** Campos de preferencias (compartidos: vista tablero y vista clásica). */
import { FONT_CATALOG, fontDisplayLabel, fontOptionStyle } from "@config/font-catalog";
import SelectPopover from "../ui/SelectPopover.astro";

type FontCategory = (typeof FONT_CATALOG)[number]["category"];
const byCategory: Record<FontCategory, typeof FONT_CATALOG> = {
  builtin: [],
  sans: [],
  serif: [],
  mono: [],
  display: [],
};
for (const e of FONT_CATALOG) {
  byCategory[e.category].push(e);
}

/** Banderas en `public/icons/flags` (decorativas mientras la UI es solo ES). */
const FLAG_FILES = [
  "Spain",
  "Mexico",
  "Argentina",
  "Chile",
  "Ecuador",
  "United_Kingdom",
  "United_States",
  "France",
  "Germany",
  "Italy",
  "Portugal",
  "Brazil",
] as const;
---

<div class="space-y-8">
  <fieldset class="space-y-4 rounded-xl border border-gray-200/90 dark:border-[#30363d] bg-white/40 dark:bg-[#0d1117]/40 p-4 sm:p-5">
    <legend class="text-sm font-semibold text-gray-900 dark:text-gray-100 px-1">
      <span data-i18n="settings.prefs.sectionAppearance">Apariencia</span>
    </legend>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div class="space-y-1 sm:col-span-2">
        <span class="text-sm font-semibold" data-i18n="settings.prefs.font">Fuente</span>
        <SelectPopover data-pref-font>
          <optgroup
            label="Built-in"
            data-i18n="settings.prefs.fontGroupBuiltin"
            data-i18n-attr="label"
          >
            {byCategory.builtin.map((e) => (
              <option value={e.id} style={fontOptionStyle(e)}>
                {fontDisplayLabel(e)}
              </option>
            ))}
          </optgroup>
          <optgroup label="Sans" data-i18n="settings.prefs.fontGroupSans" data-i18n-attr="label">
            {byCategory.sans.map((e) => (
              <option value={e.id} style={fontOptionStyle(e)}>
                {fontDisplayLabel(e)}
              </option>
            ))}
          </optgroup>
          <optgroup label="Serif" data-i18n="settings.prefs.fontGroupSerif" data-i18n-attr="label">
            {byCategory.serif.map((e) => (
              <option value={e.id} style={fontOptionStyle(e)}>
                {fontDisplayLabel(e)}
              </option>
            ))}
          </optgroup>
          <optgroup label="Mono" data-i18n="settings.prefs.fontGroupMono" data-i18n-attr="label">
            {byCategory.mono.map((e) => (
              <option value={e.id} style={fontOptionStyle(e)}>
                {fontDisplayLabel(e)}
              </option>
            ))}
          </optgroup>
          <optgroup label="Display" data-i18n="settings.prefs.fontGroupDisplay" data-i18n-attr="label">
            {byCategory.display.map((e) => (
              <option value={e.id} style={fontOptionStyle(e)}>
                {fontDisplayLabel(e)}
              </option>
            ))}
          </optgroup>
        </SelectPopover>
        <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="settings.prefs.fontGoogleHint">
          Las fuentes de estos grupos se cargan desde Google Fonts al seleccionarlas.
        </p>
      </div>

      <label class="space-y-1">
        <span class="text-sm font-semibold" data-i18n="settings.prefs.uiFontScale">Tamaño del texto</span>
        <SelectPopover data-pref-ui-font-scale>
          <option value="sm" data-i18n="settings.prefs.uiFontScaleSm">Pequeño</option>
          <option value="md" data-i18n="settings.prefs.uiFontScaleMd">Mediano</option>
          <option value="lg" data-i18n="settings.prefs.uiFontScaleLg">Grande</option>
        </SelectPopover>
        <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="settings.prefs.uiFontScaleHint">
          Afecta a la interfaz en general; si algo se ve cortado, usa Mediano.
        </p>
      </label>

      <label class="space-y-1">
        <span class="text-sm font-semibold" data-i18n="settings.prefs.accent">Color de resalte</span>
        <SelectPopover data-pref-accent>
          <option value="indigo" data-i18n="settings.prefs.accentIndigo">Índigo</option>
          <option value="emerald" data-i18n="settings.prefs.accentEmerald">Esmeralda</option>
          <option value="rose" data-i18n="settings.prefs.accentRose">Rosa</option>
          <option value="amber" data-i18n="settings.prefs.accentAmber">Ámbar</option>
          <option value="sky" data-i18n="settings.prefs.accentSky">Cielo</option>
          <option value="violet" data-i18n="settings.prefs.accentViolet">Violeta</option>
        </SelectPopover>
        <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="settings.prefs.accentHint">
          Enlaces, foco y acentos de la interfaz.
        </p>
      </label>

      <label class="space-y-1 sm:col-span-2">
        <span class="text-sm font-semibold" data-i18n="settings.prefs.motion">Animaciones</span>
        <SelectPopover data-pref-motion>
          <option value="normal" data-i18n="settings.prefs.motionNormal">Normales</option>
          <option value="reduced" data-i18n="settings.prefs.motionReduced">Reducidas</option>
        </SelectPopover>
        <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="settings.prefs.motionHint">
          “Reducidas” respeta mejor el ahorro de movimiento del sistema.
        </p>
      </label>
    </div>
  </fieldset>

  <fieldset class="space-y-4 rounded-xl border border-gray-200/90 dark:border-[#30363d] bg-white/40 dark:bg-[#0d1117]/40 p-4 sm:p-5">
    <legend class="text-sm font-semibold text-gray-900 dark:text-gray-100 px-1">Herramientas</legend>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <label class="space-y-1">
        <span class="text-sm font-semibold">Hábitos: marcado</span>
        <SelectPopover data-pref-habits-mark-style>
          <option value="paint">Pintar (animación)</option>
          <option value="fill">Relleno (simple)</option>
          <option value="check">Check (✓)</option>
        </SelectPopover>
        <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400">
          Usa el color de resalte como base. “Pintar” anima solo al marcar.
        </p>
      </label>
    </div>
  </fieldset>

  <fieldset class="space-y-4 rounded-xl border border-gray-200/90 dark:border-[#30363d] bg-white/40 dark:bg-[#0d1117]/40 p-4 sm:p-5">
    <legend class="text-sm font-semibold text-gray-900 dark:text-gray-100 px-1">Burbujas</legend>
    <p class="m-0 text-sm text-gray-600 dark:text-gray-400">
      Decide qué pestañas aparecen en el panel flotante de ayuda. La IA está desactivada por defecto.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <label class="flex items-start gap-3 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-3 py-2.5">
        <input type="checkbox" class="mt-1" data-pref-fab-shortcuts />
        <span class="min-w-0">
          <span class="block text-sm font-semibold">Atajos</span>
          <span class="block text-xs text-gray-500 dark:text-gray-400">Paleta, navegación</span>
        </span>
      </label>
      <label class="flex items-start gap-3 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-3 py-2.5">
        <input type="checkbox" class="mt-1" data-pref-fab-calendar />
        <span class="min-w-0">
          <span class="block text-sm font-semibold">Calendario</span>
          <span class="block text-xs text-gray-500 dark:text-gray-400">Notas por fecha</span>
        </span>
      </label>
      <label class="flex items-start gap-3 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-3 py-2.5">
        <input type="checkbox" class="mt-1" data-pref-fab-curiosities />
        <span class="min-w-0">
          <span class="block text-sm font-semibold">Curiosidades</span>
          <span class="block text-xs text-gray-500 dark:text-gray-400">Links e ideas</span>
        </span>
      </label>
      <label class="flex items-start gap-3 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-3 py-2.5">
        <input type="checkbox" class="mt-1" data-pref-fab-ai />
        <span class="min-w-0">
          <span class="block text-sm font-semibold">IA</span>
          <span class="block text-xs text-gray-500 dark:text-gray-400">Experimental</span>
        </span>
      </label>
    </div>
  </fieldset>

  <fieldset class="space-y-4 rounded-xl border border-gray-200/90 dark:border-[#30363d] bg-white/40 dark:bg-[#0d1117]/40 p-4 sm:p-5">
    <legend class="text-sm font-semibold text-gray-900 dark:text-gray-100 px-1">
      <span data-i18n="settings.prefs.sectionViews">Vistas de listas</span>
    </legend>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <label class="space-y-1">
        <span class="text-sm font-semibold" data-i18n="settings.prefs.technologiesView">Tecnologías</span>
        <SelectPopover data-pref-technologies-view>
          <option value="cards" data-i18n="settings.prefs.viewCards">Cuadrícula (tarjetas)</option>
          <option value="list" data-i18n="settings.prefs.viewList">Lista</option>
        </SelectPopover>
      </label>

      <label class="space-y-1">
        <span class="text-sm font-semibold" data-i18n="settings.prefs.projectsView">Proyectos</span>
        <SelectPopover data-pref-projects-view>
          <option value="cards" data-i18n="settings.prefs.viewCards">Cuadrícula (tarjetas)</option>
          <option value="list" data-i18n="settings.prefs.viewList">Lista</option>
        </SelectPopover>
      </label>
    </div>
  </fieldset>

  <fieldset class="space-y-4 rounded-xl border border-gray-200/90 dark:border-[#30363d] bg-white/40 dark:bg-[#0d1117]/40 p-4 sm:p-5">
    <legend class="text-sm font-semibold text-gray-900 dark:text-gray-100 px-1">
      <span data-i18n="settings.prefs.sectionHeader">Cabecera</span>
    </legend>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <label class="space-y-1">
        <span class="text-sm font-semibold" data-i18n="settings.prefs.showHeaderIcons">Iconos de accesos rápidos</span>
        <SelectPopover data-pref-show-header-icons>
          <option value="yes" data-i18n="settings.prefs.show">Mostrar</option>
          <option value="no" data-i18n="settings.prefs.hide">Ocultar</option>
        </SelectPopover>
        <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="settings.prefs.showHeaderIconsHint">
          Enlaces a CV, tecnologías, proyectos y portfolio en la barra superior.
        </p>
      </label>

      <label class="space-y-1">
        <span class="text-sm font-semibold" data-i18n="settings.prefs.showLangSelector">Indicador de idioma en la barra</span>
        <SelectPopover data-pref-show-lang-selector>
          <option value="yes" data-i18n="settings.prefs.show">Mostrar</option>
          <option value="no" data-i18n="settings.prefs.hide">Ocultar</option>
        </SelectPopover>
        <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="settings.prefs.showLangSelectorHint">
          Muestra la bandera de región (la interfaz sigue en español).
        </p>
      </label>

      <label class="space-y-1">
        <span class="text-sm font-semibold" data-i18n="settings.prefs.headerLangPopoverOpen">Selector de idioma (barra)</span>
        <SelectPopover data-pref-header-lang-popover>
          <option value="hover" data-i18n="settings.prefs.popoverHover">Al pasar el cursor</option>
          <option value="click" data-i18n="settings.prefs.popoverClick">Al hacer clic</option>
        </SelectPopover>
        <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="settings.prefs.headerLangPopoverHint">
          Cómo abrir el menú de idiomas.
        </p>
      </label>

      <label class="space-y-1">
        <span class="text-sm font-semibold" data-i18n="settings.prefs.headerUserMenuPopoverOpen">Menú de cuenta (avatar)</span>
        <SelectPopover data-pref-header-user-menu-popover>
          <option value="hover" data-i18n="settings.prefs.popoverHover">Al pasar el cursor</option>
          <option value="click" data-i18n="settings.prefs.popoverClick">Al hacer clic</option>
        </SelectPopover>
        <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="settings.prefs.headerUserMenuPopoverHint">
          Cómo abrir el menú de usuario.
        </p>
      </label>

      <!-- Pref menú logo (hover|clic): desactivado; el logo usa solo hover (ver auth-header-bootstrap comentario). -->
    </div>
  </fieldset>

  <fieldset class="space-y-3 rounded-xl border border-gray-200/90 dark:border-[#30363d] bg-white/40 dark:bg-[#0d1117]/40 p-4 sm:p-5">
    <legend class="text-sm font-semibold text-gray-900 dark:text-gray-100 px-1">
      <span data-i18n="settings.prefs.sectionLanguage">Idioma</span>
    </legend>
    <p class="m-0 text-sm text-gray-600 dark:text-gray-400" data-i18n="settings.prefs.languageEsOnlyNote">
      Español e inglés disponibles; más idiomas, próximamente.
    </p>
    <div class="space-y-2">
      <div class="rounded-xl border border-gray-200/80 dark:border-gray-800 bg-white/60 dark:bg-gray-950/50 p-2">
        <p class="m-0 px-1 pb-1 text-[11px] font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">
          Igual que en la cabecera
        </p>
        <div class="max-h-[min(50vh,20rem)] overflow-y-auto space-y-1">
          {
            FLAG_FILES.map((file) => (
              <button
                type="button"
                data-lang-picker-option={
                  file === "Spain"
                    ? "es"
                    : file === "Mexico"
                      ? "es_mx"
                      : file === "Argentina"
                        ? "es_ar"
                        : file === "Chile"
                          ? "es_cl"
                          : file === "Ecuador"
                            ? "es_ec"
                            : file === "United_States"
                              ? "en_us"
                              : file === "United_Kingdom"
                                ? "en"
                                : ""
                }
                class="flex w-full items-center justify-between gap-3 rounded-lg px-2 py-2 text-left text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors app-accent-ring disabled:pointer-events-none"
              >
                <span class="flex min-w-0 items-center gap-2.5">
                  <img
                    src={`/icons/flags/${file}.svg`}
                    alt=""
                    class="h-6 w-6 shrink-0 rounded-sm"
                    width="24"
                    height="24"
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="truncate">
                    {file === "Spain"
                      ? "Español (España)"
                      : file === "Mexico"
                        ? "Español (México)"
                        : file === "Argentina"
                          ? "Español (Argentina)"
                          : file === "Chile"
                            ? "Español (Chile)"
                            : file === "Ecuador"
                              ? "Español (Ecuador)"
                              : file === "United_States"
                                ? "English (US)"
                                : file === "United_Kingdom"
                                  ? "English"
                                  : file}
                  </span>
                </span>
                <span class="shrink-0 text-xs font-mono text-gray-500 dark:text-gray-400">{file}</span>
              </button>
            ))
          }
        </div>
      </div>
      <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400">
        Nota: las variantes de español se deshabilitan automáticamente salvo la inferida para tu dispositivo (igual que en el header).
      </p>
    </div>
  </fieldset>
</div>
