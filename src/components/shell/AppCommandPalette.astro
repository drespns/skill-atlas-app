---
/** Modal de command palette; lógica en `shell/command-palette.ts` + trigger en `client-shell/command-palette-trigger.ts`. */
---

<div
  data-command-palette
  class="hidden fixed inset-0 items-start justify-center p-4 sm:p-6 bg-black/55 backdrop-blur-sm"
  style="z-index: 2000;"
  aria-hidden="true"
>
  <div
    class="pointer-events-none absolute inset-0 opacity-70"
    aria-hidden="true"
    style="
      background:
        radial-gradient(900px 420px at 50% 0%, rgba(99, 102, 241, 0.18), transparent 60%),
        radial-gradient(700px 360px at 15% 10%, rgba(139, 92, 246, 0.12), transparent 58%),
        radial-gradient(760px 420px at 85% 20%, rgba(56, 189, 248, 0.08), transparent 60%);
    "
  ></div>
  <div
    data-command-palette-dialog
    class="relative w-full max-w-xl rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/85 dark:bg-gray-950/80 backdrop-blur-xl shadow-xl overflow-hidden ring-1 ring-black/5 dark:ring-white/10"
  >
    <div class="flex items-center gap-2 p-3 border-b border-gray-100 dark:border-gray-800">
      <input
        data-command-palette-input
        class="w-full rounded-xl border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-3 py-2 text-sm app-accent-ring"
        placeholder="Buscar…"
        data-i18n="common.commandPalettePlaceholder"
        data-i18n-attr="placeholder"
      />
      <button
        type="button"
        data-command-palette-close
        class="btn-secondary text-sm"
        data-i18n="common.close"
      >
        Cerrar
      </button>
    </div>
    <div data-command-palette-list class="p-2 max-h-[60vh] overflow-auto"></div>
  </div>
</div>
