---
const fabKbd =
  "inline-flex items-center rounded border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 px-1.5 py-0.5 text-[11px] font-mono font-semibold text-gray-800 dark:text-gray-200 shadow-sm";
---

<!-- Burbujas flotantes: atajos, calendario, curiosidades e IA (opcional). Script: fab-bubbles.ts -->
<div
  data-fab-root
  class="hidden print:hidden fixed inset-x-0 bottom-0 z-[1900] pointer-events-none flex flex-col items-end gap-0 px-4 pb-4 pt-20 md:px-6 md:pb-6"
  aria-live="polite"
>
  <div
    data-fab-backdrop
    class="pointer-events-none fixed inset-0 z-[1880] bg-black/45 opacity-0 transition-opacity duration-200 motion-reduce:transition-none"
    aria-hidden="true"
  >
  </div>

  <div
    id="fab-help-panel"
    data-fab-panel
    class="pointer-events-none relative z-[1890] mb-3 w-full max-w-[min(36rem,calc(100vw-2rem-env(safe-area-inset-left,0px)-env(safe-area-inset-right,0px)))] translate-y-2 scale-95 opacity-0 transition-all duration-200 motion-reduce:transition-none motion-reduce:translate-y-0 motion-reduce:scale-100"
    role="dialog"
    aria-modal="true"
    aria-labelledby="fab-panel-title"
    hidden
  >
    <div
      class="max-h-[min(32rem,72vh)] overflow-hidden rounded-2xl border border-gray-200/90 dark:border-gray-700/90 bg-white/95 dark:bg-gray-950/95 shadow-2xl ring-1 ring-black/5 dark:ring-white/10 backdrop-blur-md"
    >
      <div class="flex items-center justify-between gap-2 border-b border-gray-100 dark:border-gray-800 px-3 py-2.5">
        <div
          data-fab-tab-row
          class="hidden min-w-0 flex-1 flex flex-nowrap gap-0.5 overflow-x-auto overscroll-x-contain rounded-lg bg-gray-100/80 dark:bg-gray-900/80 p-0.5 [scrollbar-width:thin] sm:gap-1"
        >
          <button
            type="button"
            data-fab-tab="shortcuts"
            class="fab-tab shrink-0 rounded-md px-2 py-1.5 text-[11px] font-semibold text-gray-600 dark:text-gray-400 data-[active=true]:bg-white data-[active=true]:dark:bg-gray-800 data-[active=true]:text-gray-900 data-[active=true]:dark:text-gray-100 sm:px-2.5 sm:text-xs"
            data-active="true"
          >
            <span class="block whitespace-nowrap text-center" data-i18n="fab.tabShortcuts">Atajos</span>
          </button>
          <button
            type="button"
            data-fab-tab="calendar"
            class="fab-tab shrink-0 rounded-md px-2 py-1.5 text-[11px] font-semibold text-gray-600 dark:text-gray-400 data-[active=true]:bg-white data-[active=true]:dark:bg-gray-800 data-[active=true]:text-gray-900 data-[active=true]:dark:text-gray-100 sm:px-2.5 sm:text-xs"
            data-active="false"
          >
            <span class="block whitespace-nowrap text-center" data-i18n="fab.tabCalendar">Calendario</span>
          </button>
          <button
            type="button"
            data-fab-tab="curiosities"
            class="fab-tab shrink-0 rounded-md px-2 py-1.5 text-[11px] font-semibold text-gray-600 dark:text-gray-400 data-[active=true]:bg-white data-[active=true]:dark:bg-gray-800 data-[active=true]:text-gray-900 data-[active=true]:dark:text-gray-100 sm:px-2.5 sm:text-xs"
            data-active="false"
          >
            <span class="block whitespace-nowrap text-center" data-i18n="fab.tabCuriosities">Curiosidades</span>
          </button>
          <button
            type="button"
            data-fab-tab="cvTips"
            class="fab-tab shrink-0 rounded-md px-2 py-1.5 text-[11px] font-semibold text-gray-600 dark:text-gray-400 data-[active=true]:bg-white data-[active=true]:dark:bg-gray-800 data-[active=true]:text-gray-900 data-[active=true]:dark:text-gray-100 sm:px-2.5 sm:text-xs"
            data-active="false"
            aria-label="CV tips"
          >
            <span class="block whitespace-nowrap text-center" data-i18n="fab.tabCvTips">CV</span>
          </button>
          <button
            type="button"
            data-fab-tab="ai"
            class="fab-tab shrink-0 rounded-md px-2 py-1.5 text-[11px] font-semibold text-gray-600 dark:text-gray-400 data-[active=true]:bg-white data-[active=true]:dark:bg-gray-800 data-[active=true]:text-gray-900 data-[active=true]:dark:text-gray-100 sm:px-2.5 sm:text-xs"
            data-active="false"
            data-fab-tab-ai
          >
            <span class="block whitespace-nowrap text-center" data-i18n="fab.tabAi">IA</span>
          </button>
    </div>
        <h2
          id="fab-panel-title"
          data-fab-title-guest
          class="m-0 hidden min-w-0 flex-1 text-sm font-semibold text-gray-900 dark:text-gray-100"
        >
          <span data-i18n="fab.panelTitleShortcuts">Atajos</span>
        </h2>
        <button
          type="button"
          data-fab-close
          class="shrink-0 rounded-lg border border-gray-200 dark:border-gray-700 px-2 py-1 text-xs font-semibold text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-900"
          data-i18n="fab.close"
        >
          Cerrar
        </button>
      </div>

      <div data-fab-pane="shortcuts" class="max-h-[min(28rem,62vh)] overflow-y-auto p-4 space-y-4">
        <p class="m-0 text-xs text-gray-600 dark:text-gray-400">
          <span data-i18n="settings.shortcuts.intro">Atajos activos en toda la app.</span>
        </p>
        <ul class="m-0 list-none space-y-3 p-0">
          <li
            class="flex flex-col gap-2 rounded-xl border border-gray-200/70 dark:border-gray-800 bg-white/70 dark:bg-gray-950/40 px-3 py-3 sm:flex-row sm:items-center sm:justify-between"
          >
            <span class="text-sm font-medium text-gray-900 dark:text-gray-100">
              <span data-i18n="settings.shortcuts.palette">Abrir búsqueda y navegación rápida</span>
            </span>
            <div class="flex flex-wrap items-center gap-1.5">
              <kbd class={fabKbd} data-i18n="settings.shortcuts.ctrl">Ctrl</kbd><span class="text-gray-400">+</span><kbd class={fabKbd}>K</kbd>
              <span class="px-1 text-xs text-gray-500 dark:text-gray-400" data-i18n="settings.shortcuts.or">o</span>
              <kbd class={fabKbd}>⌘</kbd><span class="text-gray-400">+</span><kbd class={fabKbd}>K</kbd>
              <span class="px-1 text-xs text-gray-500 dark:text-gray-400">·</span>
              <kbd class={fabKbd}>/</kbd>
            </div>
          </li>
          <li class="-mt-1 px-1 text-xs text-gray-600 dark:text-gray-400">
            <span data-i18n="settings.shortcuts.slashHint"></span>
          </li>
          <li
            class="flex flex-col gap-2 rounded-xl border border-gray-200/70 dark:border-gray-800 bg-white/70 dark:bg-gray-950/40 px-3 py-3 sm:flex-row sm:items-center sm:justify-between"
          >
            <span class="text-sm font-medium text-gray-900 dark:text-gray-100">
              <span data-i18n="settings.shortcuts.paletteNavigate">En la paleta: moverse y abrir</span>
            </span>
            <div class="flex flex-wrap items-center gap-1.5">
              <kbd class={fabKbd}>↑</kbd><kbd class={fabKbd}>↓</kbd><span class="text-xs text-gray-500">+</span><kbd class={fabKbd}>Enter</kbd>
            </div>
          </li>
          <li
            class="flex flex-col gap-2 rounded-xl border border-gray-200/70 dark:border-gray-800 bg-white/70 dark:bg-gray-950/40 px-3 py-3 sm:flex-row sm:items-center sm:justify-between"
          >
            <span class="text-sm font-medium text-gray-900 dark:text-gray-100">
              <span data-i18n="settings.shortcuts.close">Cerrar la paleta</span>
            </span>
            <kbd class={fabKbd}>Esc</kbd>
          </li>
          <li
            class="flex flex-col gap-2 rounded-xl border border-gray-200/70 dark:border-gray-800 bg-white/70 dark:bg-gray-950/40 px-3 py-3 sm:flex-row sm:items-center sm:justify-between"
          >
            <span class="text-sm font-medium text-gray-900 dark:text-gray-100">
              <span data-i18n="settings.shortcuts.cvLinkPlaceholder">CV: enlace sugerido</span>
            </span>
            <kbd class={fabKbd}>→</kbd>
          </li>
        </ul>
        <div class="flex flex-col gap-2 border-t border-gray-100 dark:border-gray-800 pt-3 sm:flex-row sm:flex-wrap">
          <button
            type="button"
            data-fab-open-palette
            class="inline-flex justify-center rounded-xl bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500 dark:bg-indigo-500 dark:hover:bg-indigo-400"
          >
            <span data-i18n="fab.openCommandPalette">Abrir paleta</span>
          </button>
          <a
            href="/settings#shortcuts"
            class="inline-flex justify-center rounded-xl border border-gray-200 dark:border-gray-700 px-3 py-2 text-sm font-semibold text-gray-800 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900 no-underline"
          >
            <span data-i18n="fab.linkSettings">Ver en Ajustes</span>
          </a>
        </div>
      </div>

      <div data-fab-pane="calendar" class="hidden max-h-[min(28rem,62vh)] overflow-y-auto p-4 space-y-4">
        <div class="rounded-2xl border border-gray-200/70 dark:border-gray-800 bg-white/70 dark:bg-gray-950/40 p-4 shadow-sm">
          <div class="flex flex-wrap items-end justify-between gap-3">
            <div class="space-y-1">
              <p class="m-0 text-[11px] font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400" data-i18n="fab.tabCalendar">
                Calendario
              </p>
              <p class="m-0 text-xs text-gray-600 dark:text-gray-400">
                <span data-i18n="fab.calendarIntro">Notas rápidas por fecha con etiquetas (se guarda en este dispositivo).</span>
              </p>
            </div>
            <div class="flex flex-wrap gap-2">
              <label class="space-y-1">
                <span class="sr-only">Mes</span>
                <input
                  type="month"
                  data-fab-calendar-month
                  class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 px-2.5 py-2 text-sm"
                />
              </label>
              <label class="space-y-1">
                <span class="sr-only">Tag</span>
                <div data-select-popover data-placeholder="Todos">
                  <select data-fab-calendar-tag class="sr-only" data-select-native>
                    <option value="">Todos</option>
                  </select>
                  <div class="relative">
                    <button
                      type="button"
                      class="w-full inline-flex items-center justify-between gap-2 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 px-3 py-2 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900"
                      data-select-trigger
                      aria-haspopup="listbox"
                      aria-expanded="false"
                    >
                      <span class="min-w-0 truncate" data-select-trigger-label>Todos</span>
                      <span class="shrink-0 opacity-70" aria-hidden="true">▾</span>
                    </button>
                    <div
                      class="hidden absolute left-0 right-0 top-full z-30 mt-1 overflow-hidden rounded-xl border border-gray-200/80 dark:border-gray-800 bg-white/95 dark:bg-gray-950/95 shadow-lg"
                      data-select-panel
                    >
                      <ul
                        class="max-h-72 overflow-auto m-0 p-0 divide-y divide-gray-200/70 dark:divide-gray-800"
                        data-select-list
                        role="listbox"
                      ></ul>
                    </div>
                  </div>
                </div>
              </label>
            </div>
          </div>

          <form class="mt-4 grid grid-cols-1 sm:grid-cols-6 gap-2" data-fab-calendar-form>
            <label class="sm:col-span-2 space-y-1">
              <span class="text-[11px] font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Fecha</span>
              <input
                type="date"
                required
                name="date"
                class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 px-2.5 py-2 text-sm"
              />
            </label>
            <label class="sm:col-span-3 space-y-1">
              <span class="text-[11px] font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Nota</span>
              <input
                type="text"
                required
                name="title"
                maxlength="80"
                placeholder="Ej: Terminar Fase 1"
                class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 px-2.5 py-2 text-sm"
              />
            </label>
            <label class="space-y-1">
              <span class="text-[11px] font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">Tag</span>
              <input
                type="text"
                name="tag"
                maxlength="24"
                placeholder="study"
                class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 px-2.5 py-2 text-sm"
              />
            </label>
            <button
              type="submit"
              class="sm:col-span-6 inline-flex items-center justify-center gap-2 rounded-xl bg-gray-900 dark:bg-gray-100 px-3 py-2 text-sm font-semibold text-white dark:text-gray-900 hover:bg-gray-800 dark:hover:bg-gray-200"
              data-fab-calendar-add
            >
              <span>Añadir</span>
              <span aria-hidden="true">↵</span>
            </button>
          </form>
        </div>

        <div class="space-y-2" data-fab-calendar-list></div>
      </div>

      <div data-fab-pane="curiosities" class="hidden max-h-[min(28rem,62vh)] overflow-y-auto p-4 space-y-4">
        <p class="m-0 text-xs text-gray-600 dark:text-gray-400">
          <span data-i18n="fab.curiositiesIntro">Ideas y herramientas interesantes para explorar (lista viva).</span>
        </p>

        <div class="grid grid-cols-1 gap-3">
          <div class="rounded-2xl border border-sky-200/70 dark:border-sky-900/50 bg-sky-50/70 dark:bg-sky-950/25 p-4">
            <p class="m-0 text-xs font-semibold uppercase tracking-wide text-sky-700 dark:text-sky-300">Data viz</p>
            <div class="mt-2 space-y-2">
              <a href="https://flourish.studio/" target="_blank" rel="noreferrer noopener" class="block rounded-xl border border-sky-200/70 dark:border-sky-900/50 bg-white/70 dark:bg-gray-950/30 px-3 py-2.5 no-underline hover:bg-white/90 dark:hover:bg-gray-900/40">
                <p class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100">Flourish</p>
                <p class="m-0 text-xs text-gray-600 dark:text-gray-400">Storytelling y visualizaciones listas para publicar.</p>
              </a>
              <a href="https://www.datawrapper.de/" target="_blank" rel="noreferrer noopener" class="block rounded-xl border border-sky-200/70 dark:border-sky-900/50 bg-white/70 dark:bg-gray-950/30 px-3 py-2.5 no-underline hover:bg-white/90 dark:hover:bg-gray-900/40">
                <p class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100">Datawrapper</p>
                <p class="m-0 text-xs text-gray-600 dark:text-gray-400">Gráficos y mapas embebibles con buen diseño.</p>
              </a>
              <a href="https://observablehq.com/" target="_blank" rel="noreferrer noopener" class="block rounded-xl border border-sky-200/70 dark:border-sky-900/50 bg-white/70 dark:bg-gray-950/30 px-3 py-2.5 no-underline hover:bg-white/90 dark:hover:bg-gray-900/40">
                <p class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100">Observable</p>
                <p class="m-0 text-xs text-gray-600 dark:text-gray-400">Notebooks JS para prototipar visualizaciones.</p>
              </a>
            </div>
          </div>

          <div class="rounded-2xl border border-emerald-200/70 dark:border-emerald-900/50 bg-emerald-50/70 dark:bg-emerald-950/20 p-4">
            <p class="m-0 text-xs font-semibold uppercase tracking-wide text-emerald-700 dark:text-emerald-300">Productividad</p>
            <div class="mt-2 space-y-2">
              <a href="https://todoist.com/" target="_blank" rel="noreferrer noopener" class="block rounded-xl border border-emerald-200/70 dark:border-emerald-900/50 bg-white/70 dark:bg-gray-950/30 px-3 py-2.5 no-underline hover:bg-white/90 dark:hover:bg-gray-900/40">
                <p class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100">Todoist</p>
                <p class="m-0 text-xs text-gray-600 dark:text-gray-400">Tasks, filtros y hábitos “por disciplina”.</p>
              </a>
              <a href="https://www.notion.so/" target="_blank" rel="noreferrer noopener" class="block rounded-xl border border-emerald-200/70 dark:border-emerald-900/50 bg-white/70 dark:bg-gray-950/30 px-3 py-2.5 no-underline hover:bg-white/90 dark:hover:bg-gray-900/40">
                <p class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100">Notion</p>
                <p class="m-0 text-xs text-gray-600 dark:text-gray-400">Docs + bases de datos para organizar conocimiento.</p>
              </a>
              <a href="https://excalidraw.com/" target="_blank" rel="noreferrer noopener" class="block rounded-xl border border-emerald-200/70 dark:border-emerald-900/50 bg-white/70 dark:bg-gray-950/30 px-3 py-2.5 no-underline hover:bg-white/90 dark:hover:bg-gray-900/40">
                <p class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100">Excalidraw</p>
                <p class="m-0 text-xs text-gray-600 dark:text-gray-400">Diagramas rápidos y compartibles.</p>
              </a>
            </div>
          </div>

          <div class="rounded-2xl border border-amber-200/70 dark:border-amber-900/50 bg-amber-50/70 dark:bg-amber-950/20 p-4">
            <p class="m-0 text-xs font-semibold uppercase tracking-wide text-amber-700 dark:text-amber-300">Conversión</p>
            <div class="mt-2 space-y-2">
              <a href="https://convertio.co/" target="_blank" rel="noreferrer noopener" class="block rounded-xl border border-amber-200/70 dark:border-amber-900/50 bg-white/70 dark:bg-gray-950/30 px-3 py-2.5 no-underline hover:bg-white/90 dark:hover:bg-gray-900/40">
                <p class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100">Convertio</p>
                <p class="m-0 text-xs text-gray-600 dark:text-gray-400">Inspiración para el Convertidor integrado en SkillAtlas.</p>
              </a>
              <a href="https://squoosh.app/" target="_blank" rel="noreferrer noopener" class="block rounded-xl border border-amber-200/70 dark:border-amber-900/50 bg-white/70 dark:bg-gray-950/30 px-3 py-2.5 no-underline hover:bg-white/90 dark:hover:bg-gray-900/40">
                <p class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100">Squoosh</p>
                <p class="m-0 text-xs text-gray-600 dark:text-gray-400">Compresión y conversión de imágenes en el navegador.</p>
              </a>
            </div>
          </div>
        </div>
      </div>

      <div data-fab-pane="cvTips" class="hidden max-h-[min(28rem,62vh)] overflow-y-auto p-4 space-y-4">
        <div class="rounded-2xl border border-amber-200/80 dark:border-amber-900/50 bg-gradient-to-br from-amber-50/90 via-white to-white dark:from-amber-950/35 dark:via-gray-950 dark:to-gray-950 p-4 shadow-sm">
          <p class="m-0 text-lg" aria-hidden="true">💡</p>
          <h3 class="m-0 mt-2 text-base font-semibold text-gray-900 dark:text-gray-100">
            <span data-i18n="fab.cvTipsTitle">Buenas prácticas de CV</span>
          </h3>
          <p class="m-0 mt-2 text-sm leading-relaxed text-gray-600 dark:text-gray-300">
            <span data-i18n="fab.cvTipsIntro">Consejos prácticos para cuando apliques con SkillAtlas.</span>
          </p>
          <ul class="m-0 mt-3 list-none space-y-2 pl-0 text-sm text-gray-700 dark:text-gray-300">
            <li class="flex gap-2"><span class="text-amber-600 dark:text-amber-400 shrink-0">•</span><span data-i18n="fab.cvTipsBullet1"></span></li>
            <li class="flex gap-2"><span class="text-amber-600 dark:text-amber-400 shrink-0">•</span><span data-i18n="fab.cvTipsBullet2"></span></li>
            <li class="flex gap-2"><span class="text-amber-600 dark:text-amber-400 shrink-0">•</span><span data-i18n="fab.cvTipsBullet3"></span></li>
            <li class="flex gap-2"><span class="text-amber-600 dark:text-amber-400 shrink-0">•</span><span data-i18n="fab.cvTipsBullet4"></span></li>
            <li class="flex gap-2"><span class="text-amber-600 dark:text-amber-400 shrink-0">•</span><span data-i18n="fab.cvTipsBullet5"></span></li>
          </ul>
          <a
            href="/cv"
            class="mt-4 inline-flex items-center justify-center rounded-xl border border-amber-300/90 bg-white/90 px-3 py-2 text-sm font-semibold text-amber-950 no-underline hover:bg-amber-50 dark:border-amber-800 dark:bg-gray-950/60 dark:text-amber-50 dark:hover:bg-gray-900"
            data-i18n="fab.cvTipsCta"
          >
            Abrir tu CV en SkillAtlas
          </a>
        </div>
      </div>

      <div data-fab-pane="ai" class="hidden max-h-[min(28rem,62vh)] overflow-y-auto p-4">
        <div
          class="space-y-3 rounded-2xl border border-violet-200/70 dark:border-violet-800/50 bg-gradient-to-br from-violet-50/95 via-white to-white dark:from-violet-950/40 dark:via-gray-950 dark:to-gray-950 p-4 shadow-sm ring-1 ring-violet-200/40 dark:ring-violet-900/30"
        >
          <div class="flex flex-wrap items-start justify-between gap-2">
            <h3 class="m-0 text-base font-semibold tracking-tight text-violet-950 dark:text-violet-100">
              <span data-i18n="fab.aiTitle">Asistente inteligente</span>
            </h3>
            <span
              class="shrink-0 rounded-full border border-violet-300/80 bg-violet-100/80 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-violet-800 dark:border-violet-700 dark:bg-violet-950/60 dark:text-violet-200"
              data-i18n="fab.aiBadge"
            >
              Próximamente
            </span>
          </div>
          <p class="m-0 text-sm leading-relaxed text-gray-600 dark:text-gray-300">
            <span data-i18n="fab.aiIntro">
              Estamos diseñando ayudas con IA que encajen con tu mapa de skills, sin sustituir tu criterio.
            </span>
          </p>
          <ul class="m-0 list-none space-y-2.5 border-t border-violet-100/80 pt-3 dark:border-violet-900/40 pl-0 text-sm text-gray-600 dark:text-gray-400">
            <li class="flex gap-2.5">
              <span class="mt-0.5 shrink-0 text-violet-500 dark:text-violet-400" aria-hidden="true">◇</span>
              <span data-i18n="fab.aiBullet1">Sugerencias al redactar proyectos y evidencias.</span>
            </li>
            <li class="flex gap-2.5">
