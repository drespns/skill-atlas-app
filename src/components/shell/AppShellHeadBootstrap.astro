---
import { FONT_CATALOG, FONT_GOOGLE_LINK_ID } from "../../config/font-catalog";
/** Aplica prefs desde localStorage antes del primer paint (alineado con `core/prefs.ts` / `loadPrefs`). */
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<script is:inline define:vars={{ fontBootCatalog: FONT_CATALOG, fontLinkId: FONT_GOOGLE_LINK_ID }}>
  (() => {
    const STORAGE_KEY = "skillatlas_prefs_v1";
    const safeParse = (raw) => {
      if (!raw) return null;
      try {
        return JSON.parse(raw);
      } catch {
        return null;
      }
    };

    const knownIds = new Set(fontBootCatalog.map((e) => e.id));
    const normFont = (raw) => {
      if (typeof raw === "string" && knownIds.has(raw)) return raw;
      const leg = { inter: "inter", mono: "mono", serif: "serif", system: "system" };
      if (typeof raw === "string" && leg[raw]) return leg[raw];
      return "system";
    };

    const prefs = safeParse(localStorage.getItem(STORAGE_KEY)) ?? {};
    const legacyTheme = localStorage.getItem("theme");
    const themeMode =
      prefs?.themeMode ?? (legacyTheme === "dark" || legacyTheme === "light" ? legacyTheme : "auto");
    const density = "comfortable";
    const uiFontScale = prefs?.uiFontScale === "sm" || prefs?.uiFontScale === "lg" ? prefs.uiFontScale : "md";
    const fontRaw = prefs?.font ?? "system";
    const accent = prefs?.accent ?? "indigo";
    const motion = prefs?.motion ?? "normal";
    const technologiesView = prefs?.technologiesView ?? "cards";
    const projectsView = prefs?.projectsView ?? "cards";
    const projectEvidenceLayout = prefs?.projectEvidenceLayout === "grid" ? "grid" : "large";
    const showHeaderIcons = prefs?.showHeaderIcons ?? true;
    const showLangSelector = prefs?.showLangSelector ?? true;
    const lang = prefs?.lang ?? "es";

    const prefersDark = window.matchMedia?.("(prefers-color-scheme: dark)")?.matches;
    const isDark = themeMode === "dark" ? true : themeMode === "light" ? false : Boolean(prefersDark);

    const root = document.documentElement;
    root.classList.toggle("dark", isDark);
    root.dataset.theme = isDark ? "dark" : "light";
    root.dataset.themeMode = themeMode;
    root.dataset.density = density;
    root.dataset.accent = accent;
    root.dataset.motion = motion;
    root.dataset.technologiesView = technologiesView;
    root.dataset.projectsView = projectsView;
    root.dataset.projectEvidenceLayout = projectEvidenceLayout;
    root.dataset.showHeaderIcons = showHeaderIcons ? "true" : "false";
    root.dataset.showLangSelector = showLangSelector ? "true" : "false";
    root.dataset.langPref = lang;
    root.dataset.langUiLocked = "1";
    root.dataset.uiFontScale = uiFontScale;
    root.style.colorScheme = isDark ? "dark" : "light";

    const fontId = normFont(fontRaw);
    const entry = fontBootCatalog.find((e) => e.id === fontId) || fontBootCatalog[0];
    root.dataset.font = fontId;
    if (entry.googleQuery) {
      const href = `https://fonts.googleapis.com/css2?family=${encodeURIComponent(entry.googleQuery)}&display=swap`;
      let link = document.getElementById(fontLinkId);
      if (!link) {
        link = document.createElement("link");
        link.id = fontLinkId;
        link.rel = "stylesheet";
        document.head.appendChild(link);
      }
      link.href = href;
    } else {
      document.getElementById(fontLinkId)?.remove();
    }
    root.style.setProperty("--app-font-family", entry.stack);

    const mainPy = "1.5rem";
    const mainPx = "1.25rem";
    const headerPy = "1rem";
    const headerPx = "1.25rem";
    root.style.setProperty("--app-main-py", mainPy);
    root.style.setProperty("--app-main-px", mainPx);
    root.style.setProperty("--app-header-py", headerPy);
    root.style.setProperty("--app-header-px", headerPx);

    const rootFontPct = uiFontScale === "sm" ? "93.75%" : uiFontScale === "lg" ? "106.25%" : "100%";
    root.style.setProperty("--app-root-font-size", rootFontPct);

    const accentHsl =
      accent === "emerald"
        ? "152 76% 36%"
        : accent === "rose"
          ? "346 77% 49%"
          : accent === "amber"
            ? "38 92% 50%"
            : accent === "sky"
              ? "199 89% 48%"
              : accent === "violet"
                ? "262 83% 58%"
                : "239 84% 67%";
    root.style.setProperty("--app-accent-hsl", accentHsl);
    root.style.setProperty("--app-motion", motion);
  })();
</script>
