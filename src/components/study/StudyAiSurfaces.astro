---
export interface Props {
  /** `chat` = columna central; `aside` = bloque Salidas en la barra derecha. */
  part: "chat" | "aside";
}
const { part } = Astro.props;
const enabled = import.meta.env.PUBLIC_STUDY_AI_SURFACES === "true";
---

{
  enabled && part === "chat" ? (
    <div
      data-study-chat-panel
      class="rounded-xl border border-indigo-200/70 dark:border-indigo-900/50 bg-indigo-50/35 dark:bg-indigo-950/20 p-4 mb-3 space-y-3"
    >
      <div class="flex flex-wrap items-center justify-between gap-2">
        <p
          class="m-0 text-[11px] font-semibold tracking-wide text-indigo-900 dark:text-indigo-200 uppercase"
          data-i18n="study.chatKicker"
        >
          Chat con fuentes
        </p>
        <span
          data-study-chat-hint
          class="text-[10px] text-indigo-900/75 dark:text-indigo-200/75 text-right max-w-[16rem] leading-snug"
        />
      </div>
      <p
        class="m-0 hidden text-[11px] text-amber-900 dark:text-amber-200/90 rounded-lg border border-amber-200/80 dark:border-amber-900/50 bg-amber-50/60 dark:bg-amber-950/30 px-2 py-1.5"
        data-study-chat-disabled-msg
        data-i18n="study.chatDisabledHint"
      >
        El chat está desactivado. Revisa variables de entorno.
      </p>
      <div
        data-study-chat-messages
        class="max-h-56 overflow-auto space-y-2 rounded-lg border border-indigo-200/55 dark:border-indigo-900/45 bg-white/75 dark:bg-gray-950/55 p-2 min-h-[4.5rem]"
      />
      <form data-study-chat-form class="flex items-end gap-2">
        <label class="block flex-1">
          <span class="sr-only" data-i18n="study.chatInputLabel">
            Pregunta al asistente
          </span>
          <textarea
            data-study-chat-input
            rows={2}
            class="w-full text-sm rounded-xl border border-indigo-200/80 dark:border-indigo-900/50 bg-white dark:bg-gray-950 px-3 py-2 leading-relaxed resize-none"
            placeholder=""
            data-i18n="study.chatInputPlaceholder"
            data-i18n-attr="placeholder"
          />
        </label>
        <button
          type="submit"
          data-study-chat-send
          class="shrink-0 text-xs font-semibold rounded-xl bg-indigo-600 text-white px-3 py-2 hover:bg-indigo-500 disabled:opacity-50 disabled:pointer-events-none"
        >
          <span data-i18n="study.chatSend">Enviar</span>
        </button>
      </form>

      <div
        data-study-cite-focus
        class="hidden rounded-lg border border-amber-200/85 dark:border-amber-900/45 bg-amber-50/55 dark:bg-amber-950/25 p-3 space-y-2 scroll-mt-4"
      >
        <div class="flex flex-wrap items-center justify-between gap-2">
          <div class="min-w-0 flex-1">
            <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100 truncate" data-study-cite-title />
            <p class="m-0 text-[11px] text-gray-600 dark:text-gray-400 truncate" data-study-cite-meta />
          </div>
          <div class="flex flex-wrap gap-2 shrink-0">
            <button
              type="button"
              data-study-cite-source
              class="text-[11px] font-semibold text-indigo-700 dark:text-indigo-300 hover:underline"
              data-i18n="study.citeJumpSource"
            >
              Abrir fuente
            </button>
            <button
              type="button"
              data-study-cite-highlight
              class="text-[11px] font-semibold text-amber-900 dark:text-amber-200 hover:underline"
              data-i18n="study.citeHighlightSidebar"
            >
              Resaltar en lista
            </button>
          </div>
        </div>
        <div
          data-study-cite-body
          class="text-xs text-gray-800 dark:text-gray-200 leading-relaxed max-h-44 overflow-auto whitespace-pre-wrap rounded-md bg-white/70 dark:bg-gray-950/60 p-2 border border-amber-200/55 dark:border-amber-900/35"
        />
      </div>
    </div>
  ) : null
}

{
  enabled && part === "aside" ? (
    <>
      <div class="px-4 py-3 border-t border-b border-gray-200/80 dark:border-gray-800">
        <h2 class="m-0 text-sm font-semibold" data-i18n="study.studioTitle">
          Salidas
        </h2>
        <p class="m-0 mt-1 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="study.studioHint">
          Generación asistida: próximas iteraciones.
        </p>
      </div>
      <div class="p-3 grid grid-cols-2 gap-2">
        <button
          type="button"
          data-study-out="summary"
          class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-2 py-1.5 text-xs font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 text-left"
        >
          <span data-i18n="study.outSummary">Resumen</span>
        </button>
        <button
          type="button"
          data-study-out="flashcards"
          class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-2 py-1.5 text-xs font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 text-left"
        >
          <span data-i18n="study.outFlashcards">Tarjetas</span>
        </button>
        <button
          type="button"
          data-study-out="quiz"
          class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-2 py-1.5 text-xs font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 text-left"
        >
          <span data-i18n="study.outQuiz">Cuestionario</span>
        </button>
        <button
          type="button"
          data-study-out="mindmap"
          class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-2 py-1.5 text-xs font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 text-left"
        >
          <span data-i18n="study.outMindmap">Mapa mental</span>
        </button>
        <button
          type="button"
          data-study-out="report"
          class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-2 py-1.5 text-xs font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 text-left"
        >
          <span data-i18n="study.outReport">Informe</span>
        </button>
        <button
          type="button"
          data-study-out="infographic"
          class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-2 py-1.5 text-xs font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 text-left"
        >
          <span data-i18n="study.outInfographic">Infografía</span>
        </button>
      </div>
    </>
  ) : null
}
