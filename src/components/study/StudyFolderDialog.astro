---
/** Modal para crear carpeta personalizada en Fuentes (`init.ts`). */
---

<dialog
  data-study-folder-dialog
  class="study-folder-dialog w-[min(100vw-1.5rem,34rem)] max-w-[calc(100vw-1.5rem)] rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-0 text-gray-900 dark:text-gray-100 shadow-2xl"
>
  <div class="flex min-h-0 flex-1 flex-col overflow-hidden">
    <div
      class="shrink-0 border-b border-violet-200/60 dark:border-violet-900/40 bg-gradient-to-r from-violet-50/95 via-white to-indigo-50/90 dark:from-violet-950/40 dark:via-gray-950 dark:to-indigo-950/30 px-4 py-3 sm:px-5"
    >
      <p class="m-0 text-[10px] font-bold tracking-wide text-violet-700 dark:text-violet-300 uppercase" data-i18n="study.folderModalKicker">
        Fuentes
      </p>
      <h2 class="m-0 mt-1 text-base font-semibold tracking-tight" data-i18n="study.folderModalTitle">
        Nueva carpeta
      </h2>
      <p class="m-0 mt-1 text-xs text-gray-600 dark:text-gray-400" data-i18n="study.folderModalIntro">
        Las carpetas propias se guardan en este dispositivo junto al espacio de estudio.
      </p>
    </div>
    <div class="min-h-0 flex-1 overflow-y-auto overscroll-contain px-4 py-4 sm:px-5">
      <label class="block space-y-1.5">
        <span class="text-[11px] font-semibold tracking-wide text-gray-500 dark:text-gray-400 uppercase" data-i18n="study.folderModalLabel">
          Nombre
        </span>
        <input
          type="text"
          data-study-folder-name-input
          class="w-full text-sm rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2.5 shadow-sm focus:border-violet-400 focus:outline-none focus:ring-2 focus:ring-violet-500/25 dark:focus:border-violet-600"
          placeholder=""
          data-i18n="study.customFolderPrompt"
          data-i18n-attr="placeholder"
          autocomplete="off"
        />
      </label>
    </div>
    <div
      class="shrink-0 flex flex-wrap items-center justify-end gap-2 border-t border-gray-200/90 dark:border-gray-800 bg-gray-50/80 dark:bg-gray-900/50 px-4 py-3 sm:px-5"
    >
      <button
        type="button"
        data-study-folder-cancel
        class="text-xs font-semibold rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-950 px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-900"
        data-i18n="study.folderModalCancel"
      >
        Cancelar
      </button>
      <button
        type="button"
        data-study-folder-submit
        class="text-xs font-semibold rounded-xl bg-violet-600 text-white px-4 py-2 shadow-sm hover:bg-violet-500 disabled:opacity-50 disabled:pointer-events-none"
        data-i18n="study.folderModalCreate"
      >
        Crear carpeta
      </button>
    </div>
  </div>
</dialog>
