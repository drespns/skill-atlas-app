---
/** Modal nativo para crear un estudio (sustituye window.prompt). */
---

<dialog
  data-study-new-space-dialog
  class="study-new-space-dialog w-[min(100vw-1.5rem,34rem)] max-w-[calc(100vw-1.5rem)] rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-0 text-gray-900 dark:text-gray-100 shadow-2xl"
>
  <div class="study-new-space-dialog__inner flex min-h-0 flex-1 flex-col overflow-hidden">
    <div
      class="shrink-0 border-b border-indigo-200/60 dark:border-indigo-900/40 bg-gradient-to-r from-indigo-50/95 via-white to-violet-50/90 dark:from-indigo-950/40 dark:via-gray-950 dark:to-violet-950/30 px-4 py-3 sm:px-5"
    >
      <p class="m-0 text-[10px] font-bold tracking-wide text-indigo-700 dark:text-indigo-300 uppercase" data-i18n="study.newSpaceModalKicker">
        Nuevo estudio
      </p>
      <h2 class="m-0 mt-1 text-base font-semibold tracking-tight" data-i18n="study.newSpaceModalTitle">
        Nombre del estudio
      </h2>
      <p class="m-0 mt-1 text-xs text-gray-600 dark:text-gray-400" data-i18n="study.newSpaceModalIntro">
        Cada estudio tiene sus propias fuentes, notas y temario.
      </p>
    </div>
    <div class="min-h-0 flex-1 overflow-y-auto overscroll-contain px-4 py-4 sm:px-5">
      <label class="block space-y-1.5">
        <span class="text-[11px] font-semibold tracking-wide text-gray-500 dark:text-gray-400 uppercase" data-i18n="study.studyNameLabel">
          Nombre
        </span>
        <input
          type="text"
          data-study-new-space-title
          class="w-full text-sm rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2.5 shadow-sm focus:border-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/25 dark:focus:border-indigo-600"
          placeholder=""
          data-i18n="study.goalPlaceholder"
          data-i18n-attr="placeholder"
          autocomplete="off"
        />
      </label>
    </div>
    <div
      class="shrink-0 flex flex-wrap items-center justify-end gap-2 border-t border-gray-200/90 dark:border-gray-800 bg-gray-50/80 dark:bg-gray-900/50 px-4 py-3 sm:px-5"
    >
      <button
        type="button"
        data-study-new-space-cancel
        class="text-xs font-semibold rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-950 px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-900"
        data-i18n="study.newSpaceModalCancel"
      >
        Cancelar
      </button>
      <button
        type="button"
        data-study-new-space-submit
        class="text-xs font-semibold rounded-xl bg-indigo-600 text-white px-4 py-2 shadow-sm hover:bg-indigo-500 disabled:opacity-50 disabled:pointer-events-none"
        data-i18n="study.newSpaceModalCreate"
      >
        Crear estudio
      </button>
    </div>
  </div>
</dialog>
