---
type Option = { value: string; label: string; disabled?: boolean };

type Props = {
  label?: string;
  placeholder?: string;
  searchable?: boolean;
  /** Optional helper text below the control. */
  hint?: string;
  /** Extra classes for wrapper. */
  class?: string;
  /** Options can be provided via props or via <option> children (slot). */
  options?: Option[];
  /** Any extra attrs go to the hidden <select> (including data-* hooks). */
  [k: string]: any;
};

const {
  label,
  placeholder = "Selecciona…",
  searchable = false,
  hint,
  class: wrapperClass,
  options,
  ...selectAttrs
} = Astro.props as Props;

const panelClass =
  "absolute left-0 right-0 top-full z-30 mt-1 overflow-hidden rounded-xl border border-gray-200/80 dark:border-gray-800 bg-white/95 dark:bg-gray-950/95 shadow-lg";
const listClass = "max-h-72 overflow-auto m-0 p-0 divide-y divide-gray-200/70 dark:divide-gray-800";
const triggerClass =
  "w-full inline-flex items-center justify-between gap-2 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 px-3 py-2.5 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500/40 dark:focus:ring-indigo-400/30";
---

<div class={`space-y-1 ${wrapperClass ?? ""}`} data-select-popover>
  {label ? <span class="text-sm font-semibold">{label}</span> : null}

  {/* Hidden native select for compatibility (forms + scripts). */}
  <select class="sr-only" data-select-native {...selectAttrs}>
    {options
      ? options.map((o) => (
          <option value={o.value} disabled={o.disabled}>
            {o.label}
          </option>
        ))
      : <slot />}
  </select>

  <div class="relative">
    <button type="button" class={triggerClass} data-select-trigger aria-haspopup="listbox" aria-expanded="false">
      <span class="min-w-0 truncate" data-select-trigger-label>{placeholder}</span>
      <span class="shrink-0 opacity-70" aria-hidden="true">▾</span>
    </button>

    <div class={`hidden ${panelClass}`} data-select-panel>
      {searchable ? (
        <div class="p-2 border-b border-gray-200/70 dark:border-gray-800">
          <input
            type="search"
            class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white/80 dark:bg-gray-950/70 px-3 py-2 text-sm"
            placeholder="Buscar…"
            data-select-search
          />
        </div>
      ) : null}
      <ul class={listClass} data-select-list role="listbox"></ul>
    </div>
  </div>

  {hint ? <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400">{hint}</p> : null}
</div>

