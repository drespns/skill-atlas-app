---
import "../styles/global.css";
import { repoUrl } from "../data";
import clientScriptUrl from "../scripts/client.ts?url";
import { GLOBAL_BANNER } from "../config/banner";

const { title = "SkillAtlas" } = Astro.props;
const year = new Date().getFullYear();

const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname === href || pathname.startsWith(`${href}/`);
const homeHref = pathname === "/" ? "/" : "/app";

const APP_LOGO_SRC = "/favicon.svg";

/** Logos mostrados en el pie (stack con el que se construye la app). */
const FOOTER_BUILD_ICONS = [
  { src: "/icons/Astro.svg", label: "Astro" },
  { src: "/icons/Tailwind CSS.svg", label: "Tailwind CSS" },
  { src: "/icons/TypeScript.svg", label: "TypeScript" },
  { src: "/icons/Vite.js.svg", label: "Vite" },
] as const;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>

    <script is:inline>
      (() => {
        const STORAGE_KEY = "skillatlas_prefs_v1";
        const safeParse = (raw) => {
          if (!raw) return null;
          try {
            return JSON.parse(raw);
          } catch {
            return null;
          }
        };

        const prefs = safeParse(localStorage.getItem(STORAGE_KEY)) ?? {};
        const legacyTheme = localStorage.getItem("theme"); // "dark" | "light" | null
        const themeMode =
          prefs?.themeMode ?? (legacyTheme === "dark" || legacyTheme === "light" ? legacyTheme : "auto");
        const density = prefs?.density ?? "comfortable";
        const font = prefs?.font ?? "system";
        const accent = prefs?.accent ?? "indigo";
        const motion = prefs?.motion ?? "normal";
        const technologiesView = prefs?.technologiesView ?? "cards";
        const projectsView = prefs?.projectsView ?? "cards";
        const showHeaderIcons = prefs?.showHeaderIcons ?? true;
        const showLangSelector = prefs?.showLangSelector ?? true;
        const lang = prefs?.lang ?? "es";

        const prefersDark = window.matchMedia?.("(prefers-color-scheme: dark)")?.matches;
        const isDark = themeMode === "dark" ? true : themeMode === "light" ? false : Boolean(prefersDark);

        const root = document.documentElement;
        root.classList.toggle("dark", isDark);
        root.dataset.theme = isDark ? "dark" : "light";
        root.dataset.themeMode = themeMode;
        root.dataset.density = density;
        root.dataset.font = font;
        root.dataset.accent = accent;
        root.dataset.motion = motion;
        root.dataset.technologiesView = technologiesView;
        root.dataset.projectsView = projectsView;
        root.dataset.showHeaderIcons = showHeaderIcons ? "true" : "false";
        root.dataset.showLangSelector = showLangSelector ? "true" : "false";
        root.dataset.langPref = lang;
        root.style.colorScheme = isDark ? "dark" : "light";

        const fontFamily =
          font === "mono"
            ? 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace'
            : font === "inter"
              ? 'Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, "Noto Sans", "Apple Color Emoji", "Segoe UI Emoji"'
              : 'ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, "Noto Sans", "Apple Color Emoji", "Segoe UI Emoji"';
        root.style.setProperty("--app-font-family", fontFamily);

        const mainPy = density === "compact" ? "1rem" : "1.5rem";
        const mainPx = density === "compact" ? "1rem" : "1.25rem";
        const headerPy = density === "compact" ? "0.75rem" : "1rem";
        const headerPx = density === "compact" ? "1rem" : "1.25rem";
        root.style.setProperty("--app-main-py", mainPy);
        root.style.setProperty("--app-main-px", mainPx);
        root.style.setProperty("--app-header-py", headerPy);
        root.style.setProperty("--app-header-px", headerPx);

        const accentHsl =
          accent === "emerald"
            ? "152 76% 36%"
            : accent === "rose"
              ? "346 77% 49%"
              : accent === "amber"
                ? "38 92% 50%"
                : accent === "sky"
                  ? "199 89% 48%"
                  : accent === "violet"
                    ? "262 83% 58%"
                    : "239 84% 67%";
        root.style.setProperty("--app-accent-hsl", accentHsl);
        root.style.setProperty("--app-motion", motion);
      })();
    </script>
  </head>
  <body
    class="bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100 min-h-svh flex flex-col"
    style="font-family: var(--app-font-family);"
  >
    <div data-global-banner-wrap class="sticky top-0 z-1001">
      <div
        data-global-banner
        data-banner-id={GLOBAL_BANNER.id}
        data-banner-state="closed"
        class="overflow-hidden border-b border-gray-200/80 dark:border-gray-800 backdrop-blur transition-[max-height,opacity,transform] duration-300 ease-out max-h-0 opacity-0 -translate-y-2 pointer-events-none bg-white/80 dark:bg-gray-950/75"
      >
        <div class="max-w-screen-2xl mx-auto flex flex-wrap items-center justify-between gap-3 px-4 py-2">
          <div class="flex flex-wrap items-center gap-2 min-w-0">
            <span class="text-[11px] font-semibold rounded-full px-2 py-0.5 border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/70">
              {GLOBAL_BANNER.version}
            </span>
            <span data-banner-text class="text-xs text-gray-700 dark:text-gray-200 truncate">{GLOBAL_BANNER.text}</span>
            {
              GLOBAL_BANNER.href ? (
                <a
                  data-banner-link
                  href={GLOBAL_BANNER.href}
                  class="text-xs font-semibold underline decoration-gray-300 hover:decoration-gray-600 dark:decoration-gray-700 dark:hover:decoration-gray-400"
                >
                  {GLOBAL_BANNER.hrefLabel ?? "Ver más"}
                </a>
              ) : null
            }
          </div>
          <button
            type="button"
            data-banner-close
            class="text-xs font-semibold rounded-lg border border-gray-200/80 dark:border-gray-800 px-2.5 py-1 hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors"
            aria-label="Cerrar anuncio"
            title="Cerrar"
          >
            Cerrar
          </button>
        </div>
      </div>
      <div class="pointer-events-none absolute inset-0 -z-10 bg-linear-to-r from-indigo-200/40 via-transparent to-rose-200/40 dark:from-indigo-500/10 dark:to-rose-500/10 opacity-0" data-banner-glow></div>
    </div>

    <header
      class="border-b border-gray-200/80 dark:border-gray-800"
      data-app-header
      style="padding: var(--app-header-py, 1rem) var(--app-header-px, 1.25rem);"
    >
      <div class="max-w-screen-2xl mx-auto flex items-center justify-between gap-4">
        <a href={homeHref} class="flex items-center gap-3 no-underline">
          <img src={APP_LOGO_SRC} alt="SkillAtlas" class="h-8 w-8 rounded-md" />
          <span class="font-bold text-lg hover:underline">SkillAtlas</span>
          <span
            data-auth-avatar-wrap
            class="hidden items-center justify-center ml-1"
            aria-hidden="true"
          >
            <img
              data-auth-avatar
              alt=""
              class="h-8 w-8 rounded-full border border-gray-200/80 dark:border-gray-800 object-cover"
              loading="lazy"
              referrerpolicy="no-referrer"
            />
          </span>
        </a>

        <nav class="hidden md:flex flex-wrap gap-4 text-sm" data-i18n-scope="nav">
          <a href="/" class={`hover:underline ${pathname === "/" ? "font-semibold" : ""}`}>
            <span>Landing</span>
          </a>
          <a
            href="/technologies"
            class={`hover:underline ${isActive("/technologies") ? "font-semibold" : ""}`}
          >
            <span data-i18n="nav.technologies">Tecnologías</span>
          </a>
          <a
            href="/projects"
            class={`hover:underline ${isActive("/projects") ? "font-semibold" : ""}`}
          >
            <span data-i18n="nav.projects">Proyectos</span>
          </a>
          <a
            href="/portfolio"
            class={`hover:underline ${isActive("/portfolio") ? "font-semibold" : ""}`}
          >
            <span data-i18n="nav.portfolio">Portfolio</span>
          </a>
        </nav>

        <div class="flex items-center gap-2" data-header-icons>
          <button
            type="button"
            data-banner-reopen
            class="hidden sm:inline-flex items-center justify-center rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-2.5 py-2 hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors"
            aria-label="Mostrar anuncio"
            title="Mostrar anuncio"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 11v3a1 1 0 0 0 1 1h3" />
              <path d="M21 13v-3a1 1 0 0 0-1-1h-3" />
              <path d="M7 15l-3 3-3-3" />
              <path d="M17 9l3-3 3 3" />
            </svg>
          </button>
          <div
            data-lang-flags
            class="hidden sm:inline-flex items-center rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 p-0.5 gap-0.5"
            role="group"
            aria-label="Idioma"
            data-i18n="common.language"
            data-i18n-attr="aria-label"
          >
            <button
              type="button"
              data-lang-flag="es"
              class="rounded-md px-2 py-1.5 text-lg leading-none hover:bg-gray-100 dark:hover:bg-gray-900 aria-pressed:ring-2 aria-pressed:ring-gray-400 dark:aria-pressed:ring-gray-500"
              aria-pressed="true"
              title="Español"
            >
              🇪🇸
            </button>
            <button
              type="button"
              data-lang-flag="en"
              class="rounded-md px-2 py-1.5 text-lg leading-none hover:bg-gray-100 dark:hover:bg-gray-900 aria-pressed:ring-2 aria-pressed:ring-gray-400 dark:aria-pressed:ring-gray-500"
              aria-pressed="false"
              title="English"
            >
              🇬🇧
            </button>
          </div>

          <button
            type="button"
            data-command-palette-trigger
            class="hidden sm:inline-flex items-center gap-2 justify-center rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-2.5 py-2 hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors"
            aria-label="Buscar (Ctrl+K)"
            title="Buscar (Ctrl+K)"
          >
            <svg
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.3-4.3" />
            </svg>
            <span class="hidden lg:inline text-xs font-semibold text-gray-600 dark:text-gray-300">Ctrl K</span>
          </button>

          <a
            href="/login"
            data-auth-header-login
            class={`inline-flex items-center justify-center rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-2.5 py-2 hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors ${isActive("/login") ? "ring-1 ring-gray-300 dark:ring-gray-700" : ""} hidden`}
            aria-label="Login"
            title="Login"
          >
            <svg
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
              <path d="M10 17l5-5-5-5" />
              <path d="M15 12H3" />
            </svg>
          </a>

          <button
            type="button"
            data-auth-header-signout
            class="hidden items-center justify-center rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-2.5 py-2 hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors"
            aria-label="Cerrar sesión"
            title="Cerrar sesión"
          >
            <svg
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
              <path d="M16 17l5-5-5-5" />
              <path d="M21 12H9" />
            </svg>
          </button>

          <a
            href="/settings"
            data-auth-header-settings
            class={`inline-flex items-center justify-center rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-2.5 py-2 hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors ${isActive("/settings") ? "ring-1 ring-gray-300 dark:ring-gray-700" : ""} hidden`}
            aria-label="Ajustes"
            title="Ajustes"
            data-i18n="nav.settings"
            data-i18n-attr="aria-label,title"
          >
            <svg
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <!-- Icon from Lucide "sliders-horizontal" (inline SVG) -->
              <path d="M21 4H14" />
              <path d="M10 4H3" />
              <path d="M21 12H12" />
              <path d="M8 12H3" />
              <path d="M21 20H16" />
              <path d="M12 20H3" />
              <path d="M14 2v4" />
              <path d="M8 10v4" />
              <path d="M16 18v4" />
            </svg>
          </a>

          <a
            href={repoUrl}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center justify-center rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-2.5 py-2 hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors"
            aria-label="Ver repositorio en GitHub"
            title="GitHub"
            data-i18n="common.githubRepo"
            data-i18n-attr="aria-label"
          >
            <img src="/icons/GitHub.svg" alt="" class="h-5 w-5" />
          </a>

          <button
            type="button"
            data-theme-toggle
            class="inline-flex items-center justify-center rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-2.5 py-2 hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors"
            aria-label="Cambiar tema"
            title="Tema"
            aria-pressed="false"
            data-i18n="common.toggleTheme"
            data-i18n-attr="aria-label,title"
          >
            <span class="sr-only" data-i18n="common.toggleTheme">Cambiar tema</span>
            <svg
              data-icon-sun
              class="h-5 w-5 hidden dark:block"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v2"></path>
              <path d="M12 20v2"></path>
              <path d="M4.93 4.93l1.41 1.41"></path>
              <path d="M17.66 17.66l1.41 1.41"></path>
              <path d="M2 12h2"></path>
              <path d="M20 12h2"></path>
              <path d="M6.34 17.66l-1.41 1.41"></path>
              <path d="M19.07 4.93l-1.41 1.41"></path>
            </svg>
            <svg
              data-icon-moon
              class="h-5 w-5 block dark:hidden"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <main
      class="max-w-screen-2xl mx-auto flex-1 w-full"
      data-app-main
      style="padding: var(--app-main-py, 1.5rem) var(--app-main-px, 1.25rem);"
    >
      <slot />
    </main>

    <footer
      class="mt-auto border-t border-gray-200/80 dark:border-gray-800 bg-linear-to-b from-transparent to-gray-50/90 dark:to-gray-950/90"
      style="padding: 2rem var(--app-main-px, 1.25rem) 1.75rem;"
      aria-label="Site"
    >
      <div class="max-w-screen-2xl mx-auto flex flex-col gap-8">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
          <div class="space-y-2 max-w-md">
            <div class="flex items-center gap-2">
              <img src={APP_LOGO_SRC} alt="" class="h-7 w-7 rounded-md opacity-90" />
              <span class="font-bold text-base tracking-tight">SkillAtlas</span>
            </div>
            <p class="m-0 text-sm text-gray-600 dark:text-gray-400 leading-relaxed" data-i18n="footer.tagline"></p>
          </div>
          <nav
            class="flex flex-wrap gap-x-6 gap-y-2 text-sm font-medium text-gray-700 dark:text-gray-300"
            aria-label="Footer"
          >
            <a href="/technologies" class="hover:text-gray-900 dark:hover:text-white no-underline transition-colors">
              <span data-i18n="nav.technologies"></span>
            </a>
            <a href="/projects" class="hover:text-gray-900 dark:hover:text-white no-underline transition-colors">
              <span data-i18n="nav.projects"></span>
            </a>
            <a href="/portfolio" class="hover:text-gray-900 dark:hover:text-white no-underline transition-colors">
              <span data-i18n="nav.portfolio"></span>
            </a>
            <a href="/settings" class="hover:text-gray-900 dark:hover:text-white no-underline transition-colors">
              <span data-i18n="nav.settings"></span>
            </a>
            <a
              href={repoUrl}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center gap-1.5 hover:text-gray-900 dark:hover:text-white no-underline transition-colors"
            >
              <span data-i18n="footer.openSource"></span>
              <svg class="h-3.5 w-3.5 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </svg>
            </a>
          </nav>
        </div>

        <div
          class="flex flex-col items-center gap-4 pt-6 border-t border-gray-200/70 dark:border-gray-800/80"
          aria-hidden="true"
        >
          <p
            class="m-0 text-[10px] font-semibold uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400"
            data-i18n="footer.builtWith"
          >
          </p>
          <div class="flex flex-wrap items-center justify-center gap-7 md:gap-10">
            {
              FOOTER_BUILD_ICONS.map((ico) => (
                <img
                  src={ico.src}
                  alt={ico.label}
                  title={ico.label}
                  class="h-8 w-auto max-h-8 max-w-24 object-contain opacity-90 dark:opacity-85"
                  loading="lazy"
                />
              ))
            }
            <img
              src="/icons/supabase-logo-icon.svg"
              alt="Supabase"
              title="Supabase"
              class="h-9 w-auto max-h-9 object-contain opacity-90 dark:opacity-85"
              loading="lazy"
            />
          </div>
        </div>
      </div>
      <p class="max-w-screen-2xl mx-auto mt-8 pt-6 border-t border-gray-200/60 dark:border-gray-800/80 text-center text-xs text-gray-500 dark:text-gray-500">
        © {year} SkillAtlas
      </p>
    </footer>

    <div
      data-command-palette
      class="hidden fixed inset-0 z-50 items-start justify-center p-4 sm:p-6 bg-black/40"
      aria-hidden="true"
    >
      <div
        data-command-palette-dialog
        class="w-full max-w-xl rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 shadow-xl overflow-hidden"
      >
        <div class="flex items-center gap-2 p-3 border-b border-gray-100 dark:border-gray-800">
          <input
            data-command-palette-input
            class="w-full rounded-xl border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-3 py-2 text-sm app-accent-ring"
            placeholder="Buscar… (Ctrl+K)"
            data-i18n="common.commandPalettePlaceholder"
            data-i18n-attr="placeholder"
          />
          <button
            type="button"
            data-command-palette-close
            class="btn-secondary text-sm"
            data-i18n="common.close"
          >
            Cerrar
          </button>
        </div>
        <div data-command-palette-list class="p-2 max-h-[60vh] overflow-auto"></div>
      </div>
    </div>

    <script type="module" src={clientScriptUrl}></script>
  </body>
</html>

