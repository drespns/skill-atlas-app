---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { GLOBAL_BANNER } from "../config/banner";
import AppShellHeadBootstrap from "../components/shell/AppShellHeadBootstrap.astro";
import AppShellBannerDismissScript from "../components/shell/AppShellBannerDismissScript.astro";
import AppGlobalBanner from "../components/shell/AppGlobalBanner.astro";
import AppHeader from "../components/shell/AppHeader.astro";
import AppFooter from "../components/shell/AppFooter.astro";
import AppCommandPalette from "../components/shell/AppCommandPalette.astro";
import AppFabShell from "../components/shell/AppFabShell.astro";

const { title = "SkillAtlas" } = Astro.props;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="es" data-sa-banner-hydrated="0">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <slot name="head" />
    <ClientRouter />

    <AppShellHeadBootstrap />
    <AppShellBannerDismissScript bannerId={GLOBAL_BANNER.id} />
  </head>
  <body
    class="bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100 min-h-svh flex flex-col"
    style="font-family: var(--app-font-family);"
  >
    <AppGlobalBanner />
    <AppHeader pathname={pathname} />

    <main
      class="max-w-screen-2xl mx-auto flex-1 w-full"
      data-app-main
      style="padding: var(--app-main-py, 1.5rem) var(--app-main-px, 1.25rem);"
    >
      <slot />
    </main>

    <AppFooter />
    <AppCommandPalette />
    <AppFabShell />

    <script src="../scripts/client.ts"></script>
    <script src="../scripts/shell/fab-bubbles.ts"></script>
    <script src="../scripts/shell/onboarding-spotlight.ts"></script>
  </body>
</html>
