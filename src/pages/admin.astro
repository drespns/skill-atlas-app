---
import AppShell from "../layouts/AppShell.astro";

const title = "Admin";
---

<AppShell title={title}>
  <div data-requires-auth class="hidden"></div>

  <main class="max-w-5xl mx-auto space-y-6">
    <header class="space-y-2">
      <p class="m-0 text-xs font-semibold tracking-wide text-gray-500 dark:text-gray-400 uppercase">Admin</p>
      <h1 class="m-0 text-3xl md:text-4xl font-semibold tracking-tight">Solicitudes de acceso</h1>
      <p class="m-0 text-sm md:text-base text-gray-600 dark:text-gray-400 max-w-3xl">
        Panel privado para revisar solicitudes enviadas desde <span class="font-semibold">/request-access</span>.
      </p>
    </header>

    <section
      class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 shadow-sm p-5 space-y-4"
    >
      <div class="hidden" data-admin-denied>
        <p class="m-0 text-sm text-rose-700 dark:text-rose-300 font-semibold">No tienes permisos de admin.</p>
        <p class="mt-2 mb-0 text-sm text-gray-600 dark:text-gray-400">
          Si crees que es un error, añade tu <span class="font-semibold">user_id</span> a <span class="font-semibold">public.admin_users</span>
          en Supabase (ver <span class="font-semibold">saas-010</span>).
        </p>
      </div>

      <div data-admin-access-requests>
        <p class="m-0 text-sm text-gray-600 dark:text-gray-400">Cargando…</p>
      </div>
    </section>
  </main>

  <script src="../scripts/admin-access-requests.ts"></script>
</AppShell>

