---
import AppShell from "../layouts/AppShell.astro";
import { getConcepts, getProjects, getTechnologies } from "../data";

const title = "Dashboard";

const [concepts, projects, technologies] = await Promise.all([getConcepts(), getProjects(), getTechnologies()]);
const conceptsCount = concepts.length;
const projectsCount = projects.length;
const technologiesCount = technologies.length;
---

<AppShell title={title}>
  <div data-requires-auth class="hidden"></div>
  <section class="space-y-6" data-dashboard-root>
    <div class="relative overflow-hidden rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 shadow-sm">
      <div class="absolute inset-0 bg-linear-to-br from-indigo-50 via-transparent to-rose-50 dark:from-indigo-500/10 dark:to-rose-500/10" />
      <div class="relative p-6 md:p-8 flex flex-col gap-5">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
          <div class="space-y-2">
            <p class="m-0 text-xs font-semibold tracking-wide text-gray-500 dark:text-gray-400 uppercase">
              Dashboard
            </p>
            <h1 class="m-0 text-3xl md:text-4xl font-semibold tracking-tight">
              <span data-i18n="dashboard.title">{title}</span>
            </h1>
            <p class="m-0 text-sm md:text-base text-gray-600 dark:text-gray-400 max-w-2xl" data-i18n="dashboard.subtitle">
              Proyectos y tecnologías primero: evidencias, portfolio y CV cuando quieras pulir el detalle.
            </p>
          </div>

          <div class="flex flex-wrap gap-2">
            <span class="text-xs px-2.5 py-1 rounded-full border border-indigo-200/80 dark:border-indigo-800/60 bg-indigo-50/70 dark:bg-indigo-950/40 whitespace-nowrap font-medium">
              <span data-dashboard-count-projects>{projectsCount}</span> proyectos
            </span>
            <span class="text-xs px-2.5 py-1 rounded-full border border-emerald-200/80 dark:border-emerald-800/60 bg-emerald-50/70 dark:bg-emerald-950/35 whitespace-nowrap font-medium">
              <span data-dashboard-count-technologies>{technologiesCount}</span> tecnologías
            </span>
            <span class="text-xs px-2.5 py-1 rounded-full border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 whitespace-nowrap">
              <span data-dashboard-count-concepts>{conceptsCount}</span> conceptos
            </span>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="/projects"
            class="inline-flex items-center justify-center rounded-lg bg-gray-900 dark:bg-gray-100 px-4 py-2.5 text-sm font-semibold text-white dark:text-gray-900 hover:bg-gray-800 dark:hover:bg-gray-200 no-underline"
          >
            <span data-i18n="dashboard.goProjects">Ir a Proyectos</span>
          </a>
          <a
            href="/technologies"
            class="inline-flex items-center justify-center rounded-lg border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 px-4 py-2.5 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900 no-underline"
          >
            <span data-i18n="dashboard.goTechnologies">Ir a Tecnologías</span>
          </a>
          <button
            type="button"
            data-guided-tour-start
            class="inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-700"
          >
            <span data-i18n="guidedTour.startButton">Recorrido guiado</span>
          </button>
          <a
            href="/portfolio"
            class="inline-flex items-center justify-center rounded-lg border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 px-4 py-2.5 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900 no-underline"
          >
            <span data-i18n="dashboard.goPortfolio">Ver portfolio</span>
          </a>
          <a
            href="/cv"
            class="inline-flex items-center justify-center rounded-lg border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 px-4 py-2.5 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900 no-underline"
          >
            <span data-i18n="nav.cv">CV</span>
          </a>
        </div>
      </div>
    </div>

    <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 p-5 shadow-sm">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div class="space-y-1">
          <p class="m-0 text-xs font-semibold tracking-wide text-gray-500 dark:text-gray-400 uppercase">
            Stack
          </p>
          <h2 class="m-0 text-lg font-semibold text-gray-900 dark:text-gray-100">
            Tecnologías más usadas
          </h2>
          <p class="m-0 text-sm text-gray-600 dark:text-gray-400 max-w-2xl">
            Prioridad: proyectos + qué tecnologías usas realmente. (También muestra pesos GitHub cuando hay importaciones.)
          </p>
        </div>
      </div>
      <div class="mt-4 rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/60 dark:bg-gray-950/40 p-4">
        <div data-dashboard-tech-usage class="space-y-2">
          <p class="m-0 text-sm text-gray-600 dark:text-gray-400" data-i18n="common.loading">Cargando…</p>
        </div>
      </div>
    </div>

    <div
      data-dashboard-study-root
      class="rounded-2xl border border-amber-200/70 dark:border-amber-900/40 bg-amber-50/35 dark:bg-amber-950/20 p-5 shadow-sm"
    >
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div class="space-y-1 min-w-0 flex-1">
          <p class="m-0 text-xs font-semibold tracking-wide text-amber-800/90 dark:text-amber-200/90 uppercase" data-i18n="dashboard.study.kicker">
            Estudio
          </p>
          <h2 class="m-0 text-lg font-semibold text-gray-900 dark:text-gray-100" data-i18n="dashboard.study.title">
            Tu espacio de preparación
          </h2>
          <p class="m-0 text-sm text-gray-600 dark:text-gray-400 max-w-2xl" data-i18n="dashboard.study.intro">
            Fuentes, fragmentos indexados y notas enlazadas a tu cuenta.
          </p>
          <p class="m-0 text-sm font-medium text-amber-900/90 dark:text-amber-100/90 truncate hidden" data-dashboard-study-goal></p>
        </div>
        <a
          href="/study"
          class="shrink-0 inline-flex items-center justify-center rounded-lg bg-amber-700 dark:bg-amber-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-amber-800 dark:hover:bg-amber-500 no-underline"
          data-i18n="dashboard.study.openStudy"
        >
          Ir a Estudio
        </a>
      </div>
      <div class="mt-4 grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-xl border border-amber-200/60 dark:border-amber-900/35 bg-white/70 dark:bg-gray-950/50 p-3">
          <p class="m-0 text-[11px] font-semibold text-gray-600 dark:text-gray-400 uppercase" data-i18n="dashboard.study.sources">
            Fuentes
          </p>
          <p class="m-0 text-xl font-bold tabular-nums text-gray-900 dark:text-gray-100" data-dashboard-study-sources>—</p>
        </div>
        <div class="rounded-xl border border-amber-200/60 dark:border-amber-900/35 bg-white/70 dark:bg-gray-950/50 p-3">
          <p class="m-0 text-[11px] font-semibold text-gray-600 dark:text-gray-400 uppercase" data-i18n="dashboard.study.chunks">
            Chunks
          </p>
          <p class="m-0 text-xl font-bold tabular-nums text-gray-900 dark:text-gray-100" data-dashboard-study-chunks>—</p>
        </div>
        <div class="rounded-xl border border-amber-200/60 dark:border-amber-900/35 bg-white/70 dark:bg-gray-950/50 p-3">
          <p class="m-0 text-[11px] font-semibold text-gray-600 dark:text-gray-400 uppercase" data-i18n="dashboard.study.notes">
            Notas
          </p>
          <p class="m-0 text-xl font-bold tabular-nums text-gray-900 dark:text-gray-100" data-dashboard-study-notes>—</p>
        </div>
        <div class="rounded-xl border border-amber-200/60 dark:border-amber-900/35 bg-white/70 dark:bg-gray-950/50 p-3">
          <p class="m-0 text-[11px] font-semibold text-gray-600 dark:text-gray-400 uppercase" data-i18n="dashboard.study.dossiers">
            Dossiers
          </p>
          <p class="m-0 text-xl font-bold tabular-nums text-gray-900 dark:text-gray-100" data-dashboard-study-dossiers>—</p>
        </div>
      </div>
      <p class="m-0 mt-3 text-sm text-gray-700 dark:text-gray-300 hidden" data-dashboard-study-curriculum-row>
        <span class="font-semibold" data-i18n="dashboard.study.curriculumKicker">Temario</span>
        <span class="mx-1">·</span>
        <span data-dashboard-study-curriculum>—</span>
      </p>
      <p class="m-0 mt-3 text-[11px] text-gray-500 dark:text-gray-400 hidden" data-dashboard-study-hint></p>
    </div>

    <div
      class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 p-5 shadow-sm space-y-4"
      data-dashboard-charts-root
    >
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div class="space-y-1">
          <p class="m-0 text-xs font-semibold tracking-wide text-violet-600 dark:text-violet-300 uppercase" data-i18n="dashboard.charts.sectionKicker">
            Visualizaciones
          </p>
          <h2 class="m-0 text-lg font-semibold text-gray-900 dark:text-gray-100" data-i18n="dashboard.charts.sectionTitle">
            Proyectos, stack y profundidad
          </h2>
          <p class="m-0 text-sm text-gray-600 dark:text-gray-400 max-w-2xl" data-i18n="dashboard.charts.sectionIntro">
            Prioridad en proyectos y tecnologías; conceptos en barras apiladas y cobertura (tu sesión; Supabase en vivo).
          </p>
        </div>
      </div>

      <div class="hidden mt-5 space-y-3" data-dashboard-kpi-root>
        <p class="m-0 text-xs font-semibold tracking-wide text-gray-500 dark:text-gray-400 uppercase" data-i18n="dashboard.kpi.kicker">
          Métricas
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
          <div class="rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/60 dark:bg-gray-950/40 p-3 min-h-22 flex flex-col justify-between">
            <p class="m-0 text-[11px] font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wide" data-i18n="dashboard.kpi.embedsLabel">Evidencias</p>
            <p class="m-0 text-2xl font-bold tabular-nums text-gray-900 dark:text-gray-100" data-dashboard-kpi-embeds>—</p>
            <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="dashboard.kpi.embedsSub">Total embeds</p>
          </div>
          <div class="rounded-xl border border-indigo-200/70 dark:border-indigo-900/50 bg-indigo-50/50 dark:bg-indigo-950/25 p-3 min-h-22 flex flex-col justify-between">
            <p class="m-0 text-[11px] font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wide" data-i18n="dashboard.kpi.projectsEvidenceLabel">Proyectos con evidencia</p>
            <p class="m-0 text-2xl font-bold tabular-nums text-gray-900 dark:text-gray-100" data-dashboard-kpi-projects-evidence>—</p>
            <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="dashboard.kpi.projectsEvidenceSub">Con al menos un embed</p>
          </div>
          <div class="rounded-xl border border-emerald-200/60 dark:border-emerald-900/40 bg-emerald-50/40 dark:bg-emerald-950/20 p-3 min-h-22 flex flex-col justify-between">
            <p class="m-0 text-[11px] font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wide" data-i18n="dashboard.kpi.emptyTechsLabel">Techs sin conceptos</p>
            <p class="m-0 text-2xl font-bold tabular-nums text-gray-900 dark:text-gray-100" data-dashboard-kpi-empty-techs>—</p>
            <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="dashboard.kpi.emptyTechsSub">A rellenar</p>
          </div>
          <div class="rounded-xl border border-violet-200/70 dark:border-violet-900/50 bg-violet-50/50 dark:bg-violet-950/25 p-3 min-h-22 flex flex-col justify-between">
            <p class="m-0 text-[11px] font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wide" data-i18n="dashboard.kpi.masteryLabel">Dominio</p>
            <p class="m-0 text-2xl font-bold tabular-nums text-gray-900 dark:text-gray-100"><span data-dashboard-kpi-mastery-pct>—</span><span class="text-base font-semibold">%</span></p>
            <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400 leading-snug" data-dashboard-kpi-mastery-sub>—</p>
          </div>
          <div class="rounded-xl border border-indigo-200/60 dark:border-indigo-900/40 bg-indigo-50/40 dark:bg-indigo-950/20 p-3 min-h-22 flex flex-col justify-between">
            <p class="m-0 text-[11px] font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wide" data-i18n="dashboard.kpi.linkedLabel">En proyectos</p>
            <p class="m-0 text-2xl font-bold tabular-nums text-gray-900 dark:text-gray-100" data-dashboard-kpi-concepts-linked>—</p>
            <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="dashboard.kpi.linkedSub">Conceptos vinculados</p>
          </div>
          <div class="rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/60 dark:bg-gray-950/40 p-3 min-h-22 flex flex-col justify-between col-span-2 sm:col-span-1 lg:col-span-1">
            <p class="m-0 text-[11px] font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wide" data-i18n="dashboard.kpi.soloLabel">Solo stack</p>
            <p class="m-0 text-2xl font-bold tabular-nums text-gray-900 dark:text-gray-100" data-dashboard-kpi-solo-concepts>—</p>
            <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="dashboard.kpi.soloSub">Sin proyecto</p>
          </div>
        </div>
        <div class="rounded-xl border border-dashed border-amber-200/80 dark:border-amber-800/50 bg-amber-50/20 dark:bg-amber-950/10 px-3 py-2">
          <p class="m-0 text-[11px] font-semibold text-amber-900/90 dark:text-amber-200/90 mb-1.5" data-i18n="dashboard.kpi.emptyTechsHint">Enlaces rápidos (hasta 5)</p>
          <div class="flex flex-wrap gap-1 min-h-6" data-dashboard-kpi-empty-techs-list></div>
        </div>
      </div>

      <p class="m-0 text-sm text-amber-800 dark:text-amber-200/90 hidden" data-dashboard-charts-empty></p>
      <div class="space-y-6" data-dashboard-charts-wrap>
        <div class="rounded-xl border border-indigo-200/60 dark:border-indigo-900/40 bg-white/60 dark:bg-gray-950/40 p-2 min-h-[300px]">
          <div class="h-[280px] w-full" data-dashboard-chart-projects></div>
        </div>
        <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
          <div class="xl:col-span-2 rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/60 dark:bg-gray-950/40 p-2 min-h-[300px]">
            <div class="h-[280px] w-full" data-dashboard-chart-treemap></div>
          </div>
          <div class="xl:col-span-1 rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/60 dark:bg-gray-950/40 p-2 min-h-[300px]">
            <div class="h-[280px] w-full" data-dashboard-chart-stacked></div>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl">
          <div class="rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/60 dark:bg-gray-950/40 p-2 min-h-[220px]">
            <div class="h-[200px] w-full" data-dashboard-chart-pie></div>
          </div>
          <div class="rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/60 dark:bg-gray-950/40 p-2 min-h-[220px]">
            <div class="h-[200px] w-full" data-dashboard-chart-gauge></div>
          </div>
        </div>
        <div class="rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/60 dark:bg-gray-950/40 p-2 min-h-[220px] max-w-3xl">
          <div class="h-[200px] w-full" data-dashboard-chart-coverage></div>
        </div>
      </div>
    </div>

    <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 p-5 shadow-sm">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div class="space-y-1">
          <p class="m-0 text-xs font-semibold tracking-wide text-gray-500 dark:text-gray-400 uppercase" data-i18n="dashboard.recent.sectionKicker">
            Actividad
          </p>
          <h2 class="m-0 text-lg font-semibold text-gray-900 dark:text-gray-100" data-i18n="dashboard.recent.sectionTitle">
            Actividad reciente
          </h2>
          <p class="m-0 text-sm text-gray-600 dark:text-gray-400 max-w-2xl" data-i18n="dashboard.recent.sectionIntro">
            Lo último que abriste en este dispositivo. Abre un proyecto o una tecnología para volver aquí al instante.
          </p>
        </div>
      </div>
      <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="rounded-xl border border-indigo-200/60 dark:border-indigo-900/40 bg-indigo-50/40 dark:bg-indigo-950/20 p-3">
          <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100" data-i18n="dashboard.recent.projectsTitle">
            Proyectos recientes
          </p>
          <div class="mt-2 space-y-0.5" data-dashboard-recent-projects>
            <p class="m-0 text-sm text-gray-600 dark:text-gray-400" data-i18n="common.loading">Cargando…</p>
          </div>
        </div>
        <div class="rounded-xl border border-emerald-200/60 dark:border-emerald-900/40 bg-emerald-50/40 dark:bg-emerald-950/20 p-3">
          <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100" data-i18n="dashboard.recent.techTitle">
            Tecnologías recientes
          </p>
          <div class="mt-2 space-y-0.5" data-dashboard-recent-tech>
            <p class="m-0 text-sm text-gray-600 dark:text-gray-400" data-i18n="common.loading">Cargando…</p>
          </div>
        </div>
      </div>
    </div>

    <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 p-5 shadow-sm">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div class="space-y-1">
          <p class="m-0 text-xs font-semibold tracking-wide text-gray-500 dark:text-gray-400 uppercase" data-i18n="dashboard.summaryKicker">Resumen</p>
          <p class="m-0 text-sm text-gray-600 dark:text-gray-400" data-i18n="dashboard.summaryIntro">
            Accesos rápidos a tus tecnologías y proyectos (los listados se hidratan con tu sesión en Supabase).
          </p>
        </div>
      </div>

      <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="rounded-xl border border-indigo-200/60 dark:border-indigo-900/40 bg-indigo-50/30 dark:bg-indigo-950/25 p-3">
            <div class="flex flex-col gap-0.5 sm:flex-row sm:items-center sm:justify-between">
              <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100" data-i18n="nav.projects">Proyectos</p>
              <span class="text-xs text-gray-500"><span data-dashboard-count-projects>{projectsCount}</span></span>
            </div>
            <p class="m-0 mt-1 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="dashboard.exploreProjectsHint">Primeros 8 por nombre (A–Z).</p>
            <div class="mt-2 space-y-1" data-dashboard-projects-list>
              <p class="m-0 text-sm text-gray-600 dark:text-gray-400" data-i18n="common.loading">Cargando…</p>
            </div>
          </div>

          <div class="rounded-xl border border-emerald-200/60 dark:border-emerald-900/40 bg-emerald-50/30 dark:bg-emerald-950/20 p-3">
            <div class="flex flex-col gap-0.5 sm:flex-row sm:items-center sm:justify-between">
              <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100" data-i18n="nav.technologies">Tecnologías</p>
              <span class="text-xs text-gray-500"><span data-dashboard-count-technologies>{technologiesCount}</span></span>
            </div>
            <p class="m-0 mt-1 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="dashboard.exploreTechHint">Primeras 8 por nombre (A–Z).</p>
            <div class="mt-2 space-y-1" data-dashboard-technologies-list>
              <p class="m-0 text-sm text-gray-600 dark:text-gray-400" data-i18n="common.loading">Cargando…</p>
            </div>
          </div>

          <div class="rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/60 dark:bg-gray-950/40 p-3">
            <div class="flex flex-col gap-0.5 sm:flex-row sm:items-center sm:justify-between">
              <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100" data-i18n="dashboard.conceptsCardTitle">Conceptos</p>
              <span class="text-xs text-gray-500"><span data-dashboard-count-concepts>{conceptsCount}</span></span>
            </div>
            <p class="m-0 mt-1 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="dashboard.conceptsHint">Se gestionan desde cada tecnología.</p>
            <div class="mt-2 space-y-1">
              <a
                class="block rounded-lg px-2 py-1.5 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900/40 no-underline"
                href="/technologies"
                data-i18n="dashboard.browseConceptsByTech"
              >
                Ver conceptos por tecnología
              </a>
            </div>
          </div>

          <div class="md:col-span-3 rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/60 dark:bg-gray-950/40 p-3">
            <div class="flex flex-wrap items-center justify-between gap-2">
              <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100" data-i18n="dashboard.usefulLinksTitle">Enlaces útiles</p>
            </div>
            <div class="mt-2 flex flex-wrap gap-2">
              <a
