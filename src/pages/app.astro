---
import AppShell from "../layouts/AppShell.astro";
import { concepts, projects } from "../data/mock";

const title = "Dashboard";

const conceptsCount = concepts.length;
const projectsCount = projects.length;
---

<AppShell title={title}>
  <section class="space-y-6">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <h1 class="m-0 text-2xl font-semibold">{title}</h1>
        <p class="mt-2 text-sm text-gray-600">
          Tu flujo principal: tecnologías → conceptos → proyectos → portfolio.
        </p>
      </div>

      <div class="flex flex-wrap gap-2">
        <span class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-900 whitespace-nowrap">
          {conceptsCount} conceptos
        </span>
        <span class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-900 whitespace-nowrap">
          {projectsCount} proyectos
        </span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <a
        href="/technologies"
        class="border border-gray-200 rounded-xl p-5 hover:bg-gray-50 transition-colors"
      >
        <h2 class="m-0 font-semibold">Ir a Tecnologías</h2>
        <p class="mt-2 text-sm text-gray-600">Crea conceptos dentro de cada tecnología.</p>
      </a>

      <a
        href="/projects"
        class="border border-gray-200 rounded-xl p-5 hover:bg-gray-50 transition-colors"
      >
        <h2 class="m-0 font-semibold">Ir a Proyectos</h2>
        <p class="mt-2 text-sm text-gray-600">Relaciona conceptos y publica tu portfolio.</p>
      </a>
    </div>

    <a
      href="/portfolio"
      class="inline-flex items-center justify-center rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-semibold text-gray-900 hover:bg-gray-50 no-underline"
    >
      Ver portfolio público
    </a>
  </section>
</AppShell>

