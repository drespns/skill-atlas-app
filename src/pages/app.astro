---
import AppShell from "../layouts/AppShell.astro";
import { dataSource, getConcepts, getProjects, getTechnologies } from "../data";

const title = "Dashboard";

const [concepts, projects, technologies] = await Promise.all([getConcepts(), getProjects(), getTechnologies()]);
const conceptsCount = concepts.length;
const projectsCount = projects.length;
const technologiesCount = technologies.length;
---

<AppShell title={title}>
  <div data-requires-auth class="hidden"></div>
  <section class="space-y-6">
    <div class="relative overflow-hidden rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 shadow-sm">
      <div class="absolute inset-0 bg-linear-to-br from-indigo-50 via-transparent to-rose-50 dark:from-indigo-500/10 dark:to-rose-500/10" />
      <div class="relative p-6 md:p-8 flex flex-col gap-5">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
          <div class="space-y-2">
            <p class="m-0 text-xs font-semibold tracking-wide text-gray-500 dark:text-gray-400 uppercase">
              Dashboard
            </p>
            <h1 class="m-0 text-3xl md:text-4xl font-semibold tracking-tight">
              <span data-i18n="dashboard.title">{title}</span>
            </h1>
            <p class="m-0 text-sm md:text-base text-gray-600 dark:text-gray-400 max-w-2xl">
              <span data-i18n="dashboard.subtitle">
                Tu flujo principal: tecnologías → conceptos → proyectos → portfolio.
              </span>
            </p>
          </div>

          <div class="flex flex-wrap gap-2">
            <span class="text-xs px-2.5 py-1 rounded-full border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 whitespace-nowrap">
              <span data-dashboard-count-concepts>{conceptsCount}</span> conceptos
            </span>
            <span class="text-xs px-2.5 py-1 rounded-full border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 whitespace-nowrap">
              <span data-dashboard-count-projects>{projectsCount}</span> proyectos
            </span>
            <span class="text-xs px-2.5 py-1 rounded-full border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 whitespace-nowrap">
              <span data-dashboard-count-technologies>{technologiesCount}</span> tecnologías
            </span>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="/projects"
            class="inline-flex items-center justify-center rounded-lg bg-gray-900 dark:bg-gray-100 px-4 py-2.5 text-sm font-semibold text-white dark:text-gray-900 hover:bg-gray-800 dark:hover:bg-gray-200 no-underline"
          >
            Ir a Proyectos
          </a>
          <a
            href="/technologies"
            class="inline-flex items-center justify-center rounded-lg border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 px-4 py-2.5 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900 no-underline"
          >
            Ir a Tecnologías
          </a>
          <button
            type="button"
            data-onboarding-start
            class="inline-flex items-center justify-center rounded-lg border border-indigo-200/80 dark:border-indigo-900/40 bg-indigo-50/60 dark:bg-indigo-950/20 px-4 py-2.5 text-sm font-semibold text-indigo-900 dark:text-indigo-100 hover:bg-indigo-50 dark:hover:bg-indigo-950/30"
          >
            <span data-i18n="onboarding.restart">Rehacer onboarding</span>
          </button>
          <button
            type="button"
            data-onboarding-v2-start
            class="inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-700"
          >
            <span data-i18n="onboardingV2.start">Onboarding avanzado</span>
          </button>
          <a
            href="/portfolio"
            class="inline-flex items-center justify-center rounded-lg border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 px-4 py-2.5 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900 no-underline"
          >
            Ver portfolio
          </a>
          <a
            href="/cv"
            class="inline-flex items-center justify-center rounded-lg border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 px-4 py-2.5 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900 no-underline"
          >
            <span data-i18n="nav.cv">CV</span>
          </a>
        </div>
      </div>
    </div>

    <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 p-5 shadow-sm">
        <div class="flex flex-wrap items-end justify-between gap-3">
          <div class="space-y-1">
            <p class="m-0 text-xs font-semibold tracking-wide text-gray-500 dark:text-gray-400 uppercase">Resumen</p>
            <p class="m-0 text-sm text-gray-600 dark:text-gray-400">
              Accesos rápidos a tus tecnologías y proyectos (se hidrata en cliente con tu sesión).
            </p>
          </div>
        </div>

        <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/60 dark:bg-gray-950/40 p-3">
            <div class="flex items-center justify-between gap-2">
              <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100">Tecnologías</p>
              <span class="text-xs text-gray-500"><span data-dashboard-count-technologies>{technologiesCount}</span></span>
            </div>
            <div class="mt-2 space-y-1" data-dashboard-technologies-list>
              <p class="m-0 text-sm text-gray-600 dark:text-gray-400">Cargando…</p>
            </div>
          </div>

          <div class="rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/60 dark:bg-gray-950/40 p-3">
            <div class="flex items-center justify-between gap-2">
              <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100">Conceptos</p>
              <span class="text-xs text-gray-500"><span data-dashboard-count-concepts>{conceptsCount}</span></span>
            </div>
            <div class="mt-2 space-y-1">
              <a
                class="block rounded-lg px-2 py-1.5 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900/40 no-underline"
                href="/technologies"
              >
                Ver conceptos por tecnología
              </a>
            </div>
          </div>

          <div class="rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/60 dark:bg-gray-950/40 p-3">
            <div class="flex items-center justify-between gap-2">
              <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100">Proyectos</p>
              <span class="text-xs text-gray-500"><span data-dashboard-count-projects>{projectsCount}</span></span>
            </div>
            <div class="mt-2 space-y-1" data-dashboard-projects-list>
              <p class="m-0 text-sm text-gray-600 dark:text-gray-400">Cargando…</p>
            </div>
          </div>

          <div class="md:col-span-3 rounded-xl border border-gray-200/70 dark:border-gray-800/80 bg-white/60 dark:bg-gray-950/40 p-3">
            <div class="flex items-center justify-between gap-2">
              <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100">Ajustes</p>
              <span class="text-xs text-gray-500">/settings</span>
            </div>
            <div class="mt-2 space-y-1">
              <a class="block rounded-lg px-2 py-1.5 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900/40 no-underline" href="/settings">
                Preferencias
              </a>
              <a class="block rounded-lg px-2 py-1.5 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900/40 no-underline" href="/settings#portfolio">
                Perfil público
              </a>
              <a class="block rounded-lg px-2 py-1.5 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900/40 no-underline" href="/settings#shortcuts">
                Shortcuts
              </a>
            </div>
          </div>
        </div>
    </div>

    <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 p-5 shadow-sm">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div class="space-y-1">
          <p class="m-0 text-xs font-semibold tracking-wide text-gray-500 dark:text-gray-400 uppercase" data-i18n="onboardingV1.kicker">
            Pasos recomendados (V1)
          </p>
          <p class="m-0 text-sm text-gray-600 dark:text-gray-400" data-i18n="onboardingV1.hint">
            Si lo saltaste o quieres repetir, lánzalo desde aquí.
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          <button type="button" data-onboarding-start class="inline-flex items-center justify-center rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm font-semibold hover:bg-gray-50 dark:hover:bg-gray-900">
            <span data-i18n="onboarding.restart">Rehacer onboarding</span>
          </button>
        </div>
      </div>
      <ol class="mt-4 space-y-2 text-sm text-gray-700 dark:text-gray-300">
        <li>1) <a class="font-semibold hover:underline" href="/technologies">Tecnologías</a> → crear una y añadir conceptos.</li>
        <li>2) <a class="font-semibold hover:underline" href="/projects">Proyectos</a> → crear uno y asociar tecnologías.</li>
        <li>3) <a class="font-semibold hover:underline" href="/settings">Ajustes</a> → nombre, bio, privacidad, stack.</li>
        <li>4) <a class="font-semibold hover:underline" href="/portfolio">Portfolio</a> → revisar y compartir.</li>
        <li>5) <a class="font-semibold hover:underline" href="/cv">CV</a> → preview + imprimir/PDF.</li>
      </ol>
    </div>
  </section>

  {dataSource === "supabase" ? <script src="../scripts/app-dashboard.ts"></script> : null}
  <script src="../scripts/app-onboarding.ts"></script>
</AppShell>

