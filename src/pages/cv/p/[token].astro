---
import AppShell from "../../../layouts/AppShell.astro";
export const prerender = false;

const token = Astro.params.token ?? "";
const title = "CV";
---

<AppShell title={title}>
  <div data-public-cv-page data-public-cv-token={token} class="space-y-6">
    <header class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between print:hidden">
      <div class="space-y-1">
        <p class="app-kicker m-0">
          <span data-i18n="cv.publicKicker">Documento público</span>
        </p>
        <h1 class="m-0 text-2xl font-semibold tracking-tight">
          <span data-i18n="cv.publicTitle">CV</span>
        </h1>
        <p class="m-0 max-w-2xl text-sm text-gray-600 dark:text-gray-400" data-i18n="cv.publicIntro">
          Enlace compartido. Si no existe o está desactivado, verás un aviso.
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <button
          type="button"
          data-public-cv-print
          class="inline-flex items-center justify-center rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 text-sm font-semibold hover:bg-gray-50 dark:hover:bg-gray-900"
        >
          <span data-i18n="cv.printOrPdf">Imprimir / PDF</span>
        </button>
      </div>
    </header>

    <p data-public-cv-loading class="m-0 text-sm text-gray-600 dark:text-gray-400">…</p>
    <p data-public-cv-error class="m-0 hidden text-sm text-red-600 dark:text-red-400"></p>

    <article
      data-public-cv-doc
      data-cv-document
      class="hidden rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 p-8 shadow-sm print:border-0 print:shadow-none print:p-0"
    >
      <div class="border-b border-gray-200/80 dark:border-gray-800 pb-6 print:border-gray-300" data-cv-weight="hero">
        <div class="flex items-start gap-5">
          <img
            data-public-cv-doc-photo
            alt=""
            class="hidden h-16 w-16 rounded-2xl border border-gray-200 dark:border-gray-800 object-cover"
            loading="lazy"
            referrerpolicy="no-referrer"
          />
          <div class="min-w-0 flex-1">
            <h2 data-public-cv-doc-name class="m-0 text-3xl font-semibold tracking-tight text-gray-900 dark:text-gray-100"></h2>
            <p data-public-cv-doc-headline class="mt-2 mb-0 text-base font-semibold text-gray-700 dark:text-gray-300"></p>
            <div data-public-cv-doc-contact class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-gray-600 dark:text-gray-300"></div>
            <p data-public-cv-doc-bio class="mt-4 mb-0 max-w-3xl text-base leading-relaxed text-gray-600 dark:text-gray-300"></p>
            <div data-public-cv-doc-helpstack class="mt-4 hidden flex-wrap gap-2"></div>
          </div>
        </div>
      </div>

      <div data-cv-doc-sections class="flex flex-col">
      <section class="pt-8 hidden" data-public-cv-doc-experience-section data-cv-section="experience" data-cv-weight="core">
        <h3 class="m-0 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400" data-i18n="cv.docExperienceHeading">
          Experiencia
        </h3>
        <div data-public-cv-doc-experience class="mt-4 space-y-7"></div>
      </section>

      <section class="pt-8 hidden" data-public-cv-doc-education-section data-cv-section="education" data-cv-weight="support">
        <h3 class="m-0 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400" data-i18n="cv.docEducationHeading">
          Educación
        </h3>
        <div data-public-cv-doc-education class="mt-4 space-y-6"></div>
      </section>

      <section class="pt-8 hidden" data-public-cv-doc-certifications-section data-cv-section="certifications" data-cv-weight="support">
        <h3 class="m-0 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400" data-i18n="cv.docCertificationsHeading">
          Certificaciones
        </h3>
        <div data-public-cv-doc-certifications class="mt-4 space-y-5"></div>
      </section>

      <section class="pt-8 hidden" data-public-cv-doc-languages-section data-cv-section="languages" data-cv-weight="support">
        <h3 class="m-0 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400" data-i18n="cv.docLanguagesHeading">
          Idiomas
        </h3>
        <div data-public-cv-doc-languages class="mt-4 space-y-3"></div>
      </section>

      <section class="pt-6" data-public-cv-doc-projects-section data-cv-section="projects" data-cv-weight="core">
        <h3 class="m-0 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400" data-i18n="cv.docProjectsHeading">
          Proyectos
        </h3>
        <div data-public-cv-doc-projects class="mt-4 space-y-8"></div>
      </section>

      <section class="pt-8 hidden" data-public-cv-doc-highlights-section data-cv-section="highlights" data-cv-weight="core">
        <h3 class="m-0 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400"         data-i18n="cv.docHighlightsHeading">
          Logros
        </h3>
        <ul data-public-cv-doc-highlights class="mt-4 space-y-2 pl-5 text-sm text-gray-700 dark:text-gray-300"></ul>
      </section>

      <section class="pt-8 hidden" data-public-cv-doc-cover-section data-cv-section="coverLetters" data-cv-weight="support">
        <h3 class="m-0 text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400" data-i18n="cv.docCoverHeading">
          Cartas de presentación
        </h3>
        <div data-public-cv-doc-cover-letters class="mt-4 space-y-5"></div>
      </section>
      </div>
    </article>
  </div>

  <script src="../../../scripts/cv/public-cv-by-token.ts"></script>
</AppShell>

