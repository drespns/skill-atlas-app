---
import "../styles/global.css";
import AppShell from "../layouts/AppShell.astro";
---

<AppShell title="SkillAtlas">
  <!-- Full-bleed background (main is max-w constrained): edge vignette + no hard “cut” at content width -->
  <section
    class="relative left-1/2 w-screen max-w-[100vw] -translate-x-1/2 overflow-x-clip text-gray-900 dark:text-gray-100"
  >
    <div class="pointer-events-none absolute inset-0 isolate min-h-full">
      <div class="absolute inset-0 -z-20 overflow-hidden">
        <div
          class="absolute -top-40 left-1/2 h-[28rem] w-[min(140vw,90rem)] max-w-none -translate-x-1/2 rounded-[100%] bg-linear-to-r from-indigo-300/38 via-sky-200/28 to-rose-300/32 dark:from-indigo-500/18 dark:via-sky-500/12 dark:to-rose-500/14 blur-3xl"
        />
        <div
          class="absolute -top-20 -right-[min(18vw,12rem)] h-80 w-[min(90vw,52rem)] rounded-[100%] bg-linear-to-bl from-violet-200/25 via-transparent to-transparent dark:from-violet-500/12 blur-3xl"
        />
        <div
          class="absolute -bottom-48 -left-[min(12vw,8rem)] h-[26rem] w-[min(95vw,56rem)] rounded-[100%] bg-linear-to-br from-emerald-200/28 via-transparent to-amber-200/22 dark:from-emerald-500/12 dark:to-amber-500/10 blur-3xl"
        />
      </div>
      <div class="landing-dots absolute inset-0 z-0" aria-hidden="true"></div>
      <div
        class="landing-edge-vignette pointer-events-none absolute inset-0 z-[1]"
        aria-hidden="true"
      ></div>
    </div>

    <div class="relative z-10 max-w-screen-2xl mx-auto py-10 md:py-14 space-y-18">
      <div class="grid lg:grid-cols-2 gap-12 xl:gap-16 items-start">
        <div class="space-y-8">
          <div class="inline-flex items-center gap-2 rounded-full border border-gray-200/80 dark:border-gray-800 bg-white/60 dark:bg-gray-950/50 px-3 py-1.5 text-xs text-gray-700 dark:text-gray-200">
            <span class="font-semibold" data-i18n="landing.heroBadgeBrand">SkillAtlas</span>
            <span class="text-gray-400">·</span>
            <span data-i18n="landing.heroBadgeTail">Solo por invitación</span>
          </div>

          <h1 class="m-0 text-4xl md:text-6xl font-semibold tracking-tight leading-[1.05]">
            <span data-i18n="landing.heroTitleBefore">Tu conocimiento técnico,</span>
            <br />
            <span
              class="text-transparent bg-clip-text bg-linear-to-r from-indigo-600 via-sky-500 to-rose-600 dark:from-indigo-300 dark:via-sky-300 dark:to-rose-300"
              data-i18n="landing.heroTitleGradient"
            >
              listo para convertirse en portfolio
            </span>.
          </h1>
          <p
            class="m-0 text-base md:text-xl text-gray-600 dark:text-gray-400 max-w-xl leading-relaxed"
            data-i18n="landing.heroSubtitle"
          >
            Captura tecnologías y conceptos, construye proyectos con evidencias y publica un portfolio
            que se lee en minutos.
          </p>

          <div class="flex flex-col sm:flex-row flex-wrap gap-3 pt-3">
            <a
              href="/request-access"
              data-landing-request-access
              class="inline-flex items-center justify-center rounded-lg bg-gray-900 dark:bg-gray-100 px-4 py-2.5 text-sm font-semibold text-white dark:text-gray-900 hover:bg-gray-800 dark:hover:bg-gray-200 no-underline"
            >
              <span data-i18n="landing.ctaRequest">Solicitar acceso</span>
            </a>
            <a
              href="/login"
              data-landing-have-invite
              class="inline-flex items-center justify-center rounded-lg border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 px-4 py-2.5 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900 no-underline"
            >
              <span data-i18n="landing.ctaLogin">Entrar (acceso privado)</span>
            </a>
            <a
              href="/app"
              data-landing-open-app
              class="hidden items-center justify-center rounded-lg bg-gray-900 dark:bg-gray-100 px-4 py-2.5 text-sm font-semibold text-white dark:text-gray-900 hover:bg-gray-800 dark:hover:bg-gray-200 no-underline shadow-sm"
            >
              <span data-i18n="landing.ctaOpenApp">Abrir app</span>
            </a>
            <a
              href="/demo"
              data-landing-demo
              class="inline-flex items-center justify-center rounded-lg border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/55 px-4 py-2.5 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900 no-underline"
            >
              <span data-i18n="landing.ctaDemo">Ver demo</span>
            </a>
            <a
              href="/pricing"
              class="inline-flex items-center justify-center rounded-lg border border-transparent px-4 py-2.5 text-sm font-semibold text-indigo-700 dark:text-indigo-300 hover:underline underline-offset-8 decoration-2 hover:decoration-4 no-underline"
            >
              <span data-i18n="nav.pricing">Precios</span>
            </a>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 pt-3">
            <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/75 dark:bg-gray-950/65 p-4 shadow-sm">
              <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100 flex items-center gap-2">
                <span class="inline-flex h-6 w-6 items-center justify-center rounded-lg bg-indigo-500/10 dark:bg-indigo-400/10 text-indigo-700 dark:text-indigo-300">T</span>
                <span data-i18n="landing.pillTechTitle">Tecnologías</span>
              </p>
              <p class="mt-2 mb-0 text-sm text-gray-600 dark:text-gray-400 leading-relaxed" data-i18n="landing.pillTechDesc">
                Tu mapa de stack.
              </p>
            </div>
            <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/75 dark:bg-gray-950/65 p-4 shadow-sm">
              <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100 flex items-center gap-2">
                <span class="inline-flex h-6 w-6 items-center justify-center rounded-lg bg-sky-500/10 dark:bg-sky-400/10 text-sky-700 dark:text-sky-300">C</span>
                <span data-i18n="landing.pillConceptTitle">Conceptos</span>
              </p>
              <p class="mt-2 mb-0 text-sm text-gray-600 dark:text-gray-400 leading-relaxed" data-i18n="landing.pillConceptDesc">
                Aprendizaje trazable.
              </p>
            </div>
            <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/75 dark:bg-gray-950/65 p-4 shadow-sm">
              <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100 flex items-center gap-2">
                <span class="inline-flex h-6 w-6 items-center justify-center rounded-lg bg-rose-500/10 dark:bg-rose-400/10 text-rose-700 dark:text-rose-300">E</span>
                <span data-i18n="landing.pillEvidenceTitle">Evidencias</span>
              </p>
              <p class="mt-2 mb-0 text-sm text-gray-600 dark:text-gray-400 leading-relaxed" data-i18n="landing.pillEvidenceDesc">
                Links + embeds, rápido.
              </p>
            </div>
          </div>

          <div class="pt-2 space-y-3 max-w-xl">
            <p class="m-0 text-sm text-gray-600 dark:text-gray-400" data-i18n="landing.noteEvidence">
              Pensado para que tu portfolio no dependa de “me acuerdo de todo”, sino de evidencias y una historia clara (rol + resultado).
            </p>
            <p class="m-0 text-sm text-gray-600 dark:text-gray-400" data-i18n="landing.noteInvite">
              Acceso por invitación mientras iteramos con calma hacia una v1 que merezca el nombre.
            </p>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-3 rounded-3xl bg-linear-to-br from-indigo-200/70 via-transparent to-rose-200/55 dark:from-indigo-500/15 dark:to-rose-500/12 blur-2xl" />
          <div class="relative rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/85 dark:bg-gray-950/85 shadow-sm overflow-hidden">
            <div class="px-5 py-4 border-b border-gray-200/80 dark:border-gray-800 flex items-center justify-between bg-white/60 dark:bg-gray-950/40 backdrop-blur">
              <div class="flex items-center gap-2">
                <div class="h-2.5 w-2.5 rounded-full bg-rose-400/80" />
                <div class="h-2.5 w-2.5 rounded-full bg-amber-300/80" />
                <div class="h-2.5 w-2.5 rounded-full bg-emerald-300/80" />
              </div>
              <span class="text-xs font-semibold text-gray-500 dark:text-gray-400" data-i18n="landing.previewLabel">Vista previa</span>
            </div>
            <div class="p-6 space-y-4">
              <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 p-4 bg-white/60 dark:bg-gray-950/40">
                <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100" data-i18n="landing.previewProjectTitle">
                  Proyecto · “Tableau Water Intake”
                </p>
                <p class="mt-2 mb-0 text-sm text-gray-600 dark:text-gray-400" data-i18n="landing.previewProjectBody">
                  Rol: data analyst · Resultado: dashboard público + insights accionables.
                </p>
                <div class="mt-3 flex flex-wrap gap-2">
                  <span class="text-[11px] px-2 py-1 rounded-full bg-gray-100 dark:bg-gray-900 text-gray-900 dark:text-gray-100">Tableau</span>
                  <span class="text-[11px] px-2 py-1 rounded-full bg-gray-100 dark:bg-gray-900 text-gray-900 dark:text-gray-100">SQL</span>
                  <span class="text-[11px] px-2 py-1 rounded-full bg-gray-100 dark:bg-gray-900 text-gray-900 dark:text-gray-100">Storytelling</span>
                </div>
              </div>
              <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 p-4 bg-white/60 dark:bg-gray-950/40">
                <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100" data-i18n="landing.previewEvidenceTitle">Evidencias</p>
                <div class="mt-3 grid grid-cols-1 gap-2">
                  <div class="rounded-lg border border-gray-200/80 dark:border-gray-800 bg-gray-50/60 dark:bg-gray-900/20 px-3 py-2">
                    <p class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100" data-i18n="landing.previewEmbedTitle">
                      Dashboard embebido
                    </p>
                    <p class="mt-1 mb-0 text-xs text-gray-600 dark:text-gray-400 truncate" data-i18n="landing.previewEmbedUrl">
                      tableau.com / vistas / …
                    </p>
                  </div>
                  <div class="rounded-lg border border-gray-200/80 dark:border-gray-800 bg-gray-50/60 dark:bg-gray-900/20 px-3 py-2">
                    <p class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100" data-i18n="landing.previewRepoTitle">Repositorio</p>
                    <p class="mt-1 mb-0 text-xs text-gray-600 dark:text-gray-400 truncate" data-i18n="landing.previewRepoUrl">github.com / …</p>
                  </div>
                </div>
              </div>
              <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 p-4 bg-white/60 dark:bg-gray-950/40">
                <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100" data-i18n="landing.previewPortfolioTitle">Portfolio</p>
                <p class="mt-2 mb-0 text-sm text-gray-600 dark:text-gray-400" data-i18n="landing.previewPortfolioBody">
                  Tarjetas claras, filtro por tecnología y evidencia principal destacada.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div
        class="rounded-2xl border border-amber-200/70 dark:border-amber-800/60 bg-linear-to-r from-amber-50/90 via-white/80 to-sky-50/70 dark:from-amber-950/35 dark:via-gray-950/40 dark:to-sky-950/25 px-5 py-4 shadow-sm"
      >
        <p class="m-0 text-sm font-medium text-amber-950/95 dark:text-amber-100/90 leading-relaxed" data-i18n="landing.devStrip">
          Parte del producto ya puedes usarlo con invitación; el resto está en el taller. Sin fechas mágicas ni humo.
        </p>
      </div>

      <div class="pt-10">
        <div class="h-px w-full bg-linear-to-r from-transparent via-gray-200/80 to-transparent dark:via-gray-800/80" />
      </div>

      <section class="rounded-3xl border border-gray-200/80 dark:border-gray-800 bg-white/55 dark:bg-gray-950/45 shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-gray-200/70 dark:border-gray-800/70 bg-white/60 dark:bg-gray-950/40 backdrop-blur flex flex-wrap items-end justify-between gap-3">
          <div class="space-y-1">
            <p class="m-0 text-xs font-semibold tracking-wide text-gray-500 dark:text-gray-400 uppercase" data-i18n="landing.flowKicker">Flujo</p>
            <h2 class="m-0 text-lg font-semibold" data-i18n="landing.flowTitle">Del proyecto al portfolio, con evidencias.</h2>
          </div>
          <p class="m-0 text-sm text-gray-600 dark:text-gray-400 max-w-xl" data-i18n="landing.flowSubtitle">
            Una relación visual: empieza pegando URLs, cuenta la historia y publica.
          </p>
        </div>

        <div class="relative p-6">
          <div class="pointer-events-none absolute inset-0">
            <svg viewBox="0 0 1200 260" class="w-full h-full" preserveAspectRatio="none" aria-hidden="true">
              <defs>
                <linearGradient id="flowStroke" x1="0" x2="1" y1="0" y2="0">
                  <stop offset="0%" stop-color="rgb(99 102 241)" stop-opacity="0.55" />
                  <stop offset="50%" stop-color="rgb(56 189 248)" stop-opacity="0.45" />
                  <stop offset="100%" stop-color="rgb(244 63 94)" stop-opacity="0.50" />
                </linearGradient>
                <filter id="flowBlur" x="-20%" y="-40%" width="140%" height="180%">
                  <feGaussianBlur stdDeviation="8" />
                </filter>
              </defs>
              <path
                d="M 120 150 C 280 60, 420 60, 560 150 S 840 240, 1080 140"
                stroke="url(#flowStroke)"
                stroke-width="6"
                fill="none"
                filter="url(#flowBlur)"
              />
              <path
                d="M 120 150 C 280 60, 420 60, 560 150 S 840 240, 1080 140"
                stroke="url(#flowStroke)"
                stroke-width="2.25"
                fill="none"
                opacity="0.9"
              />
            </svg>
          </div>

          <div class="relative grid md:grid-cols-3 gap-5">
            <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/75 dark:bg-gray-950/65 p-6 shadow-sm">
              <div class="flex items-start justify-between gap-3">
                <div class="space-y-1">
                  <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100" data-i18n="landing.flowCard1Title">Evidencias</p>
                  <p class="m-0 text-sm text-gray-600 dark:text-gray-400 leading-relaxed" data-i18n="landing.flowCard1Body">
                    Pega URLs y detectamos el tipo para embed o enlace en segundos.
                  </p>
                </div>
                <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-indigo-500/10 dark:bg-indigo-400/10 text-indigo-700 dark:text-indigo-300 border border-indigo-500/15 dark:border-indigo-400/15">
                  🔗
                </span>
              </div>
            </div>

            <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/75 dark:bg-gray-950/65 p-6 shadow-sm">
              <div class="flex items-start justify-between gap-3">
                <div class="space-y-1">
                  <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100" data-i18n="landing.flowCard2Title">Historia</p>
                  <p class="m-0 text-sm text-gray-600 dark:text-gray-400 leading-relaxed" data-i18n="landing.flowCard2Body">
                    Rol + resultado para que el proyecto se entienda sin contexto.
                  </p>
                </div>
                <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-sky-500/10 dark:bg-sky-400/10 text-sky-700 dark:text-sky-300 border border-sky-500/15 dark:border-sky-400/15">
                  ✍️
                </span>
              </div>
            </div>

            <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/75 dark:bg-gray-950/65 p-6 shadow-sm">
              <div class="flex items-start justify-between gap-3">
                <div class="space-y-1">
                  <p class="m-0 text-xs font-semibold text-gray-900 dark:text-gray-100" data-i18n="landing.flowCard3Title">Portfolio</p>
                  <p class="m-0 text-sm text-gray-600 dark:text-gray-400 leading-relaxed" data-i18n="landing.flowCard3Body">
                    Publica tarjetas limpias y filtrables cuando tú decidas.
                  </p>
                </div>
                <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-rose-500/10 dark:bg-rose-400/10 text-rose-700 dark:text-rose-300 border border-rose-500/15 dark:border-rose-400/15">
                  ✨
                </span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="rounded-3xl border border-indigo-200/50 dark:border-indigo-900/40 bg-white/55 dark:bg-gray-950/45 shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-gray-200/70 dark:border-gray-800/70 bg-linear-to-r from-indigo-50/50 via-white/60 to-transparent dark:from-indigo-950/30 dark:via-gray-950/50 dark:to-transparent backdrop-blur flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-end sm:justify-between">
          <div class="space-y-1 max-w-3xl">
            <p class="m-0 text-xs font-semibold tracking-wide text-indigo-600 dark:text-indigo-300 uppercase" data-i18n="landing.roadmapKicker">
              Hoja de ruta
            </p>
            <h2 class="m-0 text-xl md:text-2xl font-semibold text-gray-900 dark:text-gray-100" data-i18n="landing.roadmapTitle">
              Lo que viene — en construcción, con honestidad
            </h2>
            <p class="m-0 text-sm text-gray-600 dark:text-gray-400 leading-relaxed" data-i18n="landing.roadmapSubtitle">
              El orden es aproximado; lo importante es que sepas qué es real hoy y qué sigue en el taller.
            </p>
          </div>
        </div>
        <div class="p-6 grid sm:grid-cols-2 xl:grid-cols-3 gap-4">
          <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/80 dark:bg-gray-950/60 p-5 shadow-sm flex flex-col gap-3">
            <div class="flex items-start justify-between gap-3">
              <h3 class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100" data-i18n="landing.rmPricingTitle">Precios y planes</h3>
              <span
                class="shrink-0 rounded-full border border-amber-200/90 dark:border-amber-800/60 bg-amber-50/90 dark:bg-amber-950/40 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-amber-900 dark:text-amber-200"
                data-i18n="landing.badgePartial"
              >
                Parcial
              </span>
            </div>
            <p class="m-0 text-sm text-gray-600 dark:text-gray-400 leading-relaxed flex-1" data-i18n="landing.rmPricingBody">
              Página pública con tallaje orientativo y comparativa; cobrar de verdad llegará con condiciones claras.
            </p>
          </div>
          <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/80 dark:bg-gray-950/60 p-5 shadow-sm flex flex-col gap-3">
            <div class="flex items-start justify-between gap-3">
              <h3 class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100" data-i18n="landing.rmShareTitle">Portfolio por enlace</h3>
              <span
                class="shrink-0 rounded-full border border-indigo-200/80 dark:border-indigo-800/50 bg-indigo-50/80 dark:bg-indigo-950/35 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-indigo-900 dark:text-indigo-200"
                data-i18n="landing.badgeDev"
              >
                En desarrollo
              </span>
            </div>
            <p class="m-0 text-sm text-gray-600 dark:text-gray-400 leading-relaxed flex-1" data-i18n="landing.rmShareBody">
              Ruta con token, activar compartir desde perfil y lectura pública segura vía RPC.
            </p>
          </div>
          <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/80 dark:bg-gray-950/60 p-5 shadow-sm flex flex-col gap-3">
            <div class="flex items-start justify-between gap-3">
              <h3 class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100" data-i18n="landing.rmCvTitle">CV y exportación</h3>
              <span
                class="shrink-0 rounded-full border border-indigo-200/80 dark:border-indigo-800/50 bg-indigo-50/80 dark:bg-indigo-950/35 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-indigo-900 dark:text-indigo-200"
                data-i18n="landing.badgeDev"
              >
                En desarrollo
              </span>
            </div>
            <p class="m-0 text-sm text-gray-600 dark:text-gray-400 leading-relaxed flex-1" data-i18n="landing.rmCvBody">
              Privado por defecto, plantillas, PDF y enlace público opcional cuando quieras presumir.
            </p>
          </div>
          <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/80 dark:bg-gray-950/60 p-5 shadow-sm flex flex-col gap-3">
            <div class="flex items-start justify-between gap-3">
              <h3 class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100" data-i18n="landing.rmExportTitle">Salida profesional</h3>
              <span
                class="shrink-0 rounded-full border border-indigo-200/80 dark:border-indigo-800/50 bg-indigo-50/80 dark:bg-indigo-950/35 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-indigo-900 dark:text-indigo-200"
                data-i18n="landing.badgeDev"
              >
                En desarrollo
              </span>
            </div>
            <p class="m-0 text-sm text-gray-600 dark:text-gray-400 leading-relaxed flex-1" data-i18n="landing.rmExportBody">
              PDF de portfolio, previews ricos por proyecto y export estático cuando encaje.
            </p>
          </div>
          <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/80 dark:bg-gray-950/60 p-5 shadow-sm flex flex-col gap-3">
            <div class="flex items-start justify-between gap-3">
              <h3 class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100" data-i18n="landing.rmDailyTitle">Día a día en la app</h3>
              <span
                class="shrink-0 rounded-full border border-indigo-200/80 dark:border-indigo-800/50 bg-indigo-50/80 dark:bg-indigo-950/35 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-indigo-900 dark:text-indigo-200"
                data-i18n="landing.badgeDev"
              >
                En desarrollo
              </span>
            </div>
