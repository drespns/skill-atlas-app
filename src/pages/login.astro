---
import AppShell from "../layouts/AppShell.astro";

const title = "Entrar o activar cuenta";
---

<AppShell title={title}>
  <link slot="head" rel="prefetch" href="/static/earth/day.jpg" />
  <link slot="head" rel="prefetch" href="/static/earth/night.jpg" />
  <link slot="head" rel="prefetch" href="/static/earth/specularClouds.jpg" />

  <style is:global>
    /* Login page uses full-bleed layout (no main padding) */
    :root {
      --app-main-px: 0px;
      --app-main-py: 0px;
    }
  </style>

  <section
    class="w-full overflow-hidden"
    style="height: calc(100svh - var(--app-header-h, 0px));"
  >
    <div class="grid md:grid-cols-2 h-full min-h-0">
      <div class="flex items-center justify-center px-5 py-6 md:px-10 min-h-0 overflow-y-auto">
        <div class="w-full max-w-md rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/95 dark:bg-gray-950/90 backdrop-blur p-6 shadow-sm flex flex-col">
          <div class="space-y-3">
            <p class="m-0 text-[11px] font-semibold uppercase tracking-wide text-emerald-700 dark:text-emerald-400">
              Acceso por invitación
            </p>
            <h1 class="m-0 text-2xl font-semibold text-gray-900 dark:text-gray-100 leading-tight">
              Entrar o activar tu cuenta
            </h1>
            <p class="m-0 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
              SkillAtlas no tiene registro público: entras con <strong class="font-semibold text-gray-800 dark:text-gray-200">invitación</strong> (correo del administrador) o tras aprobar una solicitud.
              Puedes activar la cuenta <strong class="font-semibold text-gray-800 dark:text-gray-200">con GitHub, LinkedIn o con correo y contraseña</strong>: los tres son válidos; elige el que te hayan indicado o el que te resulte más cómodo si ya definiste contraseña en el enlace de invitación.
            </p>
          </div>

          <div class="mt-5 rounded-xl border border-gray-200/70 dark:border-gray-800 bg-gray-50/80 dark:bg-gray-900/40 px-3 py-2.5">
            <p class="m-0 text-xs text-gray-600 dark:text-gray-400 leading-snug">
              ¿Sin invitación?
              <a
                href="/request-access"
                class="font-semibold text-gray-900 dark:text-gray-100 underline decoration-gray-400/80 underline-offset-2 hover:decoration-gray-600 dark:hover:decoration-gray-500"
              >
                Solicitar acceso
              </a>
            </p>
          </div>

          <form data-auth-password-form class="mt-5 space-y-4 flex-1">
            <div class="space-y-1">
              <p class="m-0 text-xs font-semibold text-gray-800 dark:text-gray-200">Correo y contraseña</p>
              <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400">
                Usa esto si en la invitación te pidieron crear contraseña o ya entraste antes con email. Si prefieres enlace mágico u OAuth, usa GitHub o LinkedIn abajo; no hace falta quedarte con un solo método para siempre.
              </p>
            </div>
            <div class="space-y-2">
              <label for="login-email" class="text-sm font-medium text-gray-800 dark:text-gray-200">
                Correo
              </label>
              <input
                id="login-email"
                data-auth-email
                type="email"
                autocomplete="username"
                placeholder="tu-email@dominio.com"
                required
                class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2.5 text-sm outline-none focus:ring-2 focus:ring-gray-400/30 dark:focus:ring-gray-600/40"
              />
            </div>

            <div class="space-y-2">
              <label for="login-password" class="text-sm font-medium text-gray-800 dark:text-gray-200">
                Contraseña
              </label>
              <input
                id="login-password"
                data-auth-password
                type="password"
                autocomplete="current-password"
                minlength={6}
                required
                class="w-full rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2.5 text-sm outline-none focus:ring-2 focus:ring-gray-400/30 dark:focus:ring-gray-600/40"
              />
            </div>

            <div class="flex flex-col sm:flex-row gap-2 pt-1">
              <button
                type="submit"
                data-auth-sign-in
                class="inline-flex flex-1 items-center justify-center rounded-lg bg-gray-900 dark:bg-gray-100 px-4 py-2.5 text-sm font-semibold text-white dark:text-gray-900 hover:bg-gray-800 dark:hover:bg-gray-200"
              >
                Entrar
              </button>
            </div>

            <p data-auth-feedback class="text-sm text-gray-600 dark:text-gray-400 m-0 pt-1"></p>
          </form>

          <div class="pt-2">
            <div class="space-y-1 mb-3">
              <p class="m-0 text-xs font-semibold text-gray-800 dark:text-gray-200">GitHub o LinkedIn (activar o entrar)</p>
              <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400 leading-snug">
                La primera vez tras invitación, el proveedor enlaza la cuenta al mismo email que tenga tu perfil en GitHub/LinkedIn (idealmente el de la invitación). Las siguientes veces es solo iniciar sesión.
              </p>
            </div>
            <div class="flex items-center gap-3">
              <div class="h-px flex-1 bg-gray-200 dark:bg-gray-800"></div>
              <span class="text-xs text-gray-500 dark:text-gray-400 whitespace-nowrap">GitHub · LinkedIn</span>
              <div class="h-px flex-1 bg-gray-200 dark:bg-gray-800"></div>
            </div>

            <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-2">
              <button
                type="button"
                data-auth-oauth-provider="github"
                class="inline-flex items-center justify-center gap-2 rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2.5 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900"
              >
                <img src="/icons/login/github-icon-light.svg" alt="" class="h-4 w-4" />
                Continuar con GitHub
              </button>
              <button
                type="button"
                data-auth-oauth-provider="linkedin_oidc"
                class="inline-flex items-center justify-center gap-2 rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2.5 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900"
              >
                <img src="/icons/login/linkedin-icon.svg" alt="" class="h-4 w-4" />
                Continuar con LinkedIn
              </button>
            </div>
          </div>
        </div>
      </div>

      <div
        class="hidden md:block relative min-h-0 overflow-hidden bg-linear-to-br from-slate-100 via-gray-50 to-white dark:from-gray-950 dark:via-gray-900 dark:to-gray-950"
      >
        <div data-login-earth class="absolute inset-0 z-0"></div>
        <div
          class="absolute inset-0 z-10 pointer-events-none bg-linear-to-l from-transparent via-transparent to-white/92 dark:to-gray-950/92"
          aria-hidden="true"
        ></div>
      </div>
    </div>
  </section>

  <script src="../scripts/login/login-auth.ts"></script>
  <script src="../scripts/login/login-earth.ts"></script>
</AppShell>
