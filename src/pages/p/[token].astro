---
export const prerender = false;

import AppShell from "../../layouts/AppShell.astro";
import { supabaseAnonRpc } from "../../lib/server-supabase-rpc";

const raw = Astro.params.token;
const token = typeof raw === "string" ? raw : "";

type RpcPayload = { displayName?: string; bio?: string } | null;

const rpcRes = token ? await supabaseAnonRpc<RpcPayload>("skillatlas_portfolio_by_share_token", { p_token: token }) : null;
const payload = rpcRes?.data ?? null;

const displayName = (payload as any)?.displayName ? String((payload as any).displayName).trim() : "";
const bio = (payload as any)?.bio ? String((payload as any).bio).trim() : "";
const ogTitle = displayName ? `${displayName} · Portfolio` : "Portfolio · SkillAtlas";
const ogDesc = (bio || "Portfolio público en SkillAtlas.").slice(0, 200);
const origin = Astro.url.origin || "";
const ogImage = token ? `${origin}/og/portfolio.svg?token=${encodeURIComponent(token)}` : `${origin}/og/portfolio.svg`;
---

<AppShell title="Portfolio">
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDesc} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDesc} />
    <meta name="twitter:image" content={ogImage} />
  </Fragment>
  <section class="space-y-6 max-w-screen-2xl mx-auto" data-public-portfolio-page data-public-portfolio-token={token}>
    <header class="space-y-3">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div class="flex items-start gap-4 min-w-0">
          <div class="shrink-0">
            <div
              class="h-14 w-14 rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/50 overflow-hidden"
            >
              <img
                data-public-portfolio-avatar
                alt=""
                class="h-full w-full object-cover hidden"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
              <div
                data-public-portfolio-avatar-fallback
                class="h-full w-full grid place-items-center text-xs font-semibold text-gray-500 dark:text-gray-400"
              >
                ·
              </div>
            </div>
          </div>
          <div class="space-y-1 min-w-0">
            <h1 class="m-0 text-2xl font-semibold text-gray-900 dark:text-gray-100" data-public-portfolio-name>
              Portfolio
            </h1>
            <p class="text-sm text-gray-600 dark:text-gray-400" data-public-portfolio-bio></p>
            <div
              data-public-portfolio-help-wrap
              class="hidden mt-3 pt-3 border-t border-gray-200 dark:border-gray-800 max-w-2xl"
            >
              <p
                class="text-xs font-semibold text-gray-500 dark:text-gray-400 mb-2"
                data-i18n="portfolio.helpStackLabel"
              >
                Stack de ayuda
              </p>
              <div data-public-portfolio-help-stack class="flex flex-wrap gap-2"></div>
            </div>
          </div>
        </div>

        <form class="flex flex-wrap items-center gap-2 hidden" data-public-portfolio-filter aria-hidden="true">
          <label class="text-xs font-semibold text-gray-700 dark:text-gray-200" data-i18n="portfolio.filterByTechnology">
            Tecnología
          </label>
          <select
            data-public-portfolio-tech-select
            class="rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-2.5 py-2 text-sm"
          >
          </select>
        </form>
      </div>
    </header>

    <div data-public-portfolio-mount class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 min-h-32">
      <div class="col-span-full border border-gray-200/80 dark:border-gray-800 rounded-xl p-5 bg-white/60 dark:bg-gray-950/40">
        <p class="m-0 text-sm text-gray-600 dark:text-gray-400" data-public-portfolio-loading>
          Cargando portfolio…
        </p>
      </div>
    </div>
  </section>

  <script src="../../scripts/public-portfolio-by-token.ts"></script>
</AppShell>

