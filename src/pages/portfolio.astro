---
import AppShell from "../layouts/AppShell.astro";
import EmbedCard from "../components/EmbedCard.astro";
import { getTechnologyIconSrc } from "../config/icons";
import { dataSource, profile, getProjects, getTechnologyById } from "../data";

const title = "Portfolio";
const projects = await getProjects();

const portfolioCards = await Promise.all(
  projects.map(async (project) => ({
    project,
    technologyNames: (
      await Promise.all(project.technologyIds.map(async (id) => (await getTechnologyById(id))?.name))
    )
      .filter((x): x is string => Boolean(x))
      .map((x) => x.trim())
      .filter(Boolean),
  })),
);

const allTechnologyNames = Array.from(
  new Set(portfolioCards.flatMap((c) => c.technologyNames)),
).sort((a, b) => a.localeCompare(b));

const selectedTechnologies = Astro.url.searchParams.getAll("tech").map((t) => t.trim()).filter(Boolean);

const filteredCards =
  selectedTechnologies.length === 0
    ? portfolioCards
    : portfolioCards.filter((c) => selectedTechnologies.some((t) => c.technologyNames.includes(t)));

function techHue(name: string) {
  let h = 0;
  for (let i = 0; i < name.length; i++) h = (h * 31 + name.charCodeAt(i)) >>> 0;
  return h % 360;
}
---

<AppShell title={title}>
  <div data-requires-auth class="hidden"></div>
  <section
    class="space-y-6"
    data-portfolio-preview-page
    data-public-presentation-theme="classic"
    data-public-presentation-density="comfortable"
    data-public-header-style="default"
  >
    <header class="space-y-3">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div class="flex items-start gap-4 min-w-0">
          <div class="shrink-0">
            <div class="h-14 w-14 rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/50 overflow-hidden">
              <img
                data-portfolio-avatar
                alt=""
                class="h-full w-full object-cover hidden"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
              <div data-portfolio-avatar-fallback class="h-full w-full grid place-items-center text-xs font-semibold text-gray-500 dark:text-gray-400">
                SA
              </div>
            </div>
          </div>
        <div class="space-y-1 min-w-0">
          <h1 class="m-0 text-2xl font-semibold text-gray-900 dark:text-gray-100" data-portfolio-public-name>
            {profile.publicName}
          </h1>
          <p class="text-sm text-gray-600 dark:text-gray-400" data-portfolio-public-bio>{profile.bio}</p>
          <div data-portfolio-help-wrap class="hidden mt-3 pt-3 border-t border-gray-200 dark:border-gray-800 max-w-2xl">
            <p
              class="text-xs font-semibold text-gray-500 dark:text-gray-400 mb-2"
              data-i18n="portfolio.helpStackLabel"
            >
              Stack de ayuda
            </p>
            <div data-portfolio-help-stack class="flex flex-wrap gap-2"></div>
          </div>
        </div>
        </div>

        <div class="flex flex-wrap items-end gap-3">
          {dataSource === "supabase" ? (
            <div class="relative flex flex-col gap-1" data-portfolio-tech-filter-root>
              <span class="text-xs font-semibold text-gray-700 dark:text-gray-200" data-i18n="portfolio.filterByTechnology">
                Tecnología
              </span>
              <button
                type="button"
                data-portfolio-tech-trigger
                class="inline-flex min-w-[12rem] max-w-[min(18rem,85vw)] items-center justify-between gap-2 rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-2.5 py-2 text-sm hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors text-left"
                aria-expanded="false"
                aria-haspopup="dialog"
                aria-controls="portfolio-tech-filter-panel"
              >
                <span data-portfolio-tech-summary class="truncate font-medium text-gray-900 dark:text-gray-100">—</span>
                <span class="shrink-0 text-gray-500 dark:text-gray-400" aria-hidden="true">▾</span>
              </button>
              <div
                id="portfolio-tech-filter-panel"
                data-portfolio-tech-panel
                hidden
                class="absolute left-0 top-full z-40 mt-1 w-[min(20rem,calc(100vw-2rem))] rounded-xl border border-gray-200/90 dark:border-gray-700/90 bg-white dark:bg-gray-950 p-3 shadow-xl ring-1 ring-black/5 dark:ring-white/10"
                role="dialog"
                aria-label="Filtro por tecnología"
              >
                <p class="m-0 mb-2 text-[11px] text-gray-500 dark:text-gray-400" data-i18n="portfolio.techFilterHint">
                  Marca una o varias; «Aplicar» actualiza la URL.
                </p>
                <div data-portfolio-tech-checkboxes class="max-h-52 space-y-1 overflow-y-auto pr-1"></div>
                <div class="mt-3 flex flex-wrap gap-2 border-t border-gray-200 dark:border-gray-800 pt-3">
                  <button
                    type="button"
                    data-portfolio-tech-clear
                    class="inline-flex flex-1 min-w-[5rem] justify-center rounded-lg border border-gray-200 dark:border-gray-700 px-2.5 py-2 text-xs font-semibold hover:bg-gray-50 dark:hover:bg-gray-900"
                  >
                    <span data-i18n="portfolio.techFilterClear">Todas</span>
                  </button>
                  <button
                    type="button"
                    data-portfolio-tech-apply
                    class="inline-flex flex-[2] min-w-[6rem] justify-center rounded-lg bg-gray-900 dark:bg-gray-100 px-2.5 py-2 text-xs font-semibold text-white dark:text-gray-900 hover:opacity-90"
                  >
                    <span data-i18n="portfolio.techFilterApply">Aplicar</span>
                  </button>
                </div>
              </div>
            </div>
          ) : (
            <form method="get" class="flex flex-col gap-2" data-portfolio-filter-mock>
              <span class="text-xs font-semibold text-gray-700 dark:text-gray-200" data-i18n="portfolio.filterByTechnology">
                Tecnología
              </span>
              <details class="group min-w-[12rem] max-w-[min(20rem,85vw)] rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 open:shadow-md">
                <summary class="cursor-pointer list-none px-2.5 py-2 text-sm font-medium text-gray-900 dark:text-gray-100 marker:content-none [&::-webkit-details-marker]:hidden flex items-center justify-between gap-2">
                  <span class="truncate">
                    {selectedTechnologies.length === 0 ? (
                      <span data-i18n="portfolio.allTechnologies">Todas</span>
                    ) : selectedTechnologies.length === 1 ? (
                      selectedTechnologies[0]
                    ) : (
                      <span data-i18n="portfolio.techFilterSummaryN" data-i18n-args={JSON.stringify({ count: selectedTechnologies.length })}>
                        {selectedTechnologies.length} tecnologías
                      </span>
                    )}
                  </span>
                  <span class="shrink-0 text-gray-500 group-open:rotate-180 transition-transform" aria-hidden="true">▾</span>
                </summary>
                <div class="space-y-2 border-t border-gray-200 dark:border-gray-800 px-2.5 py-3">
                  {allTechnologyNames.length === 0 ? (
                    <p class="m-0 text-xs text-gray-500 dark:text-gray-400" data-i18n="portfolio.techFilterNoTechs">
                      Sin tecnologías en el portfolio (mock).
                    </p>
                  ) : (
                    <>
                      <div class="max-h-52 space-y-1.5 overflow-y-auto">
                        {allTechnologyNames.map((name) => (
                          <label class="flex cursor-pointer items-center gap-2 rounded-lg px-2 py-1 text-sm hover:bg-gray-50 dark:hover:bg-gray-900/60 select-none">
                            <input
                              type="checkbox"
                              name="tech"
                              value={name}
                              checked={selectedTechnologies.includes(name)}
                              class="rounded border-gray-300 dark:border-gray-600"
                            />
                            <span>{name}</span>
                          </label>
                        ))}
                      </div>
                      <button
                        type="submit"
                        class="mt-2 w-full rounded-lg bg-gray-900 dark:bg-gray-100 px-3 py-2 text-sm font-semibold text-white dark:text-gray-900 hover:opacity-90"
                      >
                        <span data-i18n="portfolio.techFilterApply">Aplicar</span>
                      </button>
                    </>
                  )}
                </div>
              </details>
            </form>
          )}
          {dataSource === "supabase" ? (
            <span data-portfolio-loading class="self-end text-[11px] text-gray-500 dark:text-gray-400 pb-1">
              Cargando proyectos con tu sesión…
            </span>
          ) : null}
        </div>
      </div>
    </header>

    {dataSource === "supabase" ? (
      <div
        data-portfolio-preview-controls
        class="hidden flex flex-wrap items-end gap-4 rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/50 dark:bg-gray-950/40 px-4 py-3 sm:px-5 sm:py-4"
      >
        <div class="space-y-1 min-w-[10rem]">
          <label class="text-xs font-semibold text-gray-700 dark:text-gray-200" data-i18n="portfolio.public.viewLabel">
            Vista
          </label>
          <div data-select-popover data-placeholder="Selecciona…">
            <select data-portfolio-preview-layout class="sr-only" data-select-native></select>
            <div class="relative">
              <button
                type="button"
                class="w-full max-w-[14rem] min-h-10 inline-flex items-center justify-between gap-2 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 px-3 py-2 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900"
                data-select-trigger
                aria-haspopup="listbox"
                aria-expanded="false"
              >
                <span class="min-w-0 truncate" data-select-trigger-label>Selecciona…</span>
                <span class="shrink-0 opacity-70" aria-hidden="true">▾</span>
              </button>
              <div
                class="hidden absolute left-0 right-0 top-full z-30 mt-1 overflow-hidden rounded-xl border border-gray-200/80 dark:border-gray-800 bg-white/95 dark:bg-gray-950/95 shadow-lg"
                data-select-panel
              >
                <ul
                  class="max-h-72 overflow-auto m-0 p-0 divide-y divide-gray-200/70 dark:divide-gray-800"
                  data-select-list
                  role="listbox"
                ></ul>
              </div>
            </div>
          </div>
        </div>
        <div class="space-y-1 min-w-[10rem]">
          <label class="text-xs font-semibold text-gray-700 dark:text-gray-200" data-i18n="portfolio.public.embedCapLabel">
            Evidencias por proyecto
          </label>
          <div data-select-popover data-placeholder="Selecciona…">
            <select data-portfolio-preview-embed-cap class="sr-only" data-select-native></select>
            <div class="relative">
              <button
                type="button"
                class="w-full max-w-[14rem] min-h-10 inline-flex items-center justify-between gap-2 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 px-3 py-2 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900"
                data-select-trigger
                aria-haspopup="listbox"
                aria-expanded="false"
              >
                <span class="min-w-0 truncate" data-select-trigger-label>Selecciona…</span>
                <span class="shrink-0 opacity-70" aria-hidden="true">▾</span>
              </button>
              <div
                class="hidden absolute left-0 right-0 top-full z-30 mt-1 overflow-hidden rounded-xl border border-gray-200/80 dark:border-gray-800 bg-white/95 dark:bg-gray-950/95 shadow-lg"
                data-select-panel
              >
                <ul
                  class="max-h-72 overflow-auto m-0 p-0 divide-y divide-gray-200/70 dark:divide-gray-800"
                  data-select-list
                  role="listbox"
                ></ul>
              </div>
            </div>
          </div>
        </div>
        <label class="flex cursor-pointer items-center gap-2 pt-5 sm:pt-6">
          <input type="checkbox" data-portfolio-preview-reduced-motion class="rounded border-gray-300 dark:border-gray-600" />
          <span class="text-sm text-gray-800 dark:text-gray-200" data-i18n="portfolio.public.reducedMotionLabel">
            Menos animación
          </span>
        </label>
      </div>
    ) : null}

    {dataSource === "supabase" ? (
      <div data-portfolio-projects-csr-mount class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6 min-h-32">
        <div class="col-span-full border border-gray-200/80 dark:border-gray-800 rounded-xl p-5 bg-white/60 dark:bg-gray-950/40">
          <p class="m-0 text-sm text-gray-600 dark:text-gray-400">Cargando proyectos del portfolio…</p>
        </div>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {filteredCards.map(({ project, technologyNames }) => {
          const publicEmbeds = project.embeds.filter((e) => e.showInPublic !== false);
          const primaryEmbed = publicEmbeds[0];
          const hasStory = Boolean(project.role?.trim() || project.outcome?.trim());

          return (
            <article class="border border-gray-200/80 dark:border-gray-800 rounded-xl p-4 bg-white dark:bg-gray-950 flex flex-col gap-3 shadow-sm">
              <div>
                <h2 class="m-0 text-base font-semibold">{project.title}</h2>
                <p class="mt-1 text-sm text-gray-600 dark:text-gray-300">{project.description}</p>
                {hasStory ? (
                  <dl class="mt-2 grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs">
                    <div>
                      <dt class="font-semibold text-gray-800 dark:text-gray-200">Rol</dt>
                      <dd class="m-0 mt-1 text-gray-600 dark:text-gray-400">
                        {project.role?.trim() ? project.role : "—"}
                      </dd>
                    </div>
                    <div>
                      <dt class="font-semibold text-gray-800 dark:text-gray-200">Resultado / impacto</dt>
                      <dd class="m-0 mt-1 text-gray-600 dark:text-gray-400 line-clamp-2">
                        {project.outcome?.trim() ? project.outcome : "—"}
                      </dd>
                    </div>
                  </dl>
                ) : null}
              </div>

              <div class="flex flex-wrap gap-2">
                {technologyNames.map((name) => {
                  const iconSrc = getTechnologyIconSrc({ id: name.toLowerCase(), name });
                  const hue = techHue(name);
                  return (
                    <span
                      class="inline-flex items-center gap-1.5 text-xs px-2.5 py-1 rounded-full border whitespace-nowrap"
                      style={`border-color:hsl(${hue} 72% 52% / 0.35); background-color:hsl(${hue} 72% 52% / 0.10)`}
                    >
                      {iconSrc ? <img src={iconSrc} alt="" class="h-4 w-4 object-contain" loading="lazy" /> : null}
                      <span class="font-semibold text-gray-900 dark:text-gray-100">{name}</span>
                    </span>
                  );
                })}
              </div>

              {primaryEmbed ? (
                <EmbedCard embed={primaryEmbed} />
              ) : (
                <div class="border border-gray-200 rounded-xl p-4 text-sm text-gray-600">
                  <span data-i18n="portfolio.noEmbedsMock">Sin embeds en el mock.</span>
                </div>
              )}

              <div class="flex items-center justify-end">
                <a
                  href={`/projects/${project.id}`}
                  class="inline-flex items-center justify-center rounded-lg bg-gray-900 px-3 py-2 text-sm font-semibold text-white hover:bg-gray-800 no-underline"
                >
                  <span data-i18n="common.viewDetail">Ver detalle</span>
                </a>
              </div>
            </article>
          );
        })}
      </div>
    )}
  </section>

  <script src="../scripts/portfolio/portfolio-public-profile.ts"></script>
  {dataSource === "supabase" ? (
    <script src="../scripts/portfolio/portfolio-projects.ts"></script>
  ) : null}
</AppShell>

