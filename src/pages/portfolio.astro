---
import AppShell from "../layouts/AppShell.astro";
import EmbedCard from "../components/EmbedCard.astro";
import { dataSource, profile, getProjects, getTechnologyById } from "../data";

const title = "Portfolio";
const projects = await getProjects();

const portfolioCards = await Promise.all(
  projects.map(async (project) => ({
    project,
    technologyNames: (
      await Promise.all(project.technologyIds.map(async (id) => (await getTechnologyById(id))?.name))
    )
      .filter((x): x is string => Boolean(x))
      .map((x) => x.trim())
      .filter(Boolean),
  })),
);

const allTechnologyNames = Array.from(
  new Set(portfolioCards.flatMap((c) => c.technologyNames)),
).sort((a, b) => a.localeCompare(b));

const selectedTechnology =
  typeof Astro.url.searchParams.get("tech") === "string"
    ? String(Astro.url.searchParams.get("tech"))
    : "";

const filteredCards =
  selectedTechnology && selectedTechnology !== "all"
    ? portfolioCards.filter((c) => c.technologyNames.includes(selectedTechnology))
    : portfolioCards;
---

<AppShell title={title}>
  <section class="space-y-6">
    <header class="space-y-3">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <div class="space-y-1">
          <h1 class="m-0 text-2xl font-semibold">{profile.publicName}</h1>
          <p class="text-sm text-gray-600">{profile.bio}</p>
        </div>

        <form class="flex flex-wrap items-center gap-2">
          <label
            class="text-xs font-semibold text-gray-700 dark:text-gray-200"
            for="portfolio-tech"
            data-i18n="portfolio.filterByTechnology"
          >
            Tecnología
          </label>
          <select
            id="portfolio-tech"
            name="tech"
            class="rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-2.5 py-2 text-sm hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors"
          >
            <option
              value="all"
              selected={selectedTechnology === "" || selectedTechnology === "all"}
              data-i18n="portfolio.allTechnologies"
            >
              Todas
            </option>
            {allTechnologyNames.map((name) => (
              <option value={name} selected={selectedTechnology === name}>
                {name}
              </option>
            ))}
          </select>
          <button
            type="submit"
            class="inline-flex items-center justify-center rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-3 py-2 text-sm font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors"
          >
            <span data-i18n="portfolio.filter">Filtrar</span>
          </button>
        </form>
      </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {filteredCards.map(({ project, technologyNames }) => {
        const primaryEmbed = project.embeds[0];

        return (
          <article class="border border-gray-200/80 dark:border-gray-800 rounded-xl p-4 bg-white dark:bg-gray-950 flex flex-col gap-3 shadow-sm">
            <div>
              <h2 class="m-0 text-base font-semibold">{project.title}</h2>
              <p class="mt-1 text-sm text-gray-600 dark:text-gray-300">{project.description}</p>
            </div>

            <div class="flex flex-wrap gap-2">
              {technologyNames.map((name) => (
                <span
                  class="text-xs px-2 py-1 rounded-full bg-gray-100 dark:bg-gray-900 text-gray-900 dark:text-gray-100 whitespace-nowrap"
                >
                  {name}
                </span>
              ))}
            </div>

            {primaryEmbed ? (
              <EmbedCard embed={primaryEmbed} />
            ) : (
              <div class="border border-gray-200 rounded-xl p-4 text-sm text-gray-600">
                <span data-i18n="portfolio.noEmbedsMock">Sin embeds en el mock.</span>
              </div>
            )}

            <div class="flex items-center justify-end">
              <a
                href={
                  dataSource === "supabase"
                    ? `/projects/view?project=${encodeURIComponent(project.id)}`
                    : `/projects/${project.id}`
                }
                class="inline-flex items-center justify-center rounded-lg bg-gray-900 px-3 py-2 text-sm font-semibold text-white hover:bg-gray-800 no-underline"
              >
                <span data-i18n="common.viewDetail">Ver detalle</span>
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </section>
</AppShell>

