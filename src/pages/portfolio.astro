---
import AppShell from "../layouts/AppShell.astro";
import EmbedCard from "../components/EmbedCard.astro";
import { profile, projects, getTechnologyById } from "../data/mock";

const title = "Portfolio";
---

<AppShell title={title}>
  <section class="space-y-6">
    <header class="space-y-2">
      <h1 class="m-0 text-2xl font-semibold">{profile.publicName}</h1>
      <p class="text-sm text-gray-600">{profile.bio}</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {projects.map((project) => {
        const technologyNames = project.technologyIds
          .map((id) => getTechnologyById(id)?.name)
          .filter((x): x is string => Boolean(x));

        const primaryEmbed = project.embeds[0];

        return (
          <article class="border border-gray-200 rounded-xl p-4 flex flex-col gap-3">
            <div>
              <h2 class="m-0 text-base font-semibold">{project.title}</h2>
              <p class="mt-1 text-sm text-gray-600">{project.description}</p>
            </div>

            <div class="flex flex-wrap gap-2">
              {technologyNames.map((name) => (
                <span
                  class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-900 whitespace-nowrap"
                >
                  {name}
                </span>
              ))}
            </div>

            {primaryEmbed ? (
              <EmbedCard embed={primaryEmbed} />
            ) : (
              <div class="border border-gray-200 rounded-xl p-4 text-sm text-gray-600">
                Sin embeds en el mock.
              </div>
            )}

            <div class="flex items-center justify-end">
              <a
                href={`/projects/${project.id}`}
                class="inline-flex items-center justify-center rounded-lg bg-gray-900 px-3 py-2 text-sm font-semibold text-white hover:bg-gray-800 no-underline"
              >
                Ver detalle
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </section>
</AppShell>

