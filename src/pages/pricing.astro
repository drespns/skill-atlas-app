---
import AppShell from "../layouts/AppShell.astro";
import PricingPageDecor from "../components/pricing/PricingPageDecor.astro";
import PricingWarningBanner from "../components/pricing/PricingWarningBanner.astro";
import PricingHero from "../components/pricing/PricingHero.astro";
import PricingCards from "../components/pricing/PricingCards.astro";
import PricingCompareTable from "../components/pricing/PricingCompareTable.astro";
import PricingFaqs from "../components/pricing/PricingFaqs.astro";
import PricingBottomCta from "../components/pricing/PricingBottomCta.astro";

const title = "Precios · SkillAtlas";
---

<AppShell title={title}>
  <div class="relative overflow-hidden" data-pricing-page>
    <PricingPageDecor />

    <div class="max-w-7xl mx-auto space-y-14 md:space-y-20">
      <PricingWarningBanner />
      <PricingHero />
      <PricingCards />
      <PricingCompareTable />
      <PricingFaqs />
      <PricingBottomCta />
    </div>
  </div>

  <script src="../scripts/pricing/pricing-billing.ts"></script>
</AppShell>
