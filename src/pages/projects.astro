---
import AppShell from "../layouts/AppShell.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { dataSource, getProjects, getTechnologyById } from "../data";

const title = "Proyectos";

const projects = await getProjects();

const projectCards = await Promise.all(
  projects.map(async (project) => ({
  project,
  technologyNames: (
    await Promise.all(project.technologyIds.map(async (id) => (await getTechnologyById(id))?.name))
  ).filter((x): x is string => Boolean(x)),
})),
);
---

<AppShell title={title}>
  <div data-requires-auth class="hidden"></div>
  <section class="space-y-5">
    <header class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <h1 class="m-0 text-2xl font-semibold">
          <span data-i18n="projects.title">{title}</span>
        </h1>
        <p class="mt-2 text-sm text-gray-600">
          <span data-i18n="projects.subtitle">Proyectos conectados con tecnologías y conceptos.</span>
        </p>
      </div>

      <div class="flex flex-wrap gap-2">
        {dataSource === "supabase" ? (
          <div
            data-view-toggle
            data-scope="projects"
            class="hidden sm:inline-flex items-center rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 p-1"
          >
            <button
              type="button"
              data-view="cards"
              aria-pressed="true"
              class="px-2 py-1 rounded-md text-xs font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 app-accent-ring"
              data-i18n="settings.prefs.viewCards"
            >
              Cards
            </button>
            <button
              type="button"
              data-view="list"
              aria-pressed="false"
              class="px-2 py-1 rounded-md text-xs font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 app-accent-ring"
              data-i18n="settings.prefs.viewList"
            >
              Lista
            </button>
          </div>
        ) : null}

        <span
          class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-900 whitespace-nowrap"
          data-projects-count
        >
          {dataSource === "supabase" ? "…" : `${projects.length} proyectos`}
        </span>
      </div>
    </header>

    {dataSource === "supabase" ? (
      <form
        data-project-form
        class="border border-gray-200 dark:border-gray-800 rounded-xl p-4 bg-white dark:bg-gray-950 space-y-3"
      >
        <p class="m-0 text-sm font-semibold">
          <span data-i18n="projects.newProject">Nuevo proyecto</span>
        </p>
        <div class="grid grid-cols-1 gap-2">
          <input
            name="title"
            type="text"
            placeholder="Título del proyecto"
            data-i18n="projects.projectTitlePlaceholder"
            data-i18n-attr="placeholder"
            class="border border-gray-200 dark:border-gray-800 rounded-lg px-3 py-2 bg-white dark:bg-gray-950"
            required
          />
          <textarea
            name="description"
            rows={3}
            placeholder="Descripción breve"
            data-i18n="projects.projectDescPlaceholder"
            data-i18n-attr="placeholder"
            class="border border-gray-200 dark:border-gray-800 rounded-lg px-3 py-2 bg-white dark:bg-gray-950"
          />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            <label class="flex flex-col gap-1 text-xs font-semibold text-gray-700 dark:text-gray-300">
              <span data-i18n="projects.editStatusLabel">Estado</span>
              <div data-select-popover data-placeholder="En proceso">
                <select name="status" class="sr-only" data-select-native>
                <option value="draft" data-i18n="projects.statusDraft">Borrador</option>
                <option value="in_progress" selected data-i18n="projects.statusInProgress">En proceso</option>
                <option value="portfolio_visible" data-i18n="projects.statusPortfolioVisible">Visible en portfolio</option>
                <option value="archived" data-i18n="projects.statusArchived">Archivado</option>
                </select>
                <div class="relative">
                  <button
                    type="button"
                    class="w-full inline-flex items-center justify-between gap-2 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 px-3 py-2.5 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900"
                    data-select-trigger
                    aria-haspopup="listbox"
                    aria-expanded="false"
                  >
                    <span class="min-w-0 truncate" data-select-trigger-label>En proceso</span>
                    <span class="shrink-0 opacity-70" aria-hidden="true">▾</span>
                  </button>
                  <div
                    class="hidden absolute left-0 right-0 top-full z-30 mt-1 overflow-hidden rounded-xl border border-gray-200/80 dark:border-gray-800 bg-white/95 dark:bg-gray-950/95 shadow-lg"
                    data-select-panel
                  >
                    <ul
                      class="max-h-72 overflow-auto m-0 p-0 divide-y divide-gray-200/70 dark:divide-gray-800"
                      data-select-list
                      role="listbox"
                    ></ul>
                  </div>
                </div>
              </div>
              <p
                class="m-0 mt-1 text-[11px] font-normal text-gray-500 dark:text-gray-400 leading-snug max-w-prose"
                data-i18n="projects.statusWorkflowHint"
              ></p>
            </label>
            <label class="flex flex-col gap-1 text-xs font-semibold text-gray-700 dark:text-gray-300">
              <span data-i18n="projects.editTagsLabel">Etiquetas</span>
              <input
                name="tags"
                type="text"
                data-i18n="projects.editTagsPlaceholder"
                data-i18n-attr="placeholder"
                class="border border-gray-200 dark:border-gray-800 rounded-lg px-3 py-2 bg-white dark:bg-gray-950 text-sm font-normal"
                placeholder="master, trabajo, personal…"
              />
            </label>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            <label class="flex flex-col gap-1 text-xs font-semibold text-gray-700 dark:text-gray-300">
              <span data-i18n="projects.editDateStartLabel">Inicio</span>
              <input
                name="date_start"
                type="date"
                class="border border-gray-200 dark:border-gray-800 rounded-lg px-3 py-2 bg-white dark:bg-gray-950 text-sm font-normal"
              />
            </label>
            <label class="flex flex-col gap-1 text-xs font-semibold text-gray-700 dark:text-gray-300">
              <span data-i18n="projects.editDateEndLabel">Fin</span>
              <input
                name="date_end"
                type="date"
                class="border border-gray-200 dark:border-gray-800 rounded-lg px-3 py-2 bg-white dark:bg-gray-950 text-sm font-normal"
              />
            </label>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
            <input
              name="role"
              type="text"
              data-i18n="projects.newFormRolePlaceholder"
              data-i18n-attr="placeholder"
              placeholder="Rol (opcional)"
              class="border border-gray-200 dark:border-gray-800 rounded-lg px-3 py-2 bg-white dark:bg-gray-950"
            />
            <input
              name="outcome"
              type="text"
              data-i18n="projects.newFormOutcomePlaceholder"
              data-i18n-attr="placeholder"
              placeholder="Resultado / impacto (opcional)"
              class="border border-gray-200 dark:border-gray-800 rounded-lg px-3 py-2 bg-white dark:bg-gray-950"
            />
          </div>
          <div class="flex flex-wrap items-center gap-3">
            <button
              type="submit"
              class="inline-flex items-center justify-center rounded-lg bg-gray-900 dark:bg-gray-100 px-3 py-2 text-sm font-semibold text-white dark:text-gray-900 hover:bg-gray-800 dark:hover:bg-gray-200"
            >
              <span data-i18n="projects.saveProject">Guardar proyecto</span>
            </button>
            <button
              type="submit"
              data-project-save-open="1"
              class="inline-flex items-center justify-center rounded-lg border border-gray-300 dark:border-gray-700 px-3 py-2 text-sm font-semibold text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900"
            >
              <span data-i18n="projects.saveProjectAndOpen">Guardar e ir a detalles</span>
            </button>
            <p data-project-feedback class="text-sm text-gray-600 m-0 basis-full sm:basis-auto"></p>
          </div>
        </div>
      </form>
    ) : null}

    {dataSource === "supabase" ? (
      <div
        data-projects-csr-mount
        class="grid grid-cols-1 md:grid-cols-2 gap-4 min-h-32"
      >
        <p class="text-sm text-gray-600 col-span-full m-0">Cargando proyectos…</p>
      </div>
    ) : projectCards.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {projectCards.map(({ project, technologyNames }) => (
          <ProjectCard project={project} technologyNames={technologyNames} />
        ))}
      </div>
    ) : (
      <div class="border border-gray-200 rounded-xl p-5 bg-gray-50">
        <p class="m-0 font-semibold">
          <span data-i18n="projects.emptyTitle">Aún no tienes proyectos.</span>
        </p>
        <p class="mt-2 text-sm text-gray-600">
          <span data-i18n="projects.emptyBody">Crea tu primer proyecto desde aquí.</span>
        </p>
      </div>
    )}
  </section>

  {dataSource === "supabase" ? (
    <script src="../scripts/projects/projects.ts"></script>
  ) : null}
  {dataSource === "supabase" ? <script src="../scripts/core/view-toggle.ts"></script> : null}
</AppShell>

