---
import AppShell from "../layouts/AppShell.astro";
import ProjectCard from "../components/ProjectCard.astro";
import projectsScriptUrl from "../scripts/projects.ts?url";
import viewToggleScriptUrl from "../scripts/view-toggle.ts?url";
import { dataSource, getProjects, getTechnologyById } from "../data";

const title = "Proyectos";

const projects = await getProjects();

const projectCards = await Promise.all(
  projects.map(async (project) => ({
  project,
  technologyNames: (
    await Promise.all(project.technologyIds.map(async (id) => (await getTechnologyById(id))?.name))
  ).filter((x): x is string => Boolean(x)),
})),
);
---

<AppShell title={title}>
  <section class="space-y-5">
    <header class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <h1 class="m-0 text-2xl font-semibold">
          <span data-i18n="projects.title">{title}</span>
        </h1>
        <p class="mt-2 text-sm text-gray-600">
          <span data-i18n="projects.subtitle">Proyectos conectados con tecnologías y conceptos.</span>
        </p>
      </div>

      <div class="flex flex-wrap gap-2">
        {dataSource === "supabase" ? (
          <div
            data-view-toggle
            data-scope="projects"
            class="hidden sm:inline-flex items-center rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 p-1"
          >
            <button
              type="button"
              data-view="cards"
              aria-pressed="true"
              class="px-2 py-1 rounded-md text-xs font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 app-accent-ring"
              data-i18n="settings.prefs.viewCards"
            >
              Cards
            </button>
            <button
              type="button"
              data-view="list"
              aria-pressed="false"
              class="px-2 py-1 rounded-md text-xs font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 app-accent-ring"
              data-i18n="settings.prefs.viewList"
            >
              Lista
            </button>
          </div>
        ) : null}

        <span
          class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-900 whitespace-nowrap"
          data-projects-count
        >
          {dataSource === "supabase" ? "…" : `${projects.length} proyectos`}
        </span>
      </div>
    </header>

    {dataSource === "supabase" ? (
      <form
        data-project-form
        class="border border-gray-200 dark:border-gray-800 rounded-xl p-4 bg-white dark:bg-gray-950 space-y-3"
      >
        <p class="m-0 text-sm font-semibold">
          <span data-i18n="projects.newProject">Nuevo proyecto</span>
        </p>
        <div class="grid grid-cols-1 gap-2">
          <input
            name="title"
            type="text"
            placeholder="Título del proyecto"
            data-i18n="projects.projectTitlePlaceholder"
            data-i18n-attr="placeholder"
            class="border border-gray-200 dark:border-gray-800 rounded-lg px-3 py-2 bg-white dark:bg-gray-950"
            required
          />
          <textarea
            name="description"
            rows={3}
            placeholder="Descripción breve"
            data-i18n="projects.projectDescPlaceholder"
            data-i18n-attr="placeholder"
            class="border border-gray-200 dark:border-gray-800 rounded-lg px-3 py-2 bg-white dark:bg-gray-950"
          />
          <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
            <input
              name="role"
              type="text"
              placeholder="Rol (opcional)"
              class="border border-gray-200 dark:border-gray-800 rounded-lg px-3 py-2 bg-white dark:bg-gray-950"
            />
            <input
              name="outcome"
              type="text"
              placeholder="Resultado / impacto (opcional)"
              class="border border-gray-200 dark:border-gray-800 rounded-lg px-3 py-2 bg-white dark:bg-gray-950"
            />
          </div>
          <div class="flex items-center gap-3">
            <button
              type="submit"
              class="inline-flex items-center justify-center rounded-lg bg-gray-900 dark:bg-gray-100 px-3 py-2 text-sm font-semibold text-white dark:text-gray-900 hover:bg-gray-800 dark:hover:bg-gray-200"
            >
              <span data-i18n="projects.saveProject">Guardar proyecto</span>
            </button>
            <p data-project-feedback class="text-sm text-gray-600 m-0"></p>
          </div>
        </div>
      </form>
    ) : null}

    {dataSource === "supabase" ? (
      <div
        data-projects-csr-mount
        class="grid grid-cols-1 md:grid-cols-2 gap-4 min-h-32"
      >
        <p class="text-sm text-gray-600 col-span-full m-0">Cargando proyectos…</p>
      </div>
    ) : projectCards.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {projectCards.map(({ project, technologyNames }) => (
          <ProjectCard project={project} technologyNames={technologyNames} />
        ))}
      </div>
    ) : (
      <div class="border border-gray-200 rounded-xl p-5 bg-gray-50">
        <p class="m-0 font-semibold">
          <span data-i18n="projects.emptyTitle">Aún no tienes proyectos.</span>
        </p>
        <p class="mt-2 text-sm text-gray-600">
          <span data-i18n="projects.emptyBody">En el MVP puedes empezar desde aquí.</span>
        </p>
      </div>
    )}
  </section>

  {dataSource === "supabase" ? (
    <script type="module" src={projectsScriptUrl}></script>
  ) : null}
  {dataSource === "supabase" ? <script type="module" src={viewToggleScriptUrl}></script> : null}
</AppShell>

