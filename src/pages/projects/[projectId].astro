---
import AppShell from "../../layouts/AppShell.astro";
import ProgressBadge from "../../components/ProgressBadge.astro";
import EmbedCard from "../../components/EmbedCard.astro";
import { getConceptById, getProjectById, getTechnologyById, projects } from "../../data";

export async function getStaticPaths() {
  return projects.map((p) => ({
    params: { projectId: p.id },
  }));
}

const { projectId } = Astro.params;
const project = getProjectById(String(projectId));

const title = project?.title ?? "Proyecto";
---

<AppShell title={title}>
  {project ? (
    <section class="space-y-6">
      <header class="space-y-3">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
          <div>
            <h1 class="m-0 text-2xl font-semibold">{project.title}</h1>
            <p class="mt-2 text-sm text-gray-600">{project.description}</p>
          </div>

          <div class="flex flex-wrap gap-2">
            {project.technologyIds.map((id) => {
              const name = getTechnologyById(id)?.name ?? id;
              return (
                <span
                  class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-900 whitespace-nowrap"
                >
                  {name}
                </span>
              );
            })}
          </div>
        </div>

        <a
          href="/projects"
          class="inline-flex items-center justify-center rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-semibold text-gray-900 hover:bg-gray-50 no-underline"
        >
          Volver a Proyectos
        </a>
      </header>

      <section class="space-y-3">
        <h2 class="m-0 text-base font-semibold">Embeds</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {project.embeds.map((embed) => (
            <EmbedCard embed={embed} />
          ))}
        </div>
      </section>

      <section class="space-y-3">
        <h2 class="m-0 text-base font-semibold">Conceptos relacionados</h2>
        <div class="space-y-2">
          {project.conceptIds.map((id) => {
            const concept = getConceptById(id);
            if (!concept) return null;

            const techName =
              getTechnologyById(concept.technologyId)?.name ?? concept.technologyId;

            return (
              <div
                class="flex items-start justify-between gap-4 border border-gray-200 rounded-xl p-3"
              >
                <div class="min-w-0">
                  <p class="m-0 font-semibold">{concept.title}</p>
                  <p class="mt-1 text-xs text-gray-600">{techName}</p>
                </div>
                <ProgressBadge progress={concept.progress} />
              </div>
            );
          })}
        </div>
      </section>
    </section>
  ) : (
    <section class="space-y-3">
      <h1 class="m-0 text-2xl font-semibold">{title}</h1>
      <p class="text-sm text-gray-600">No se encontró el proyecto.</p>
      <a
        href="/projects"
        class="inline-flex items-center justify-center rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-semibold text-gray-900 hover:bg-gray-50 no-underline"
      >
        Volver a Proyectos
      </a>
    </section>
  )}
</AppShell>

