---
import AppShell from "../layouts/AppShell.astro";
import { profile } from "../data";
import settingsAuthScriptUrl from "../scripts/settings-auth.ts?url";

const title = "Ajustes";
---

<AppShell title={title}>
  <section class="max-w-lg space-y-6">
    <header class="space-y-2">
      <h1 class="m-0 text-2xl font-semibold">
        <span data-i18n="settings.title">{title}</span>
      </h1>
      <p class="text-sm text-gray-600 dark:text-gray-400">
        <span data-i18n="settings.subtitle">En el MVP, estos datos son de ejemplo (read-only).</span>
      </p>
    </header>

    <div class="space-y-4">
      <section
        class="rounded-xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 p-5 shadow-sm space-y-4"
      >
        <div class="flex items-center justify-between gap-3">
          <h2 class="m-0 text-base font-semibold">
            <span data-i18n="settings.auth.sectionTitle">Cuenta</span>
          </h2>
          <span
            data-auth-status
            class="text-xs px-2 py-1 rounded-full bg-amber-100 text-amber-800 dark:bg-amber-950/50 dark:text-amber-200"
          >
            <span data-auth-status-active class="hidden" data-i18n="settings.auth.sessionActive">Sesión activa</span>
            <span data-auth-status-inactive data-i18n="settings.auth.noSession">Sin sesión</span>
          </span>
        </div>

        <p class="m-0 text-sm text-gray-600 dark:text-gray-400">
          <span data-i18n="settings.auth.currentUser">Usuario actual</span>:
          <strong data-auth-user-email class="text-gray-900 dark:text-gray-100">-</strong>
        </p>

        <div data-auth-no-session class="pt-2 space-y-3 hidden">
          <p class="m-0 text-sm text-amber-700 dark:text-amber-300">
            Inicia sesión para acceder a Ajustes.
          </p>
          <a
            href="/login"
            class="inline-flex items-center justify-center rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/30 px-3 py-2 text-sm font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors no-underline"
          >
            Ir a Login
          </a>
        </div>

        <div class="flex flex-wrap items-center gap-2 pt-1 border-t border-gray-100 dark:border-gray-800">
          <button
            type="button"
            data-auth-refresh
            class="inline-flex items-center justify-center rounded-lg border border-gray-200 dark:border-gray-800 px-3 py-2 text-sm font-semibold hover:bg-gray-50 dark:hover:bg-gray-900"
          >
            <span data-i18n="settings.auth.refresh">Refrescar estado</span>
          </button>
          <button
            type="button"
            data-auth-logout
            class="inline-flex items-center justify-center rounded-lg border border-red-200 dark:border-red-900/50 text-red-700 dark:text-red-300 px-3 py-2 text-sm font-semibold hover:bg-red-50 dark:hover:bg-red-950/30"
          >
            <span data-i18n="settings.auth.logout">Cerrar sesión</span>
          </button>
        </div>

        <p data-auth-feedback class="text-sm text-gray-600 dark:text-gray-400 m-0"></p>
      </section>

      <div class="space-y-2">
        <label class="text-sm font-semibold" data-i18n="settings.publicName">Nombre público</label>
        <input
          disabled
          value={profile.publicName}
          class="w-full border border-gray-200 dark:border-gray-800 rounded-lg px-3 py-2 bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100"
        />
      </div>

      <div class="space-y-2">
        <label class="text-sm font-semibold" data-i18n="settings.publicBio">Bio pública</label>
        <textarea
          disabled
          rows={4}
          value={profile.bio}
          class="w-full border border-gray-200 dark:border-gray-800 rounded-lg px-3 py-2 bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100"
        />
      </div>
    </div>
  </section>

  <script type="module" src={settingsAuthScriptUrl}></script>
</AppShell>
