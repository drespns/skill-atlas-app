---
import AppShell from "../layouts/AppShell.astro";
import SettingsPageHeader from "../components/settings/SettingsPageHeader.astro";
import SettingsSessionChrome from "../components/settings/SettingsSessionChrome.astro";
import SettingsClassicSidebar from "../components/settings/SettingsClassicSidebar.astro";
import SettingsClassicPanels from "../components/settings/SettingsClassicPanels.astro";
import { profile } from "../data";

const title = "Ajustes";

const kbd =
  "inline-flex items-center rounded border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 px-1.5 py-0.5 text-[11px] font-mono font-semibold text-gray-800 dark:text-gray-200 shadow-sm";
---

<AppShell title={title}>
  <div data-requires-auth class="hidden"></div>
  <section class="max-w-7xl mx-auto space-y-8" data-settings-page-root>
    <SettingsPageHeader title={title} />
    <SettingsSessionChrome />

    <div
      class="rounded-xl border border-gray-200/80 dark:border-[#30363d] bg-[#f6f8fa] dark:bg-[#0d1117] shadow-sm overflow-hidden motion-safe:transition-shadow motion-safe:duration-300 dark:shadow-black/30"
    >
      <div data-settings-classic-row class="flex flex-col lg:flex-row gap-0">
        <SettingsClassicSidebar />
        <SettingsClassicPanels kbd={kbd} profile={profile} />
      </div>
    </div>
  </section>

  <script src="../scripts/settings/settings-auth.ts"></script>
  <script src="../scripts/settings/settings-prefs.ts"></script>
  <script src="../scripts/settings/settings-classic-ui.ts"></script>
  <script src="../scripts/settings/settings-profile.ts"></script>
  <script src="../scripts/settings/settings-qa.ts"></script>
</AppShell>
