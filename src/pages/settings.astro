---
import AppShell from "../layouts/AppShell.astro";
import { profile } from "../data";
import settingsAuthScriptUrl from "../scripts/settings-auth.ts?url";

const title = "Ajustes";
---

<AppShell title={title}>
  <section class="max-w-2xl space-y-6">
    <header class="space-y-2">
      <h1 class="m-0 text-2xl font-semibold">
        <span data-i18n="settings.title">{title}</span>
      </h1>
      <p class="text-sm text-gray-600">
        <span data-i18n="settings.subtitle">En el MVP, estos datos son de ejemplo (read-only).</span>
      </p>
    </header>

    <div class="space-y-4">
      <section class="border border-gray-200 rounded-xl p-4 bg-white space-y-3">
        <div class="flex items-center justify-between gap-3">
          <h2 class="m-0 text-base font-semibold">Auth (single-account)</h2>
          <span data-auth-status class="text-xs px-2 py-1 rounded-full bg-amber-100 text-amber-800">
            Sin sesión
          </span>
        </div>

        <p class="m-0 text-sm text-gray-600">
          Usuario actual: <strong data-auth-user-email>-</strong>
        </p>

        <form data-auth-login-form class="flex flex-col md:flex-row gap-2">
          <input
            data-auth-email
            type="email"
            placeholder="tu-email@dominio.com"
            class="flex-1 border border-gray-200 rounded-lg px-3 py-2 bg-white"
            required
          />
          <button
            type="submit"
            class="inline-flex items-center justify-center rounded-lg bg-gray-900 px-3 py-2 text-sm font-semibold text-white hover:bg-gray-800"
          >
            Enviar magic link
          </button>
        </form>

        <div class="flex items-center gap-2">
          <button
            type="button"
            data-auth-refresh
            class="inline-flex items-center justify-center rounded-lg border border-gray-200 px-3 py-2 text-sm font-semibold hover:bg-gray-50"
          >
            Refrescar estado
          </button>
          <button
            type="button"
            data-auth-logout
            class="inline-flex items-center justify-center rounded-lg border border-red-200 text-red-700 px-3 py-2 text-sm font-semibold hover:bg-red-50"
          >
            Cerrar sesión
          </button>
        </div>

        <p data-auth-feedback class="text-sm text-gray-600 m-0"></p>
      </section>

      <div class="space-y-2">
        <label class="text-sm font-semibold" data-i18n="settings.publicName">Nombre público</label>
        <input
          disabled
          value={profile.publicName}
          class="w-full border border-gray-200 rounded-lg px-3 py-2 bg-gray-50 text-gray-900"
        />
      </div>

      <div class="space-y-2">
        <label class="text-sm font-semibold" data-i18n="settings.publicBio">Bio pública</label>
        <textarea
          disabled
          rows={4}
          value={profile.bio}
          class="w-full border border-gray-200 rounded-lg px-3 py-2 bg-gray-50 text-gray-900"
        />
      </div>
    </div>
  </section>

  <script type="module" src={settingsAuthScriptUrl}></script>
</AppShell>

