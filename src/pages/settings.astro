---
import AppShell from "../layouts/AppShell.astro";
import SettingsPrefsFields from "../components/settings/SettingsPrefsFields.astro";
import SettingsShortcutsBody from "../components/settings/SettingsShortcutsBody.astro";
import SettingsPortfolioProfileBody from "../components/settings/SettingsPortfolioProfileBody.astro";
import SettingsPortfolioClassicBlocks from "../components/settings/SettingsPortfolioClassicBlocks.astro";
import { profile } from "../data";

const title = "Ajustes";

const kbd =
  "inline-flex items-center rounded border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 px-1.5 py-0.5 text-[11px] font-mono font-semibold text-gray-800 dark:text-gray-200 shadow-sm";
---

<AppShell title={title}>
  <div data-requires-auth class="hidden"></div>
  <section class="max-w-7xl mx-auto space-y-8" data-settings-page-root>
    <header class="space-y-2">
      <h1 class="m-0 text-2xl font-semibold">
        <span data-i18n="settings.title">{title}</span>
      </h1>
      <p class="text-sm text-gray-600 dark:text-gray-400 max-w-2xl">
        <span data-i18n="settings.subtitle">
          Personaliza la interfaz, tu perfil público y atajos. Se sincroniza con tu cuenta cuando hayas iniciado sesión.
        </span>
      </p>
    </header>

    <div class="space-y-2">
    <div
      class="flex flex-wrap items-center justify-between gap-x-4 gap-y-3 rounded-xl border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/50 px-3 py-2.5 shadow-sm"
      role="region"
      data-i18n="settings.shell.toolbarLabel"
      data-i18n-attr="aria-label"
    >
      <div class="flex items-center gap-2 min-w-0 flex-1 basis-full sm:basis-auto sm:flex-initial sm:max-w-[min(100%,26rem)]">
        <svg
          class="h-5 w-5 shrink-0 text-gray-500 dark:text-gray-400"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
        <span
          data-auth-status
          class="text-xs px-2 py-1 rounded-full shrink-0 bg-amber-100 text-amber-800 dark:bg-amber-950/50 dark:text-amber-200"
        >
          <span data-auth-status-active class="hidden" data-i18n="settings.auth.sessionActive">Sesión activa</span>
          <span data-auth-status-inactive data-i18n="settings.auth.noSession">Sin sesión</span>
        </span>
        <strong
          data-auth-user-email
          class="text-sm font-medium text-gray-900 dark:text-gray-100 truncate min-w-0"
          >-</strong
        >
      </div>

      <div class="flex flex-wrap items-center justify-end gap-3 sm:gap-4 sm:shrink-0">
        <span class="text-gray-300 dark:text-gray-600 select-none hidden sm:inline" aria-hidden="true">|</span>
        <div class="flex items-center gap-2.5 text-sm text-gray-700 dark:text-gray-200">
          <svg
            class="h-5 w-5 shrink-0 text-gray-500 dark:text-gray-400"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
          </svg>
          <label class="inline-flex flex-wrap items-center gap-2 font-medium">
            <span data-i18n="settings.prefs.theme">Tema</span>
            <select
              data-pref-theme
              class="rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-2.5 py-1.5 text-sm hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors app-accent-ring min-w-40"
            >
              <option value="auto" data-i18n="settings.prefs.themeAuto">Auto (sistema)</option>
              <option value="light" data-i18n="settings.prefs.themeLight">Claro</option>
              <option value="dark" data-i18n="settings.prefs.themeDark">Oscuro</option>
            </select>
          </label>
        </div>
        <div class="flex flex-wrap items-center gap-2 sm:gap-3 text-sm text-gray-700 dark:text-gray-200">
          <span class="text-gray-300 dark:text-gray-600 select-none hidden sm:inline" aria-hidden="true">|</span>
          <button
            type="button"
            data-settings-sidebar-toggle
            class="rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 px-2.5 py-1.5 text-xs font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 motion-safe:transition-colors app-accent-ring"
            aria-pressed="false"
          >
            <span data-settings-sidebar-toggle-label data-i18n="settings.classic.sidebarLeft">Barra: izquierda</span>
          </button>
        </div>
        <div
          class="hidden sm:block w-px h-7 shrink-0 bg-gray-200 dark:bg-gray-700"
          aria-hidden="true"
        >
        </div>
        <div class="flex flex-wrap items-center gap-2 justify-end">
          <button
            type="button"
            data-auth-refresh
            class="inline-flex items-center justify-center rounded-lg border border-gray-200 dark:border-gray-800 px-2.5 py-1.5 text-xs sm:text-sm font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 app-accent-ring"
          >
            <span data-i18n="settings.auth.refresh">Refrescar estado</span>
          </button>
          <button
            type="button"
            data-auth-logout
            class="inline-flex items-center justify-center rounded-lg border border-red-200 dark:border-red-900/50 text-red-700 dark:text-red-300 px-2.5 py-1.5 text-xs sm:text-sm font-semibold hover:bg-red-50 dark:hover:bg-red-950/30"
          >
            <span data-i18n="settings.auth.logout">Cerrar sesión</span>
          </button>
        </div>
      </div>
    </div>

    <div
      data-auth-no-session
      hidden
      class="flex flex-wrap items-center gap-2 rounded-lg border border-amber-200/80 dark:border-amber-900/40 bg-amber-50/60 dark:bg-amber-950/25 px-3 py-2 text-sm text-amber-900 dark:text-amber-100"
    >
      <span data-i18n="settings.auth.noSessionBanner">Inicia sesión para sincronizar tus ajustes.</span>
      <a
        href="/login"
        class="font-semibold text-amber-800 dark:text-amber-200 underline underline-offset-2 hover:opacity-90"
        data-i18n="settings.auth.goToLogin"
      >
        Ir a login
      </a>
    </div>

    <p data-auth-feedback class="text-xs text-gray-600 dark:text-gray-400 m-0 min-h-4"></p>
    </div>

    <div
      class="rounded-xl border border-gray-200/80 dark:border-[#30363d] bg-[#f6f8fa] dark:bg-[#0d1117] shadow-sm overflow-hidden motion-safe:transition-shadow motion-safe:duration-300 dark:shadow-black/30"
    >
      <div data-settings-classic-row class="flex flex-col lg:flex-row gap-0">
        <aside
          class="shrink-0 border-b lg:border-b-0 lg:border-r border-gray-200/80 dark:border-[#30363d] bg-white dark:bg-[#161b22] px-3 py-4 sm:px-4 lg:w-[16rem] lg:sticky lg:top-24 lg:self-start lg:max-h-[calc(100vh-6.5rem)] lg:overflow-y-auto"
        >
          <nav data-settings-classic-nav class="space-y-5" aria-label="Ajustes">
            <div>
              <p class="settings-classic-nav-heading">
                <span data-i18n="settings.classic.navGeneral">General</span>
              </p>
              <div class="mt-1 space-y-0.5">
                <a href="#classic-prefs" data-settings-nav-link class="settings-classic-nav-link">
                  <svg class="settings-nav-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.5"></circle>
                    <path
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      d="M8 1v2M8 13v2M3.05 3.05l1.41 1.41M11.54 11.54l1.41 1.41M1 8h2M13 8h2M3.05 12.95l1.41-1.41M11.54 4.46l1.41-1.41"></path>
                  </svg>
                  <span data-i18n="settings.prefs.sectionTitle">Preferencias</span>
                </a>
                <a href="#classic-shortcuts" data-settings-nav-link class="settings-classic-nav-link">
                  <svg class="settings-nav-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <rect x="2" y="5" width="12" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"></rect>
                    <path stroke="currentColor" stroke-width="1.2" stroke-linecap="round" d="M4.5 7.5h.01M7 7.5h.01M9.5 7.5h.01M12 7.5h.01M5.5 9.8h5"></path>
                  </svg>
                  <span data-i18n="settings.shortcuts.sectionTitle">Atajos</span>
                </a>
              </div>
            </div>
            <div>
              <p class="settings-classic-nav-heading">
                <span data-i18n="settings.classic.navPortfolio">Portfolio y CV</span>
              </p>
              <div class="mt-1 space-y-0.5">
                <a href="#classic-portfolio-profile" data-settings-nav-link class="settings-classic-nav-link">
                  <svg class="settings-nav-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <circle cx="8" cy="5" r="2.5" stroke="currentColor" stroke-width="1.5"></circle>
                    <path
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      d="M3 14c.8-2.3 3.2-4 5-4s4.2 1.7 5 4"></path>
                  </svg>
                  <span data-i18n="settings.portfolio.profileCardTitle">Perfil público</span>
                </a>
                <a href="#classic-portfolio-links" data-settings-nav-link class="settings-classic-nav-link">
                  <svg class="settings-nav-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      d="M6.2 9.8l-1.9 1.9a2 2 0 01-2.8-2.8l1.5-1.5M9.8 6.2l1.9-1.9a2 2 0 012.8 2.8l-1.5 1.5M6 10l4-4"
                    ></path>
                  </svg>
                  <span data-i18n="settings.portfolio.linksCardTitle">Enlaces públicos</span>
                </a>
                <a href="#classic-portfolio-display" data-settings-nav-link class="settings-classic-nav-link">
                  <svg class="settings-nav-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <rect x="2" y="2" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"></rect>
                    <rect x="9" y="2" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"></rect>
                    <rect x="2" y="9" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"></rect>
                    <rect x="9" y="9" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"></rect>
                  </svg>
                  <span data-i18n="settings.portfolio.publicDisplayKicker">Vista pública</span>
                </a>
                <a href="#classic-portfolio-presentation" data-settings-nav-link class="settings-classic-nav-link">
                  <svg class="settings-nav-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" d="M2 5h3M11 5h3M2 8h12M2 11h5M9 11h5"></path>
                    <circle cx="6.5" cy="5" r="1.2" fill="currentColor"></circle>
                    <circle cx="11" cy="8" r="1.2" fill="currentColor"></circle>
                    <circle cx="7.5" cy="11" r="1.2" fill="currentColor"></circle>
                  </svg>
                  <span data-i18n="settings.portfolio.presentationKicker">Presentación</span>
                </a>
                <a href="#classic-cv-public" data-settings-nav-link class="settings-classic-nav-link">
                  <svg class="settings-nav-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linejoin="round"
                      d="M5 2h6l3 3v9a1 1 0 01-1 1H5a1 1 0 01-1-1V3a1 1 0 011-1z"></path>
                    <path stroke="currentColor" stroke-width="1.2" stroke-linecap="round" d="M5 6h6M5 9h4"></path>
                  </svg>
                  <span data-i18n="cv.publicShareTitle">CV público</span>
                </a>
              </div>
            </div>
            <div>
              <p class="settings-classic-nav-heading">
                <span data-i18n="settings.classic.navTools">Herramientas</span>
              </p>
              <div class="mt-1 space-y-0.5">
                <a href="#classic-qa" data-settings-nav-link class="settings-classic-nav-link">
                  <svg class="settings-nav-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linejoin="round"
                      d="M5.5 2h5v3.5L13 12.5a2 2 0 01-2 2H5a2 2 0 01-2-2L5.5 5.5V2z"></path>
                    <path stroke="currentColor" stroke-width="1.2" stroke-linecap="round" d="M5.5 6h5"></path>
                  </svg>
                  <span data-i18n="settings.qa.kicker">Onboarding / QA</span>
                </a>
              </div>
            </div>
          </nav>
        </aside>
        <div
          data-settings-panels-root
          class="settings-panels-root min-w-0 flex-1 px-4 py-8 sm:px-8 lg:px-12 lg:py-10 bg-white dark:bg-[#0d1117] border-l border-transparent lg:border-l-gray-200/80 dark:lg:border-l-[#30363d] overflow-x-hidden"
        >
          <section
            id="classic-prefs"
            data-settings-section="prefs"
            data-settings-panel
            class="settings-classic-panel max-w-3xl pb-10"
            aria-hidden="false"
          >
            <div class="space-y-4 max-w-3xl">
              <div class="flex flex-wrap items-center justify-between gap-3 border-b border-gray-200/90 dark:border-[#30363d] pb-5">
                <h1 class="m-0 text-3xl font-normal tracking-tight text-gray-900 dark:text-gray-100">
                  <span data-i18n="settings.prefs.sectionTitle">Preferencias</span>
                </h1>
                <button
                  type="button"
                  data-pref-reset
                  class="inline-flex items-center justify-center rounded-md border border-gray-200 dark:border-[#30363d] bg-white dark:bg-[#21262d] px-3 py-2 text-xs font-semibold hover:bg-gray-50 dark:hover:bg-[#30363d] motion-safe:transition-colors"
                >
                  <span data-i18n="settings.prefs.reset">Restablecer</span>
                </button>
              </div>
              <SettingsPrefsFields />
              <p class="m-0 text-xs text-gray-600 dark:text-gray-400">
                <span data-i18n="settings.prefs.localFirstHint">
                  Cambios aplicados al instante en toda la app.
                </span>
              </p>
            </div>
          </section>
          <section
            id="classic-shortcuts"
            data-settings-section="shortcuts"
            data-settings-panel
            hidden
            class="settings-classic-panel hidden max-w-3xl pb-10"
            aria-hidden="true"
          >
            <div class="space-y-4 max-w-3xl">
              <h1 class="m-0 text-3xl font-normal tracking-tight text-gray-900 dark:text-gray-100 border-b border-gray-200/90 dark:border-[#30363d] pb-5">
                <span data-i18n="settings.shortcuts.sectionTitle">Atajos de teclado</span>
              </h1>
              <p class="m-0 text-sm text-gray-600 dark:text-gray-400">
                <span data-i18n="settings.shortcuts.intro"
                  >Atajos activos en toda la app (salvo al escribir en un campo).</span
                >
              </p>
              <SettingsShortcutsBody kbd={kbd} />
            </div>
          </section>
          <section
            id="classic-portfolio-profile"
            data-settings-profile-root
            data-settings-section="portfolio_profile"
            data-settings-panel
            hidden
            class="settings-classic-panel hidden max-w-3xl pb-10"
            aria-hidden="true"
          >
            <div class="space-y-4 max-w-3xl">
              <div class="space-y-1 border-b border-gray-200/90 dark:border-[#30363d] pb-5">
                <h1 class="m-0 text-3xl font-normal tracking-tight text-gray-900 dark:text-gray-100">
                  <span data-i18n="settings.portfolio.profileCardTitle">Perfil público</span>
                </h1>
                <p class="m-0 text-sm text-gray-600 dark:text-gray-400">
                  <span data-i18n="settings.portfolio.hint"
                    >Texto que se muestra arriba en tu portfolio público.</span
                  >
                </p>
                <p data-profile-cloud-hint class="m-0 text-xs min-h-4 text-gray-500 dark:text-gray-400"></p>
              </div>
              <SettingsPortfolioProfileBody profile={profile} />
            </div>
          </section>
          <SettingsPortfolioClassicBlocks />
        </div>
      </div>
    </div>

  </section>

  <script src="../scripts/settings-auth.ts"></script>
  <script src="../scripts/settings-prefs.ts"></script>
  <script src="../scripts/settings-classic-ui.ts"></script>
  <script src="../scripts/settings-profile.ts"></script>
  <script src="../scripts/settings-qa.ts"></script>
</AppShell>
