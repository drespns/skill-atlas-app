        </div>
        <button value="close" class="text-xs font-semibold rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-900" data-i18n="common.close">
          Cerrar
        </button>
      </div>

      <div class="mt-4 flex flex-wrap items-center justify-between gap-2">
        <div class="flex items-center gap-2">
          <button type="button" data-study-dossier-copy class="text-xs font-semibold rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-900" data-i18n="study.dossierCopy">
            Copiar
          </button>
          <button type="button" data-study-dossier-export class="text-xs font-semibold rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-900" data-i18n="study.dossierExport">
            Exportar .md
          </button>
        </div>
        <button type="button" data-study-dossier-reapply class="text-xs font-semibold rounded-xl bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 px-3 py-2" data-i18n="study.dossierReapply">
          Reaplicar en búsqueda
        </button>
      </div>

      <div data-study-dossier-view-body class="mt-4 space-y-2 max-h-[70vh] overflow-auto pr-1"></div>
    </form>
  </dialog>

  <script src="@scripts/study/study-workspace.ts"></script>
