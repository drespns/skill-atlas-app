---
import AppShell from "../layouts/AppShell.astro";
import TechnologyCard from "../components/TechnologyCard.astro";

import { dataSource, getConcepts, getTechnologies } from "../data";

const title = "Tecnologías";

const [concepts, mockTechnologies] = await Promise.all([getConcepts(), getTechnologies()]);

const technologies = mockTechnologies.map((t) => ({
  id: t.id,
  name: t.name,
  conceptsCount: concepts.filter((c) => c.technologyId === t.id).length,
}));
---

<AppShell title={title}>
  <div data-requires-auth class="hidden"></div>
  <header class="flex items-center justify-between gap-4 mb-5">
    <h1 class="m-0 text-2xl font-semibold">
      <span data-i18n="technologies.title">{title}</span>
    </h1>
    <div class="flex items-center gap-2">
      {dataSource === "supabase" ? (
        <div
          data-view-toggle
          data-scope="technologies"
          class="hidden sm:inline-flex items-center rounded-lg border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-950/60 p-1"
        >
          <button
            type="button"
            data-view="cards"
            aria-pressed="true"
            class="px-2 py-1 rounded-md text-xs font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 app-accent-ring"
            data-i18n="settings.prefs.viewCards"
          >
            Cards
          </button>
          <button
            type="button"
            data-view="list"
            aria-pressed="false"
            class="px-2 py-1 rounded-md text-xs font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 app-accent-ring"
            data-i18n="settings.prefs.viewList"
          >
            Lista
          </button>
        </div>
      ) : null}

      {dataSource === "supabase" ? (
        <label class="hidden sm:inline-flex items-center gap-2 text-xs font-semibold text-gray-600 dark:text-gray-300 select-none">
          <input type="checkbox" class="accent-indigo-600" data-tech-filter-stack />
          Solo en mi stack
        </label>
      ) : null}

      <span class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-900" data-technologies-count>
        {dataSource === "supabase" ? "…" : `${technologies.length} total`}
      </span>
    </div>
  </header>

  {dataSource === "supabase" ? (
    <form
      data-tech-form
      class="mb-6 border border-gray-200 dark:border-gray-800 rounded-xl p-4 bg-white dark:bg-gray-950 space-y-3"
    >
      <p class="m-0 text-sm font-semibold">
        <span data-i18n="common.newTechnology">Nueva tecnología</span>
      </p>
      <p class="m-0 text-xs text-gray-600 dark:text-gray-400">
        Elige una tecnología del catálogo (hay plantilla de conceptos) o escribe un nombre libre. El <strong>slug</strong> se ajusta solo al elegir del catálogo.
      </p>
      <div class="flex items-center justify-between gap-3">
        <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400">
          Tip: en modo múltiple, escribe varios nombres separados por coma y pulsa Enter.
        </p>
        <div class="flex flex-wrap items-center gap-3">
          <button
            type="button"
            data-tech-github-import
            class="inline-flex items-center rounded-lg border border-indigo-200 dark:border-indigo-800 bg-indigo-50/60 dark:bg-indigo-950/25 px-2.5 py-1.5 text-xs font-semibold text-indigo-800 dark:text-indigo-200 hover:bg-indigo-50 dark:hover:bg-indigo-950/35"
          >
            Importar desde GitHub
          </button>
          <label class="inline-flex items-center gap-2 text-xs font-semibold text-gray-700 dark:text-gray-300 select-none">
            <input type="checkbox" class="accent-indigo-600" data-tech-multi-toggle />
            Modo múltiple
          </label>
        </div>
      </div>
      <div class="flex flex-col md:flex-row gap-2">
        <div class="relative flex-1 min-w-0" data-tech-seed-wrap>
          <div class="flex flex-wrap items-center gap-2 mb-2">
            <label class="inline-flex items-center gap-2 text-[11px] font-semibold text-gray-600 dark:text-gray-400">
              Tipo
              <select
                data-tech-kind
                class="rounded-lg border border-gray-200 dark:border-gray-800 bg-white/80 dark:bg-gray-950/70 px-2 py-1 text-[11px] font-semibold text-gray-800 dark:text-gray-200"
              >
                <option value="all">Todo</option>
                <option value="technology">Tecnología</option>
                <option value="framework">Framework</option>
                <option value="library">Librería</option>
                <option value="package">Paquete</option>
              </select>
            </label>
            <span class="text-[11px] text-gray-500 dark:text-gray-400">“Librerías/paquetes” = subtecnologías.</span>
          </div>
          <input
            name="name"
            type="text"
            placeholder="Buscar: Snowflake, dbt, Power BI… o nombre propio"
            data-tech-name-input
            data-i18n="technologies.newPlaceholder"
            data-i18n-attr="placeholder"
            autocomplete="off"
            class="w-full border border-gray-200 dark:border-gray-800 rounded-lg px-3 py-2 bg-white dark:bg-gray-950"
            required
          />
          <div data-tech-multi-chips class="hidden mt-2 flex-wrap gap-2"></div>
          <ul
            data-tech-seed-suggestions
            class="hidden absolute left-0 right-0 top-full z-30 mt-1 max-h-[min(70vh,28rem)] overflow-auto rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-950 py-1 shadow-lg text-left"
            role="listbox"
          ></ul>
        </div>
        <button
          type="submit"
          class="inline-flex items-center justify-center rounded-lg bg-gray-900 dark:bg-gray-100 px-3 py-2 text-sm font-semibold text-white dark:text-gray-900 hover:bg-gray-800 dark:hover:bg-gray-200"
        >
          <span data-i18n="common.save">Guardar</span>
        </button>
      </div>
      <p data-tech-feedback class="text-sm text-gray-600 m-0"></p>
    </form>
  ) : null}

  {dataSource === "supabase" ? (
    <section
      data-technologies-csr-mount
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 min-h-24"
    >
      <p class="text-sm text-gray-600 col-span-full m-0">Cargando tecnologías…</p>
    </section>
  ) : (
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {technologies.map((tech) => (
        <div class="space-y-2">
          <TechnologyCard technology={tech} />
        </div>
      ))}
    </section>
  )}

  {dataSource === "supabase" ? (
    <script src="../scripts/technologies/technologies.ts"></script>
  ) : null}
  {dataSource === "supabase" ? <script src="../scripts/core/view-toggle.ts"></script> : null}
</AppShell>

