---
import AppShell from "../../layouts/AppShell.astro";

const title = "Bio corta (portfolio / LinkedIn)";
---

<AppShell title={title}>
  <div data-requires-auth class="hidden"></div>
  <section class="space-y-6" data-tools-bio-page>
    <header class="space-y-2">
      <a href="/tools" class="text-sm font-semibold text-gray-700 dark:text-gray-200 hover:underline">← Herramientas</a>
      <h1 class="m-0 text-3xl md:text-4xl font-semibold tracking-tight">{title}</h1>
      <p class="m-0 text-sm text-gray-600 dark:text-gray-400 max-w-2xl">
        Plantillas combinadas con tus datos; revisa y ajusta el texto antes de publicarlo.
      </p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div class="space-y-3 rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 p-4">
        <label class="block space-y-1">
          <span class="text-xs font-semibold text-gray-500 dark:text-gray-400">Rol o titular</span>
          <input type="text" data-bio-role class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-3 py-2 text-sm" placeholder="p. ej. Ingeniero de software" />
        </label>
        <label class="block space-y-1">
          <span class="text-xs font-semibold text-gray-500 dark:text-gray-400">Años de experiencia (número)</span>
          <input type="text" data-bio-years class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-3 py-2 text-sm" placeholder="5" />
        </label>
        <label class="block space-y-1">
          <span class="text-xs font-semibold text-gray-500 dark:text-gray-400">Stack (coma o salto de línea)</span>
          <textarea data-bio-stack rows="3" class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-3 py-2 text-sm" placeholder="TypeScript, React, Node…"></textarea>
        </label>
        <label class="block space-y-1">
          <span class="text-xs font-semibold text-gray-500 dark:text-gray-400">Enfoque / interés (opcional)</span>
          <input type="text" data-bio-focus class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-3 py-2 text-sm" placeholder="p. ej. datos, DX, producto" />
        </label>
        <div class="grid grid-cols-2 gap-2">
          <label class="block space-y-1">
            <span class="text-xs font-semibold text-gray-500 dark:text-gray-400">Tono</span>
            <select data-bio-tone class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-2 py-2 text-sm">
              <option value="neutral">Neutral</option>
              <option value="formal">Formal</option>
              <option value="casual">Cercano</option>
            </select>
          </label>
          <label class="block space-y-1">
            <span class="text-xs font-semibold text-gray-500 dark:text-gray-400">Idioma</span>
            <select data-bio-lang class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-2 py-2 text-sm">
              <option value="es">Español</option>
              <option value="en">English</option>
            </select>
          </label>
        </div>
        <button type="button" data-bio-gen class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">
          Generar variantes
        </button>
      </div>
      <div class="space-y-2 rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 p-4">
        <p class="m-0 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Variante 1</p>
        <textarea data-bio-out1 rows="3" readonly class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/60 px-3 py-2 text-sm"></textarea>
        <p class="m-0 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Variante 2</p>
        <textarea data-bio-out2 rows="3" readonly class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/60 px-3 py-2 text-sm"></textarea>
        <p class="m-0 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Variante 3</p>
        <textarea data-bio-out3 rows="3" readonly class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/60 px-3 py-2 text-sm"></textarea>
      </div>
    </div>
  </section>
  <script src="../../scripts/tools/bio-builder.ts"></script>
</AppShell>
