---
import AppShell from "../../layouts/AppShell.astro";
import SelectPopover from "../../components/ui/SelectPopover.astro";

const title = "Convertidor";
---

<AppShell title={title}>
  <div data-requires-auth class="hidden"></div>
  <section class="space-y-6" data-tools-convert-page>
    <header class="space-y-2">
      <a href="/tools" class="text-sm font-semibold text-gray-700 dark:text-gray-200 hover:underline">← Herramientas</a>
      <h1 class="m-0 text-3xl md:text-4xl font-semibold tracking-tight">{title}</h1>
      <p class="m-0 text-sm md:text-base text-gray-600 dark:text-gray-400 max-w-2xl">
        Primera iteración: UI y flujo. La conversión real (server-side) la trataremos como funcionalidad <strong>Pro</strong>.
      </p>
    </header>

    <section class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 shadow-sm p-5 space-y-4">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_1fr] gap-3 items-end">
        <SelectPopover label="Tipo" data-convert-kind>
            <option value="document">Documento</option>
            <option value="image">Imagen</option>
            <option value="audio">Audio</option>
            <option value="video">Vídeo</option>
        </SelectPopover>
        <div class="hidden md:block"></div>
        <div class="hidden md:block"></div>
        <SelectPopover label="De" data-convert-from></SelectPopover>
        <button
          type="button"
          data-convert-swap
          class="inline-flex items-center justify-center rounded-xl border border-gray-200 dark:border-gray-800 bg-white/70 dark:bg-gray-950/60 px-3 py-2.5 text-sm font-semibold text-gray-800 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900"
          aria-label="Intercambiar formatos"
          title="Intercambiar"
        >
          ⇄
        </button>
        <SelectPopover label="A" data-convert-to></SelectPopover>
      </div>

      <div
        class="rounded-2xl border border-dashed border-gray-300 dark:border-gray-700 bg-gray-50/60 dark:bg-gray-950/35 p-6 sm:p-8"
        data-convert-dropzone
      >
        <div class="flex flex-col items-center text-center gap-3">
          <div class="h-12 w-12 rounded-2xl bg-gray-900 text-white dark:bg-gray-100 dark:text-gray-900 grid place-items-center text-lg font-bold">
            ⬆
          </div>
          <div class="space-y-1">
            <p class="m-0 text-base font-semibold text-gray-900 dark:text-gray-100">Suelta tu archivo aquí</p>
            <p class="m-0 text-sm text-gray-600 dark:text-gray-400">
              o <button type="button" data-convert-pick class="font-semibold underline underline-offset-4">selecciona un archivo</button>
            </p>
          </div>
          <input type="file" data-convert-file class="hidden" />
          <p class="m-0 text-xs text-gray-500 dark:text-gray-400 max-w-xl">
            Gratis: conversiones de <strong>imagen</strong> soportadas en tu navegador. El resto será Pro (server-side).
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-3">
        <div class="lg:col-span-2 rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/40 p-4">
          <div class="flex items-center justify-between gap-3">
            <p class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100">Archivo</p>
          </div>
          <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-3 items-start">
            <div class="rounded-xl border border-gray-200/70 dark:border-gray-800 bg-gray-50/70 dark:bg-gray-950/50 p-3">
              <div class="flex items-center justify-between gap-3">
                <p class="m-0 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Entrada</p>
                <p class="m-0 text-[11px] font-semibold text-gray-500 dark:text-gray-400" data-convert-file-meta></p>
              </div>
              <img data-convert-preview-in class="mt-2 w-full max-h-56 object-contain rounded-lg hidden" alt="" />
              <p class="m-0 mt-2 text-xs text-gray-500 dark:text-gray-400" data-convert-preview-in-hint></p>
            </div>
            <div class="rounded-xl border border-gray-200/70 dark:border-gray-800 bg-gray-50/70 dark:bg-gray-950/50 p-3">
              <p class="m-0 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Salida</p>
              <img data-convert-preview-out class="mt-2 w-full max-h-56 object-contain rounded-lg hidden" alt="" />
              <p class="m-0 mt-2 text-xs text-gray-500 dark:text-gray-400" data-convert-preview-out-hint></p>
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/40 p-4 space-y-3">
          <p class="m-0 text-sm font-semibold text-gray-900 dark:text-gray-100">Conversión</p>
          <button
            type="button"
            data-convert-run
            class="inline-flex w-full items-center justify-center rounded-xl bg-gray-900 dark:bg-gray-100 px-4 py-3 text-sm font-semibold text-white dark:text-gray-900 hover:bg-gray-800 dark:hover:bg-gray-200"
          >
            Convertir
          </button>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            <a
              href="#"
              data-convert-download
              class="hidden w-full text-center rounded-xl border border-gray-200 dark:border-gray-800 bg-white/80 dark:bg-gray-950/50 px-4 py-3 text-sm font-semibold text-gray-900 dark:text-gray-100 no-underline hover:bg-gray-50 dark:hover:bg-gray-900"
              download
            >
              Descargar
            </a>
            <div
              class="rounded-xl border border-emerald-200/70 dark:border-emerald-900/40 bg-emerald-50/80 dark:bg-emerald-950/20 px-3 py-3 text-sm font-semibold text-emerald-900 dark:text-emerald-100 hidden"
              data-convert-ok
            >
              OK
            </div>
          </div>
          <p class="m-0 text-sm text-gray-600 dark:text-gray-400 min-h-10" data-convert-feedback></p>

          <div class="rounded-xl border border-amber-200/90 dark:border-amber-900/50 bg-amber-50/95 dark:bg-amber-950/30 px-4 py-3 text-sm text-amber-950 dark:text-amber-100">
            <p class="m-0 font-semibold">Pro (idea)</p>
            <p class="m-0 mt-1">
              Para no depender de límites tipo “10 archivos/día”, lo haremos con infraestructura propia (y límites claros) y lo marcaremos como Pro.
            </p>
          </div>
        </div>
      </div>
    </section>
  </section>

  <section class="mt-6 rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white/70 dark:bg-gray-950/40 p-5">
    <h2 class="m-0 text-lg font-semibold tracking-tight">Conversiones sin coste (ahora mismo)</h2>
    <p class="m-0 mt-2 text-sm text-gray-600 dark:text-gray-400 max-w-3xl">
      Estas conversiones se hacen <strong>en tu navegador</strong> (sin servidor) y no consumen créditos.
    </p>
    <ul class="m-0 mt-3 pl-5 text-sm text-gray-700 dark:text-gray-300 space-y-1">
      <li><strong>Imagen</strong>: entrada <code>PNG</code>, <code>JPG</code>, <code>WEBP</code> (y <code>SVG</code> rasterizado) → salida <code>PNG</code>/<code>JPG</code>/<code>WEBP</code>.</li>
    </ul>
    <p class="m-0 mt-3 text-xs text-gray-500 dark:text-gray-400">
      Documentos, audio y vídeo se consideran Pro porque normalmente requieren infraestructura server-side o WASM pesado.
    </p>
  </section>

  <script src="../../scripts/tools/convert.ts"></script>
</AppShell>

