    <dialog data-et-sub-dialog class="et-dialog et-sub-dialog p-0 w-[min(100vw-1.5rem,28rem)] max-w-[calc(100vw-1.25rem)]">
      <div class="divide-y divide-gray-100 dark:divide-gray-800 flex flex-col" data-et-sub-form>
        <div class="px-5 py-4 flex items-start justify-between gap-3 shrink-0">
          <div>
            <h3 class="m-0 text-lg font-semibold" data-et-sub-dialog-title>Suscripción</h3>
            <p class="m-0 mt-1 text-xs text-gray-500 dark:text-gray-400">Se usa el importe por ciclo indicado.</p>
          </div>
          <button
            type="button"
            data-et-sub-close
            class="rounded-lg p-2 text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-900"
            aria-label="Cerrar"
          >
            ✕
          </button>
        </div>
        <div class="px-5 py-4 space-y-3">
          <input type="hidden" data-et-sub-id value="" />
          <label class="block space-y-1">
            <span class="text-xs font-semibold text-gray-600 dark:text-gray-300">Nombre</span>
            <input required data-et-sub-name class="et-field w-full text-sm py-2" />
          </label>
          <div class="grid grid-cols-2 gap-3">
            <label class="block space-y-1">
              <span class="text-xs font-semibold text-gray-600 dark:text-gray-300">Importe</span>
              <input required type="number" step="0.01" min="0" data-et-sub-amount class="et-field w-full text-sm py-2 font-mono" />
            </label>
            <label class="block space-y-1">
              <span class="text-xs font-semibold text-gray-600 dark:text-gray-300">Moneda</span>
              <select data-et-sub-currency class="et-field w-full text-sm py-2">
                <option value="EUR">EUR</option>
                <option value="USD">USD</option>
              </select>
            </label>
          </div>
          <label class="block space-y-1">
            <span class="text-xs font-semibold text-gray-600 dark:text-gray-300">Ciclo</span>
            <select data-et-sub-cycle class="et-field w-full text-sm py-2">
              <option value="weekly">Semanal</option>
              <option value="monthly">Mensual</option>
              <option value="quarterly">Trimestral</option>
              <option value="yearly">Anual</option>
            </select>
          </label>
          <label class="block space-y-1">
            <span class="text-xs font-semibold text-gray-600 dark:text-gray-300">Categoría</span>
            <select data-et-sub-category class="et-field w-full text-sm py-2"></select>
          </label>
          <label class="block space-y-1">
            <span class="text-xs font-semibold text-gray-600 dark:text-gray-300">Desde (primer cargo / inicio)</span>
            <input type="date" data-et-sub-billing-start class="et-field w-full text-sm py-2" />
          </label>
          <p class="m-0 text-[11px] text-gray-500 dark:text-gray-400" data-et-sub-next-hint>
            Con la fecha de inicio y el ciclo se calcula el próximo cobro (p. ej. mensual → mes siguiente).
          </p>
          <label class="flex items-center gap-2 text-sm font-medium">
            <input type="checkbox" data-et-sub-active class="h-4 w-4 rounded border-gray-300 text-indigo-600" checked />
            Activa (cuenta en totales)
          </label>
          <label class="block space-y-1">
            <span class="text-xs font-semibold text-gray-600 dark:text-gray-300">Etiquetas (coma)</span>
            <input type="text" data-et-sub-tags class="et-field w-full text-sm py-2" placeholder="cloud, trabajo" />
          </label>
          <label class="block space-y-1">
            <span class="text-xs font-semibold text-gray-600 dark:text-gray-300">Notas</span>
            <textarea data-et-sub-notes rows="2" class="et-field et-textarea w-full text-sm py-2 min-h-[3.25rem]"></textarea>
          </label>
        </div>
        <div class="px-5 py-4 flex items-center justify-between gap-2 bg-gray-50/80 dark:bg-gray-900/40 shrink-0">
          <button type="button" data-et-sub-delete class="text-sm font-semibold text-red-600 dark:text-red-400 hover:underline">
            Eliminar
          </button>
          <div class="flex gap-2">
            <button type="button" data-et-sub-cancel class="et-btn-secondary text-sm py-2">Cancelar</button>
            <button type="button" data-et-sub-save class="et-btn-primary text-sm py-2">Guardar</button>
          </div>
        </div>
      </div>
    </dialog>

    <dialog data-et-dlg-alert class="et-dialog w-[min(100vw-1.5rem,24rem)] p-0">
      <div class="et-dialog-panel space-y-4">
        <p class="m-0 text-sm text-gray-700 dark:text-gray-200" data-et-dlg-alert-msg></p>
        <div class="flex justify-end">
          <button type="button" class="et-btn-primary text-sm py-2" data-et-dlg-alert-ok>Aceptar</button>
        </div>
      </div>
    </dialog>

    <dialog data-et-dlg-confirm class="et-dialog w-[min(100vw-1.5rem,26rem)] p-0">
      <div class="et-dialog-panel space-y-4">
        <p class="m-0 text-sm text-gray-700 dark:text-gray-200" data-et-dlg-confirm-msg></p>
        <div class="flex justify-end gap-2">
          <button type="button" class="et-btn-secondary text-sm py-2" data-et-dlg-confirm-cancel>Cancelar</button>
          <button type="button" class="et-btn-primary text-sm py-2" data-et-dlg-confirm-ok data-et-dlg-confirm-ok-label>Continuar</button>
        </div>
      </div>
    </dialog>

    <dialog data-et-dlg-import class="et-dialog w-[min(100vw-1.5rem,28rem)] p-0">
      <div class="et-dialog-panel space-y-4">
        <h3 class="m-0 text-base font-semibold text-gray-900 dark:text-gray-50">Importar cuaderno</h3>
        <p class="m-0 text-sm text-gray-600 dark:text-gray-400" data-et-dlg-import-hint></p>
        <div class="flex flex-col-reverse sm:flex-row sm:justify-end gap-2 pt-1">
          <button type="button" class="et-btn-secondary text-sm py-2" data-et-dlg-import-cancel>Cancelar</button>
          <button type="button" class="et-btn-dashed text-sm py-2" data-et-dlg-import-replace>Sustituir datos</button>
          <button type="button" class="et-btn-primary text-sm py-2" data-et-dlg-import-merge>Fusionar por id</button>
        </div>
      </div>
    </dialog>

    <dialog data-et-dlg-link class="et-dialog w-[min(100vw-1.5rem,26rem)] p-0">
      <div class="et-dialog-panel space-y-3">
        <h3 class="m-0 text-base font-semibold text-gray-900 dark:text-gray-50">Añadir enlace</h3>
        <label class="block space-y-1">
          <span class="text-xs font-semibold text-gray-600 dark:text-gray-300">Título</span>
          <input type="text" class="et-field w-full text-sm py-2" data-et-dlg-link-title placeholder="Factura, portal…" />
        </label>
        <label class="block space-y-1">
          <span class="text-xs font-semibold text-gray-600 dark:text-gray-300">URL (https)</span>
          <input type="url" class="et-field w-full text-sm py-2 font-mono" data-et-dlg-link-url placeholder="https://…" />
        </label>
        <div class="flex justify-end gap-2 pt-1">
          <button type="button" class="et-btn-secondary text-sm py-2" data-et-dlg-link-cancel>Cancelar</button>
          <button type="button" class="et-btn-primary text-sm py-2" data-et-dlg-link-save>Guardar</button>
        </div>
      </div>
    </dialog>

    <dialog data-et-dlg-category class="et-dialog et-dialog-narrow w-[min(100vw-1.5rem,26rem)] max-w-[calc(100vw-1.25rem)] p-0 overflow-x-hidden">
      <div class="et-dialog-panel et-dialog-panel--fit space-y-3">
        <h3 class="m-0 text-base font-semibold text-gray-900 dark:text-gray-50">Nueva categoría</h3>
        <label class="block space-y-1">
          <span class="text-xs font-semibold text-gray-600 dark:text-gray-300">Nombre</span>
          <input type="text" class="et-field w-full text-sm py-2" data-et-dlg-cat-name placeholder="p. ej. Netflix" />
        </label>
        <label class="block space-y-1">
          <span class="text-xs font-semibold text-gray-600 dark:text-gray-300">Dentro de (opcional)</span>
          <select class="et-field w-full text-sm py-2" data-et-dlg-cat-parent></select>
        </label>
        <p class="m-0 text-xs text-gray-500 dark:text-gray-400">Si eliges una categoría padre, esta fila será una subcategoría (se suma al padre en gráficos).</p>
        <div class="flex justify-end gap-2 pt-1">
          <button type="button" class="et-btn-secondary text-sm py-2" data-et-dlg-cat-cancel>Cancelar</button>
          <button type="button" class="et-btn-primary text-sm py-2" data-et-dlg-cat-save>Crear</button>
        </div>
      </div>
    </dialog>

    <dialog data-et-dlg-e2e-set class="et-dialog w-[min(100vw-1.5rem,26rem)] p-0">
      <div class="et-dialog-panel space-y-3">
        <h3 class="m-0 text-base font-semibold text-gray-900 dark:text-gray-50">Frase del cuaderno</h3>
        <p class="m-0 text-xs text-gray-500 dark:text-gray-400 leading-relaxed">
          Es la <strong class="font-medium text-gray-700 dark:text-gray-300">clave secreta</strong> con la que se bloquea o desbloquea la copia en la nube. Solo existe en esta pestaña: no la enviamos al servidor. Mínimo 8 caracteres; inventa la tuya (p. ej. <span class="font-mono text-[11px] text-gray-700 dark:text-gray-300">gatos-Luna-cafe-2026</span>).
        </p>
        <label class="block space-y-1">
          <span class="text-xs font-semibold text-gray-600 dark:text-gray-300">Escribe la frase</span>
          <input type="password" class="et-field w-full text-sm py-2" data-et-dlg-e2e-p1 autocomplete="new-password" />
        </label>
        <label class="block space-y-1">
          <span class="text-xs font-semibold text-gray-600 dark:text-gray-300">Repite la misma frase</span>
          <input type="password" class="et-field w-full text-sm py-2" data-et-dlg-e2e-p2 autocomplete="new-password" />
        </label>
        <div class="flex justify-end gap-2 pt-1">
          <button type="button" class="et-btn-secondary text-sm py-2" data-et-dlg-e2e-set-cancel>Cancelar</button>
          <button type="button" class="et-btn-primary text-sm py-2" data-et-dlg-e2e-set-save>Guardar</button>
        </div>
      </div>
    </dialog>

    <dialog data-et-dlg-e2e-unlock class="et-dialog w-[min(100vw-1.5rem,26rem)] p-0">
      <div class="et-dialog-panel space-y-3">
        <h3 class="m-0 text-base font-semibold text-gray-900 dark:text-gray-50">Desbloquear copia en la nube</h3>
        <p class="m-0 text-xs text-gray-500 dark:text-gray-400 leading-relaxed">
          Escribe la <strong class="font-medium text-gray-700 dark:text-gray-300">misma frase del cuaderno</strong> que usaste cuando protegiste esa copia. Así esta hoja y la de la nube pueden fusionarse.
        </p>
        <label class="block space-y-1">
          <span class="text-xs font-semibold text-gray-600 dark:text-gray-300">Frase del cuaderno</span>
          <input type="password" class="et-field w-full text-sm py-2" data-et-dlg-e2e-unlock-pass autocomplete="current-password" />
        </label>
        <div class="flex justify-end gap-2 pt-1">
          <button type="button" class="et-btn-secondary text-sm py-2" data-et-dlg-e2e-unlock-cancel>Cancelar</button>
          <button type="button" class="et-btn-primary text-sm py-2" data-et-dlg-e2e-unlock-go>Desbloquear</button>
        </div>
      </div>
    </dialog>
  </section>

  <style is:global>
