---
import AppShell from "../../layouts/AppShell.astro";

const title = "Checklist pre-entrevista";
---

<AppShell title={title}>
  <div data-requires-auth class="hidden"></div>
  <section class="space-y-6" data-tools-interview-page>
    <header class="space-y-2">
      <a href="/tools" class="text-sm font-semibold text-gray-700 dark:text-gray-200 hover:underline">← Herramientas</a>
      <h1 class="m-0 text-3xl md:text-4xl font-semibold tracking-tight">{title}</h1>
      <p class="m-0 text-sm text-gray-600 dark:text-gray-400 max-w-2xl">
        Lista local en tu navegador. Exporta/importa JSON para hacer copias o mover de dispositivo.
      </p>
    </header>

    <div class="max-w-lg space-y-4 rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 p-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <label class="block space-y-1">
          <span class="text-xs font-semibold text-gray-500 dark:text-gray-400">Empresa</span>
          <input type="text" data-int-company class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-3 py-2 text-sm" />
        </label>
        <label class="block space-y-1">
          <span class="text-xs font-semibold text-gray-500 dark:text-gray-400">Rol</span>
          <input type="text" data-int-role class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-3 py-2 text-sm" />
        </label>
      </div>
      <div class="space-y-2" data-int-list></div>
      <div class="flex flex-col sm:flex-row gap-2">
        <input type="text" data-int-new class="flex-1 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-3 py-2 text-sm" placeholder="Nueva tarea…" />
        <button type="button" data-int-add class="rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Añadir</button>
      </div>
      <div class="flex flex-wrap gap-2 pt-2 border-t border-gray-200 dark:border-gray-800">
        <button type="button" data-int-export class="rounded-lg border border-gray-200 dark:border-gray-700 px-3 py-2 text-sm font-semibold hover:bg-gray-50 dark:hover:bg-gray-900">
          Exportar JSON
        </button>
        <label class="inline-flex items-center gap-2 rounded-lg border border-gray-200 dark:border-gray-700 px-3 py-2 text-sm font-semibold cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-900">
          Importar
          <input type="file" accept="application/json,.json" class="sr-only" data-int-import />
        </label>
      </div>
    </div>
  </section>
  <script src="../../scripts/tools/interview-prep.ts"></script>
</AppShell>
