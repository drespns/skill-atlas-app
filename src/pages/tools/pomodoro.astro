---
import AppShell from "../../layouts/AppShell.astro";

const title = "Pomodoro";
---

<AppShell title={title}>
  <div data-requires-auth class="hidden"></div>
  <section class="space-y-6" data-tools-pomodoro-page>
    <header class="space-y-2">
      <a href="/tools" class="text-sm font-semibold text-gray-700 dark:text-gray-200 hover:underline">← Herramientas</a>
      <h1 class="m-0 text-3xl md:text-4xl font-semibold tracking-tight">{title}</h1>
      <p class="m-0 text-sm text-gray-600 dark:text-gray-400 max-w-2xl">
        Temporizador en el navegador. Cuenta pomodoros completados hoy (localStorage).
      </p>
    </header>

    <div class="max-w-md mx-auto text-center space-y-4 rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 p-8">
      <p class="m-0 text-sm font-semibold text-indigo-600 dark:text-indigo-400" data-pomo-phase>Enfoque</p>
      <p class="m-0 text-5xl sm:text-6xl font-mono font-bold tabular-nums text-gray-900 dark:text-gray-100" data-pomo-display>25:00</p>
      <p class="m-0 text-xs text-gray-500 dark:text-gray-400" data-pomo-stat>Pomodoros hoy: 0</p>
      <div class="flex flex-wrap justify-center gap-2 justify-items-center">
        <label class="flex items-center gap-1 text-xs text-gray-600 dark:text-gray-400">
          Trabajo (min)
          <input type="number" data-pomo-work min="1" max="120" value="25" class="w-16 rounded border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-2 py-1" />
        </label>
        <label class="flex items-center gap-1 text-xs text-gray-600 dark:text-gray-400">
          Descanso (min)
          <input type="number" data-pomo-break min="1" max="60" value="5" class="w-14 rounded border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-2 py-1" />
        </label>
      </div>
      <div class="flex flex-wrap justify-center gap-2">
        <button type="button" data-pomo-start class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-500">Iniciar</button>
        <button type="button" data-pomo-pause class="rounded-lg border border-gray-200 dark:border-gray-700 px-4 py-2 text-sm font-semibold hover:bg-gray-50 dark:hover:bg-gray-900">Pausa</button>
        <button type="button" data-pomo-reset class="rounded-lg border border-gray-200 dark:border-gray-700 px-4 py-2 text-sm font-semibold hover:bg-gray-50 dark:hover:bg-gray-900">Reiniciar</button>
      </div>
    </div>
  </section>
  <script src="../../scripts/tools/pomodoro.ts"></script>
</AppShell>
