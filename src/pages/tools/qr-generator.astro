---
import AppShell from "../../layouts/AppShell.astro";

const title = "Código QR";
---

<AppShell title={title}>
  <div data-requires-auth class="hidden"></div>
  <section class="space-y-6" data-tools-qr-page>
    <header class="space-y-2">
      <a href="/tools" class="text-sm font-semibold text-gray-700 dark:text-gray-200 hover:underline">← Herramientas</a>
      <h1 class="m-0 text-3xl md:text-4xl font-semibold tracking-tight">{title}</h1>
      <p class="m-0 text-sm text-gray-600 dark:text-gray-400 max-w-2xl">URL o texto corto → QR PNG en el navegador.</p>
    </header>

    <div class="max-w-md space-y-4 rounded-2xl border border-gray-200/80 dark:border-gray-800 bg-white dark:bg-gray-950 p-4">
      <label class="block space-y-1">
        <span class="text-xs font-semibold text-gray-500 dark:text-gray-400">Contenido</span>
        <input type="text" data-qr-text class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-3 py-2 text-sm" placeholder="https://…" />
      </label>
      <div class="flex flex-wrap gap-2">
        <button type="button" data-qr-gen class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Generar</button>
        <button type="button" data-qr-dl class="rounded-lg border border-gray-200 dark:border-gray-700 px-4 py-2 text-sm font-semibold hover:bg-gray-50 dark:hover:bg-gray-900">Descargar PNG</button>
      </div>
      <p class="m-0 text-xs text-rose-600 dark:text-rose-400" data-qr-err></p>
      <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white p-4 inline-block">
        <canvas width="240" height="240" data-qr-canvas class="block"></canvas>
      </div>
    </div>
  </section>
  <script src="../../scripts/tools/qr-generator.ts"></script>
</AppShell>
