---
import AppShell from "../../layouts/AppShell.astro";

const title = "Estimación bruto → neto";
---

<AppShell title={title}>
  <div data-requires-auth class="hidden"></div>
  <section class="space-y-6" data-tools-salary-page>
    <header class="space-y-2">
      <a href="/tools" class="text-sm font-semibold text-gray-700 dark:text-gray-200 hover:underline">← Herramientas</a>
      <h1 class="m-0 text-3xl md:text-4xl font-semibold tracking-tight">{title}</h1>
      <p class="m-0 text-sm text-gray-600 dark:text-gray-400 max-w-2xl">
        Cálculo orientativo: aplica un porcentaje único de retención sobre el bruto. No sustituye asesoría fiscal ni nómina real.
      </p>
    </header>

    <div class="max-w-md space-y-4 rounded-2xl border border-amber-200/80 dark:border-amber-900/50 bg-amber-50/50 dark:bg-amber-950/20 p-4">
      <p class="m-0 text-xs text-amber-900 dark:text-amber-200/90">
        <strong>Aviso:</strong> impuestos y cotizaciones dependen de país, convenio y situación personal. Usa solo como orden de magnitud.
      </p>
      <label class="block space-y-1">
        <span class="text-xs font-semibold text-gray-600 dark:text-gray-400">Importe bruto</span>
        <input type="text" data-sal-gross class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-3 py-2 text-sm" placeholder="3000" />
      </label>
      <label class="block space-y-1">
        <span class="text-xs font-semibold text-gray-600 dark:text-gray-400">Retención aproximada: <span data-sal-tax-val>25</span>%</span>
        <input type="range" data-sal-tax min="0" max="50" value="25" class="w-full accent-indigo-600" />
      </label>
      <label class="block space-y-1">
        <span class="text-xs font-semibold text-gray-600 dark:text-gray-400">Periodo del bruto indicado</span>
        <select data-sal-period class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-2 py-2 text-sm">
          <option value="month">Mensual</option>
          <option value="year">Anual</option>
        </select>
      </label>
      <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-950 p-3 space-y-1 text-sm">
        <p class="m-0 text-gray-600 dark:text-gray-400">Neto mensual estimado</p>
        <p class="m-0 text-2xl font-bold text-gray-900 dark:text-gray-100" data-sal-net>0</p>
        <p class="m-0 text-xs text-gray-500 dark:text-gray-400">Neto anual estimado: <span data-sal-year>0</span></p>
      </div>
    </div>
  </section>
  <script src="../../scripts/tools/salary-estimate.ts"></script>
</AppShell>
