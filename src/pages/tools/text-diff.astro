---
import AppShell from "../../layouts/AppShell.astro";

const title = "Diff de texto";
---

<AppShell title={title}>
  <div data-requires-auth class="hidden"></div>
  <section class="space-y-6" data-tools-diff-page>
    <header class="space-y-2">
      <a href="/tools" class="text-sm font-semibold text-gray-700 dark:text-gray-200 hover:underline">← Herramientas</a>
      <h1 class="m-0 text-3xl md:text-4xl font-semibold tracking-tight">{title}</h1>
      <p class="m-0 text-sm text-gray-600 dark:text-gray-400 max-w-2xl">
        Comparación línea a línea: verde añadido, rojo eliminado (respecto al texto A → B).
      </p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
      <label class="block space-y-1">
        <span class="text-xs font-semibold text-gray-500 dark:text-gray-400">Texto A</span>
        <textarea data-diff-a rows="14" class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-3 py-2 text-sm font-mono"></textarea>
      </label>
      <label class="block space-y-1">
        <span class="text-xs font-semibold text-gray-500 dark:text-gray-400">Texto B</span>
        <textarea data-diff-b rows="14" class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-3 py-2 text-sm font-mono"></textarea>
      </label>
    </div>
    <button type="button" data-diff-run class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Comparar</button>
    <div data-diff-out></div>
  </section>
  <script src="../../scripts/tools/text-diff.ts"></script>
</AppShell>
